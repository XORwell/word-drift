# How many drift events of each type are in the graph?
PREFIX drift: <https://w3id.org/word-drift/ontology#>
PREFIX skos:  <http://www.w3.org/2004/02/skos/core#>

SELECT ?type (COUNT(?e) AS ?n) WHERE {
    ?e a drift:DriftEvent ;
       drift:driftType ?t .
    ?t skos:prefLabel ?type .
    FILTER(lang(?type) = "en")
}
GROUP BY ?type
ORDER BY DESC(?n) ?type
