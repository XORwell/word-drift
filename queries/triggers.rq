# The causal join (ADR 0004): which proposed trigger is associated with which
# shift, in which category, with what confidence. Causation runs through
# drift:CausalHypothesis, never a direct shortcut.
PREFIX drift: <https://w3id.org/word-drift/ontology#>
PREFIX skos:  <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?word ?type ?year ?trigger ?category ?confidence WHERE {
    ?h a drift:CausalHypothesis ;
       drift:aboutDrift ?e ;
       drift:proposedTrigger ?tr ;
       drift:confidence ?confidence .
    ?e drift:affectsWord ?w ;
       drift:driftType ?t .
    ?w drift:writtenForm ?word .
    ?t skos:prefLabel ?type .
    FILTER(lang(?type) = "en")
    ?tr rdfs:label ?trigger ;
        drift:triggerCategory ?cat ;
        drift:eventDate ?year .
    FILTER(lang(?trigger) = "en")
    ?cat skos:prefLabel ?category .
}
ORDER BY ?year ?word
