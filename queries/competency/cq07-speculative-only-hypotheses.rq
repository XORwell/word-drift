# CQ07 — Hypotheses resting ONLY on speculative evidence.
# The evidence ladder (ADR 0004 / concept §3) says a hypothesis is "supported"
# only if it carries at least one NON-speculative evidence type. This query
# returns the hypotheses that violate that intent: every evidence type they
# carry is drift:Speculative.
#
# NOTE: this is a *quality* probe, not currently a SHACL hard constraint. The
# SHACL shape (causal-hypothesis-shape.ttl) requires >=1 evidence type but does
# NOT require a non-speculative one, so this query can return rows even on a
# graph that fully conforms. See data/reports/oops-scan.md (P-WD-1) for the
# recommended fix. Non-empty here flags curation debt, not a parse/run failure.
PREFIX drift: <https://w3id.org/word-drift/ontology#>

SELECT ?hypothesis ?word ?confidence WHERE {
  ?h a drift:CausalHypothesis ;
     drift:aboutDrift ?e ;
     drift:confidence ?confidence .
  ?e drift:affectsWord ?w .
  ?w drift:writtenForm ?word .
  FILTER NOT EXISTS {
    ?h drift:evidenceType ?ev .
    FILTER(?ev != drift:Speculative)
  }
  BIND(STRAFTER(STR(?h), "resource/") AS ?hypothesis)
}
ORDER BY DESC(?confidence) ?word
