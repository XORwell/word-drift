# Cross-lingual roll-up: drift events grouped by language and type.
# Foundation for "same direction of drift across DE and EN" analyses.
PREFIX drift: <https://w3id.org/word-drift/ontology#>
PREFIX skos:  <http://www.w3.org/2004/02/skos/core#>

SELECT ?language ?type (COUNT(?e) AS ?n) (GROUP_CONCAT(?word; SEPARATOR=", ") AS ?words) WHERE {
    ?e a drift:DriftEvent ;
       drift:affectsWord ?w ;
       drift:driftType ?t .
    ?w drift:language ?language ;
       drift:writtenForm ?word .
    ?t skos:prefLabel ?type .
    FILTER(lang(?type) = "en")
}
GROUP BY ?language ?type
ORDER BY ?language ?type
