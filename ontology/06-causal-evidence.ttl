@prefix drift: <https://w3id.org/word-drift/ontology#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix dct:   <http://purl.org/dc/terms/> .

# =============================================================
# WORD-DRIFT — Module 06: Causal hypothesis + evidence (ADR 0004)
# Causation is a CLAIM, not a fact. We do not assert that an event
# caused a shift; we record a reified, graded, evidence-bearing
# hypothesis that the shift is ASSOCIATED with the event. Multiple
# competing hypotheses per drift event are expected.
# This is the ONLY way to express causation: there is no shortcut
# property. Queries join Word -> DriftEvent -> CausalHypothesis ->
# TriggerEvent.
# =============================================================

drift:CausalHypothesis a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "causal hypothesis"@en , "Kausalhypothese"@de ;
    rdfs:comment "A reified, evidenced proposal that a drift event is associated with a trigger event. The authoritative carrier of confidence and evidence; drift:triggeredBy is only its human-readable shortcut. Several may compete for one drift event."@en .

drift:aboutDrift a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "about drift"@en ;
    rdfs:domain drift:CausalHypothesis ;
    rdfs:range drift:DriftEvent ;
    rdfs:comment "Functional: a hypothesis explains exactly one drift event. A claim spanning several events is split into one hypothesis each."@en .

drift:proposedTrigger a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:label "proposed trigger"@en ;
    rdfs:domain drift:CausalHypothesis ;
    rdfs:range drift:TriggerEvent ;
    rdfs:comment "The event this hypothesis proposes as associated with the shift. Proposed, not proven. Functional: one hypothesis proposes one trigger; competing triggers are competing hypotheses."@en .

drift:evidenceType a owl:ObjectProperty ;
    rdfs:label "evidence type"@en ;
    rdfs:domain drift:CausalHypothesis ;
    rdfs:range skos:Concept ;
    rdfs:comment "What kind of evidence backs this hypothesis, from drift:EvidenceTypeScheme."@en .

# drift:confidence (module 04, domain CausalHypothesis) and drift:hasSource
# (module 05) are required here by SHACL. prov:wasAttributedTo records who
# proposes the hypothesis; dct:date when.

# =============================================================
# Evidence ladder (SKOS), ordered weak to strong. A hypothesis is
# "supported" only if it carries at least one NON-speculative type.
# =============================================================

drift:EvidenceTypeScheme a skos:ConceptScheme ;
    skos:prefLabel "Evidence type"@en ;
    rdfs:comment "Typology of evidence for a causal hypothesis, from speculative to reproducible to attributed."@en .

drift:Speculative a skos:Concept ; skos:inScheme drift:EvidenceTypeScheme ;
    skos:prefLabel "speculative (temporal coincidence)"@en ;
    skos:definition "Drift year roughly coincides with the event, asserted by the curator only. Correlation, easily spurious. Never sufficient alone."@en .

drift:FrequencyCorrelation a skos:Concept ; skos:inScheme drift:EvidenceTypeScheme ;
    skos:prefLabel "frequency correlation"@en ;
    skos:definition "The word's frequency curve (drift:FrequencyObservation) spikes at the event. Reproducible from a public corpus, independent of the curator."@en .

drift:ChangeSignalAlignment a skos:Concept ; skos:inScheme drift:EvidenceTypeScheme ;
    skos:prefLabel "change-signal alignment"@en ;
    skos:definition "The diachronic usage-graph or embedding change signal (DWUG / SemEval) aligns with the event date. Strongest reproducible evidence: the field's own change measure."@en .

drift:LexicographicNote a skos:Concept ; skos:inScheme drift:EvidenceTypeScheme ;
    skos:prefLabel "lexicographic note"@en ;
    skos:definition "A dictionary etymology note states the link. Attributed evidence, not the curator's own claim."@en .

drift:ScholarlyAttestation a skos:Concept ; skos:inScheme drift:EvidenceTypeScheme ;
    skos:prefLabel "scholarly attestation"@en ;
    skos:definition "A peer-reviewed study states the link. Strongest attributed evidence."@en .
