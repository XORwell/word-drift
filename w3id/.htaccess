# WORD-DRIFT — w3id.org persistent-identifier redirect config
# ---------------------------------------------------------------------------
# Deployed (by a human, via PR) to:  github.com/perma-id/w3id.org → word-drift/
# Serves the persistent base:        https://w3id.org/word-drift/
#
# Strategy: content negotiation.
#   - RDF requests (Turtle / RDF/XML / N-Triples / JSON-LD) and *.ttl URLs
#     → Gitea raw files in the repository (the canonical machine-readable data).
#   - Everything else (HTML / browsers) → the static browse & visualization site.
#
# NOTE: w3id.org runs Apache with mod_rewrite + mod_headers enabled and
# AllowOverride for FollowSymLinks/Indexes. Keep this file conservative;
# the perma-id maintainers review every PR.
# ---------------------------------------------------------------------------

Options +FollowSymLinks
RewriteEngine On

# --- Ontology namespace: https://w3id.org/word-drift/ontology# --------------
# The drift: vocabulary lives in the repo's ontology/ modules. Send RDF clients
# to the raw concatenated/individual Turtle; humans to the repo's ontology view.

# Turtle (explicit Accept) for the ontology root
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [OR]
RewriteCond %{HTTP_ACCEPT} application/n-triples [OR]
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^ontology/?$ https://raw.githubusercontent.com/XORwell/word-drift/main/ontology/01-lexical.ttl [R=303,L]

# HTML / default for the ontology
RewriteRule ^ontology/?$ https://github.com/XORwell/word-drift/tree/main/ontology [R=302,L]

# --- Resource namespace: https://w3id.org/word-drift/resource/{slug} --------
# Each curated word slug maps to its Turtle file in examples/.
# Example: https://w3id.org/word-drift/resource/word-querdenker
#          → examples/querdenker.ttl  (raw) for RDF clients
#          → the site explore view    for browsers
#
# The {slug} after "word-" / "sense-" etc. is the example file stem; we strip
# the typed prefix to recover the file name.

# RDF clients → raw Turtle (best-effort: word-<stem> → examples/<stem>.ttl)
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [OR]
RewriteCond %{HTTP_ACCEPT} application/n-triples [OR]
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^resource/word-([^/]+)/?$ https://raw.githubusercontent.com/XORwell/word-drift/main/examples/$1.ttl [R=303,L]

# Browsers → site explore page, carrying the slug as a query parameter
RewriteRule ^resource/word-([^/]+)/?$ https://w3id.org/word-drift/site/explore.html?word=$1 [R=302,L]

# Any other resource IRI (sense-, drift-, trigger-, hypothesis-…) → repo search
RewriteRule ^resource/(.+)$ https://github.com/XORwell/word-drift/search?q=$1 [R=302,L]

# --- Dataset metadata: VoID / DCAT / Croissant ------------------------------
RewriteRule ^void(\.ttl)?$       https://raw.githubusercontent.com/XORwell/word-drift/main/dataset-metadata/void.ttl       [R=303,L]
RewriteRule ^dcat(\.ttl)?$       https://raw.githubusercontent.com/XORwell/word-drift/main/dataset-metadata/dcat.ttl       [R=303,L]
RewriteRule ^croissant(\.jsonld)?$ https://raw.githubusercontent.com/XORwell/word-drift/main/dataset-metadata/croissant.jsonld [R=303,L]

# --- SPARQL endpoint placeholder --------------------------------------------
# Replace the target with the live qlever endpoint once deployed.
RewriteRule ^sparql/?$ https://github.com/XORwell/word-drift/tree/main/scripts/load-qlever.sh [R=302,L]

# --- Static site passthrough ------------------------------------------------
# https://w3id.org/word-drift/site/... → the deployed static site host.
# Replace SITE_HOST with the real site origin on deployment.
RewriteRule ^site/(.*)$ https://raw.githubusercontent.com/XORwell/word-drift/main/site/$1 [R=302,L]

# --- Default / root ---------------------------------------------------------
# Bare https://w3id.org/word-drift/ → the repository landing page.
RewriteRule ^$ https://github.com/XORwell/word-drift [R=302,L]
