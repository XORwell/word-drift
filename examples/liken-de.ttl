@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# =============================================================
# "liken" (de) -- cross-lingual pair with "like" (like.ttl)
# Metonymization (loanword):
#   English social-media "to like" entered German as "liken":
#   einen Social-Media-Beitrag mit dem Gefaellt-mir-Button
#   markieren. Driven by the Facebook Like button (2009) and the
#   German "Gefaellt mir" feature.
# =============================================================

wdr:word-liken a drift:Word ;
    drift:writtenForm "liken"@de ;
    drift:language "de" ;
    rdfs:label "liken"@de ;
    ontolex:sense wdr:sense-liken-social ;
    drift:crossLingualOf wdr:word-like .

wdr:sense-liken-social a drift:Sense ;
    drift:gloss "to like: to register approval of a social-media post via the Like button"@en ;
    drift:gloss "einen Social-Media-Beitrag mit dem Gefaellt-mir-Button markieren; positiv bewerten"@de ;
    drift:connotation drift:Positive ;
    drift:firstAttested "2010"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "2010"^^xsd:gYear ]
    ] .

# A German base sense (the loan stem before the social meaning fixed it).
wdr:sense-liken-base a drift:Sense ;
    drift:gloss "to like (borrowed verb stem, before the social-media sense fixed)"@en ;
    drift:gloss "moegen, gut finden (entlehnter Verbstamm, vor Verfestigung der Social-Media-Bedeutung)"@de ;
    drift:connotation drift:Positive ;
    drift:firstAttested "2008"^^xsd:gYear .

# --- trigger events ---
wdr:trigger-facebook-like a drift:TriggerEvent ;
    rdfs:label "Facebook Like button launch (2009)"@en ;
    dct:description "Facebook launched its 'Like' button (German 'Gefaellt mir') in 2009; the feature made the borrowed verb 'liken' the common German term for one-click social endorsement."@en ;
    drift:eventDate "2009"^^xsd:gYear ;
    drift:triggerCategory drift:Technology ;
    owl:sameAs wd:Q355 .

# --- drift event: metonymization (causation lives in the hypothesis below) ---
wdr:drift-liken-social a drift:DriftEvent ;
    drift:affectsWord wdr:word-liken ;
    drift:senseFrom wdr:sense-liken-base ;
    drift:senseTo wdr:sense-liken-social ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "2010"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "2015"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-liken-dwds , wdr:src-liken-wikipedia .

# --- causal hypothesis (ADR 0004) ---
# DWDS is a lexicographic source -> LexicographicNote; Wikipedia is general -> Speculative.
wdr:hyp-liken-facebook a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-liken-social ;
    drift:proposedTrigger wdr:trigger-facebook-like ;
    drift:evidenceType drift:LexicographicNote , drift:Speculative ;
    drift:confidence 0.82 ;
    drift:hasSource wdr:src-liken-dwds , wdr:src-liken-wikipedia ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-liken-dwds a drift:Source ;
    dct:title "DWDS - liken"@de ;
    drift:sourceURL "https://www.dwds.de/wb/liken"^^xsd:anyURI .

wdr:src-liken-wikipedia a drift:Source ;
    dct:title "Like-Button - Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Like-Button"^^xsd:anyURI .
