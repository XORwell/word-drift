@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# WORKED EXAMPLE - "deer" (en)
# Narrowing (classic textbook case):
#   Old English "deor" = any wild animal (beast in general) ->
#   Middle English: narrowed to the cervid family (Cervidae).
#   Cognate German "Tier" (= animal) retained the broad sense.
# =============================================================

wdr:word-deer a drift:Word ;
    drift:writtenForm "deer"@en ;
    drift:language "en" ;
    rdfs:label "deer"@en ;
    ontolex:sense wdr:sense-deer-animal , wdr:sense-deer-cervid .

wdr:sense-deer-animal a drift:Sense ;
    drift:gloss "any wild animal; a beast (Old English 'deor'; cognate with German 'Tier')"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "0700"^^xsd:gYear .

wdr:sense-deer-cervid a drift:Sense ;
    drift:gloss "a deer: a ruminant mammal of the family Cervidae, bearing antlers in the male"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1200"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1200"^^xsd:gYear ]
    ] .

# --- drift event: narrowing (no external trigger; purely language-internal) ---
wdr:drift-deer-medieval a drift:DriftEvent ;
    drift:affectsWord wdr:word-deer ;
    drift:senseFrom wdr:sense-deer-animal ;
    drift:senseTo wdr:sense-deer-cervid ;
    drift:driftType drift:Narrowing ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1100"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1400"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-deer-etymonline , wdr:src-deer-oed .

# --- sources ---
wdr:src-deer-etymonline a drift:Source ;
    dct:title "Etymonline - deer (n.)"@en ;
    drift:sourceURL "https://www.etymonline.com/word/deer"^^xsd:anyURI .

wdr:src-deer-oed a drift:Source ;
    dct:title "Oxford English Dictionary - deer, n."@en ;
    drift:sourceURL "https://www.oed.com/dictionary/deer_n"^^xsd:anyURI .
