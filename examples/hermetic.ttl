@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "hermetic" (en)
# Metonymization: from Hermes Trismegistus, the legendary
# father of alchemy credited with a secret airtight seal. The
# alchemical adjective yielded the everyday sense "airtight".
# =============================================================

wdr:word-hermetic a drift:Word ;
    drift:writtenForm "hermetic"@en ;
    drift:language "en" ;
    rdfs:label "hermetic"@en ;
    ontolex:sense wdr:sense-hermetic-alchemy , wdr:sense-hermetic-airtight .

wdr:sense-hermetic-alchemy a drift:Sense ;
    drift:gloss "dealing with the occult sciences, especially alchemy; of or relating to Hermes Trismegistus"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1630"^^xsd:gYear .

wdr:sense-hermetic-airtight a drift:Sense ;
    drift:gloss "completely sealed against the escape or entry of air; airtight"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1600"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1600"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-hermetic-hermes a drift:TriggerEvent ;
    rdfs:label "Hermes Trismegistus and the hermetic seal"@en ;
    dct:description "Hermes Trismegistus, the legendary sage identified by alchemists with the god Hermes, was credited with a secret process for sealing a glass tube perfectly airtight. From this 'hermetic seal' the adjective acquired its everyday sense 'airtight', attested in the adverb from about 1600."@en ;
    drift:eventDate "1600"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural ;
    owl:sameAs wd:Q192358 .

# --- drift event ---
wdr:drift-hermetic-hermes a drift:DriftEvent ;
    drift:affectsWord wdr:word-hermetic ;
    drift:senseFrom wdr:sense-hermetic-alchemy ;
    drift:senseTo wdr:sense-hermetic-airtight ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1600"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1660"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-hermetic-etym , wdr:src-hermetic-wikt .

# --- causal hypothesis ---
wdr:hyp-hermetic-hermes a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-hermetic-hermes ;
    drift:proposedTrigger wdr:trigger-hermetic-hermes ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-hermetic-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-hermetic-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- hermetic"@en ;
    drift:sourceURL "https://www.etymonline.com/word/hermetic"^^xsd:anyURI .

wdr:src-hermetic-wikt a drift:Source ;
    dct:title "Wiktionary -- hermetic"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/hermetic"^^xsd:anyURI .
