@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "stentorian" (en)
# Metaphorization: from Stentor, the Greek herald in Homer's
# Iliad whose voice was as loud as fifty men. The proper name
# yielded an adjective for an extremely loud, powerful voice.
# =============================================================

wdr:word-stentorian a drift:Word ;
    drift:writtenForm "stentorian"@en ;
    drift:language "en" ;
    rdfs:label "stentorian"@en ;
    ontolex:sense wdr:sense-stentorian-herald , wdr:sense-stentorian-loud .

wdr:sense-stentorian-herald a drift:Sense ;
    drift:gloss "of or like Stentor, the loud-voiced herald of the Greeks in Homer's Iliad"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1600"^^xsd:gYear .

wdr:sense-stentorian-loud a drift:Sense ;
    drift:gloss "of a voice: extremely loud, powerful, and resonant"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1600"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1600"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-stentorian-stentor a drift:TriggerEvent ;
    rdfs:label "Stentor, the loud-voiced herald of Homer's Iliad"@en ;
    dct:description "Stentor was the herald of the Greek forces at Troy, described by Homer as having a voice as loud as fifty men. The figure, known from the eighth-century BC epic, lent his name to the adjective for a powerful voice."@en ;
    drift:eventDate "1600"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-stentorian-stentor a drift:DriftEvent ;
    drift:affectsWord wdr:word-stentorian ;
    drift:senseFrom wdr:sense-stentorian-herald ;
    drift:senseTo wdr:sense-stentorian-loud ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1600"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1650"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-stentorian-etym , wdr:src-stentorian-wikt .

# --- causal hypothesis ---
wdr:hyp-stentorian-stentor a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-stentorian-stentor ;
    drift:proposedTrigger wdr:trigger-stentorian-stentor ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-stentorian-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-stentorian-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- stentorian"@en ;
    drift:sourceURL "https://www.etymonline.com/word/stentorian"^^xsd:anyURI .

wdr:src-stentorian-wikt a drift:Source ;
    dct:title "Wiktionary -- stentorian"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/stentorian"^^xsd:anyURI .
