@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Tempo" (de)
# Broadening: 1929 brand of paper handkerchief (Vereinigte
# Papierwerke) -> umgangssprachlich generic word for any
# Papiertaschentuch. The 1929 brand launch is the trigger.
# =============================================================

wdr:word-tempo-de a drift:Word ;
    drift:writtenForm "Tempo"@de ;
    drift:language "de" ;
    rdfs:label "Tempo"@de ;
    ontolex:sense wdr:sense-tempo-de-brand , wdr:sense-tempo-de-generic .

wdr:sense-tempo-de-brand a drift:Sense ;
    drift:gloss "the Tempo brand of disposable paper handkerchief"@en ;
    drift:gloss "die Marke Tempo fuer Papiertaschentuecher der Vereinigten Papierwerke"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1929"^^xsd:gYear .

wdr:sense-tempo-de-generic a drift:Sense ;
    drift:gloss "any disposable paper tissue, regardless of maker (colloquial German)"@en ;
    drift:gloss "umgangssprachlich jedes Papiertaschentuch, unabhaengig vom Hersteller"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1950"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1950"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-tempo-de-brand a drift:TriggerEvent ;
    rdfs:label "Tempo paper handkerchief brand registered"@en ;
    dct:description "In 1929 the Vereinigte Papierwerke registered the Tempo brand of disposable paper handkerchief at the Reichspatentamt in Berlin. The brand became the colloquial German word for any paper tissue."@en ;
    drift:eventDate "1929"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-tempo-de-brand a drift:DriftEvent ;
    drift:affectsWord wdr:word-tempo-de ;
    drift:senseFrom wdr:sense-tempo-de-brand ;
    drift:senseTo wdr:sense-tempo-de-generic ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1929"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1960"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-tempo-de-wikt , wdr:src-tempo-de-wiki .

# --- causal hypothesis ---
wdr:hyp-tempo-de-brand a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-tempo-de-brand ;
    drift:proposedTrigger wdr:trigger-tempo-de-brand ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-tempo-de-wikt ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-tempo-de-wikt a drift:Source ;
    dct:title "Tempo -- Wiktionary"@de ;
    drift:sourceURL "https://de.wiktionary.org/wiki/Tempo"^^xsd:anyURI .

wdr:src-tempo-de-wiki a drift:Source ;
    dct:title "Tempo (Marke) -- Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Tempo_(Marke)"^^xsd:anyURI .
