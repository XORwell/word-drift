@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "hertz" (en)
# Metonymization: the surname Hertz (Heinrich Hertz, who proved
# electromagnetic waves in 1888) becomes the common name of the
# SI unit of frequency. His demonstration of radio waves is the
# identifiable trigger.
# =============================================================

wdr:word-hertz a drift:Word ;
    drift:writtenForm "hertz"@en ;
    drift:language "en" ;
    rdfs:label "hertz"@en ;
    ontolex:sense wdr:sense-hertz-name , wdr:sense-hertz-unit .

wdr:sense-hertz-name a drift:Sense ;
    drift:gloss "the surname of the German physicist Heinrich Rudolf Hertz"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1857"^^xsd:gYear .

wdr:sense-hertz-unit a drift:Sense ;
    drift:gloss "the SI unit of frequency, one cycle per second; an everyday word for the frequency of signals, sound, or processors"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1928"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1928"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-hertz-waves a drift:TriggerEvent ;
    rdfs:label "Hertz demonstrates electromagnetic waves"@en ;
    dct:description "In 1888 Heinrich Hertz experimentally produced and detected electromagnetic (radio) waves, confirming Maxwell's theory. His name was adopted for the unit of frequency, formally ratified by the IEC in 1935 and the General Conference on Weights and Measures in 1960."@en ;
    drift:eventDate "1888"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

# --- drift event ---
wdr:drift-hertz-waves a drift:DriftEvent ;
    drift:affectsWord wdr:word-hertz ;
    drift:senseFrom wdr:sense-hertz-name ;
    drift:senseTo wdr:sense-hertz-unit ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1888"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1935"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-hertz-etym , wdr:src-hertz-wiki .

# --- causal hypothesis ---
wdr:hyp-hertz-waves a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-hertz-waves ;
    drift:proposedTrigger wdr:trigger-hertz-waves ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-hertz-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-hertz-etym a drift:Source ;
    dct:title "hertz -- Online Etymology Dictionary"@en ;
    drift:sourceURL "https://www.etymonline.com/word/hertz"^^xsd:anyURI .

wdr:src-hertz-wiki a drift:Source ;
    dct:title "Heinrich Hertz -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Heinrich_Hertz"^^xsd:anyURI .
