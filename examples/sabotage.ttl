@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "sabotage" (en)
# Broadening: from a narrow labour-movement sense of deliberately
# bungling work (French syndicalism, ca. 1910) to any deliberate
# destruction or obstruction. French CGT advocacy of "sabotage"
# around 1910 is the datable trigger for the English borrowing.
# =============================================================

wdr:word-sabotage a drift:Word ;
    drift:writtenForm "sabotage"@en ;
    drift:language "en" ;
    rdfs:label "sabotage"@en ;
    ontolex:sense wdr:sense-sabotage-labour , wdr:sense-sabotage-general .

wdr:sense-sabotage-labour a drift:Sense ;
    drift:gloss "the deliberate slowing or bungling of work by labourers as an industrial weapon"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1910"^^xsd:gYear .

wdr:sense-sabotage-general a drift:Sense ;
    drift:gloss "any deliberate destruction, obstruction, or undermining of an effort, machine, or cause"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1918"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1918"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-sabotage-cgt a drift:TriggerEvent ;
    rdfs:label "French syndicalist promotion of 'sabotage' as industrial action"@en ;
    dct:description "Around 1910 the French syndicalist movement (CGT) openly advocated 'sabotage' as a tactic, popularising the word; English borrowed it in this narrow labour sense before broadening it during and after the First World War."@en ;
    drift:eventDate "1910"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

# --- drift event ---
wdr:drift-sabotage-cgt a drift:DriftEvent ;
    drift:affectsWord wdr:word-sabotage ;
    drift:senseFrom wdr:sense-sabotage-labour ;
    drift:senseTo wdr:sense-sabotage-general ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1910"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1920"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-sabotage-etym , wdr:src-sabotage-wikt .

# --- causal hypothesis ---
wdr:hyp-sabotage-cgt a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-sabotage-cgt ;
    drift:proposedTrigger wdr:trigger-sabotage-cgt ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.75 ;
    drift:hasSource wdr:src-sabotage-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-sabotage-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- sabotage"@en ;
    drift:sourceURL "https://www.etymonline.com/word/sabotage"^^xsd:anyURI .

wdr:src-sabotage-wikt a drift:Source ;
    dct:title "sabotage -- Wiktionary"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/sabotage"^^xsd:anyURI .
