@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "jovial" (en)
# Metaphorization: from Jove (Jupiter), Roman sky-god and
# planet. The astrological sense "born under Jupiter" yielded
# an adjective for a good-humoured, merry disposition.
# =============================================================

wdr:word-jovial a drift:Word ;
    drift:writtenForm "jovial"@en ;
    drift:language "en" ;
    rdfs:label "jovial"@en ;
    ontolex:sense wdr:sense-jovial-planet , wdr:sense-jovial-merry .

wdr:sense-jovial-planet a drift:Sense ;
    drift:gloss "pertaining to or born under the influence of the planet Jupiter (Jove)"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1580"^^xsd:gYear .

wdr:sense-jovial-merry a drift:Sense ;
    drift:gloss "good-humoured, cheerful, merry; full of hearty, sociable good spirits"@en ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1580"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1580"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-jovial-jove a drift:TriggerEvent ;
    rdfs:label "Astrological disposition of those born under Jupiter"@en ;
    dct:description "Renaissance astrology held that those born under the sign of Jupiter (Jove), the most benign planet, were of a happy and generous disposition. The planetary adjective and the merry sense both surface in the 1580s, the cheerful meaning growing directly out of the astrological belief."@en ;
    drift:eventDate "1580"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-jovial-jove a drift:DriftEvent ;
    drift:affectsWord wdr:word-jovial ;
    drift:senseFrom wdr:sense-jovial-planet ;
    drift:senseTo wdr:sense-jovial-merry ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1580"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1620"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-jovial-etym , wdr:src-jovial-wikt .

# --- causal hypothesis ---
wdr:hyp-jovial-jove a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-jovial-jove ;
    drift:proposedTrigger wdr:trigger-jovial-jove ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-jovial-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-jovial-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- jovial"@en ;
    drift:sourceURL "https://www.etymonline.com/word/jovial"^^xsd:anyURI .

wdr:src-jovial-wikt a drift:Source ;
    dct:title "Wiktionary -- jovial"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/jovial"^^xsd:anyURI .
