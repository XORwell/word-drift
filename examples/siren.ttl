@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "siren" (en)
# Metaphorization: from the Sirens of Greek myth, sea-nymphs
# whose song lured sailors to destruction. The mythical name
# yielded a figure for a dangerously alluring woman or thing.
# =============================================================

wdr:word-siren a drift:Word ;
    drift:writtenForm "siren"@en ;
    drift:language "en" ;
    rdfs:label "siren"@en ;
    ontolex:sense wdr:sense-siren-nymph , wdr:sense-siren-temptress .

wdr:sense-siren-nymph a drift:Sense ;
    drift:gloss "one of the mythical sea-nymphs whose singing lured sailors to their destruction"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1340"^^xsd:gYear .

wdr:sense-siren-temptress a drift:Sense ;
    drift:gloss "a woman or thing that sings sweetly and charms, dangerously alluring or seductive"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1580"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1580"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-siren-sirens a drift:TriggerEvent ;
    rdfs:label "The Sirens of Greek myth"@en ;
    dct:description "In Greek myth the Sirens lured passing sailors to wreck with their song, as in the Odyssey. The mythical name, in English from the mid-14th century, yielded by the 1580s the figurative sense of a dangerously alluring woman or temptation."@en ;
    drift:eventDate "1580"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural ;
    owl:sameAs wd:Q150986 .

# --- drift event ---
wdr:drift-siren-sirens a drift:DriftEvent ;
    drift:affectsWord wdr:word-siren ;
    drift:senseFrom wdr:sense-siren-nymph ;
    drift:senseTo wdr:sense-siren-temptress ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1550"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1620"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-siren-etym , wdr:src-siren-wikt .

# --- causal hypothesis ---
wdr:hyp-siren-sirens a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-siren-sirens ;
    drift:proposedTrigger wdr:trigger-siren-sirens ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-siren-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-siren-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- siren"@en ;
    drift:sourceURL "https://www.etymonline.com/word/siren"^^xsd:anyURI .

wdr:src-siren-wikt a drift:Source ;
    dct:title "Wiktionary -- siren"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/siren"^^xsd:anyURI .
