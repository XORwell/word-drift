@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "spartan" (en)
# Metonymization: from Sparta, the Greek city-state famed for
# austere discipline. The civic name became an adjective for
# severe simplicity and frugal endurance.
# =============================================================

wdr:word-spartan a drift:Word ;
    drift:writtenForm "spartan"@en ;
    drift:language "en" ;
    rdfs:label "spartan"@en ;
    ontolex:sense wdr:sense-spartan-place , wdr:sense-spartan-austere .

wdr:sense-spartan-place a drift:Sense ;
    drift:gloss "of or belonging to Sparta or its citizens in ancient Greece"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1580"^^xsd:gYear .

wdr:sense-spartan-austere a drift:Sense ;
    drift:gloss "marked by austerity, severe self-discipline, frugality, and the avoidance of comfort or luxury"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1640"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1640"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-spartan-sparta a drift:TriggerEvent ;
    rdfs:label "Reputation of Spartan austerity"@en ;
    dct:description "Ancient accounts of Sparta's harsh military upbringing and plain living made the civic name a byword for austerity. The adjective generalised to mean severe simplicity and frugal endurance."@en ;
    drift:eventDate "1640"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-spartan-sparta a drift:DriftEvent ;
    drift:affectsWord wdr:word-spartan ;
    drift:senseFrom wdr:sense-spartan-place ;
    drift:senseTo wdr:sense-spartan-austere ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1580"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1660"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-spartan-etym , wdr:src-spartan-wikt .

# --- causal hypothesis ---
wdr:hyp-spartan-sparta a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-spartan-sparta ;
    drift:proposedTrigger wdr:trigger-spartan-sparta ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-spartan-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-spartan-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- spartan"@en ;
    drift:sourceURL "https://www.etymonline.com/word/spartan"^^xsd:anyURI .

wdr:src-spartan-wikt a drift:Source ;
    dct:title "Wiktionary -- spartan"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/spartan"^^xsd:anyURI .
