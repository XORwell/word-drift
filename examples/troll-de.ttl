@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# =============================================================
# "Troll" (de) -- cross-lingual pair with "troll" (troll.ttl)
# Metaphorization (loanword):
#   "Troll" als Fabelwesen der nordischen Mythologie ->
#   "Person, die im Internet absichtlich provoziert" (Internet-
#    Troll). The German sense was borrowed from English internet
#    culture, rooted in early-1990s Usenet.
# =============================================================

wdr:word-troll-de a drift:Word ;
    drift:writtenForm "Troll"@de ;
    drift:language "de" ;
    rdfs:label "Troll"@de ;
    ontolex:sense wdr:sense-troll-de-creature , wdr:sense-troll-de-online ;
    drift:crossLingualOf wdr:word-troll .

wdr:sense-troll-de-creature a drift:Sense ;
    drift:gloss "a troll: a mythological being of Scandinavian folklore"@en ;
    drift:gloss "Troll: Fabelwesen der nordischen Mythologie"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1846"^^xsd:gYear .

wdr:sense-troll-de-online a drift:Sense ;
    drift:gloss "an internet troll: a person who posts deliberately provocative messages online"@en ;
    drift:gloss "Internet-Troll: Person, die im Internet absichtlich provoziert oder stoert"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1999"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1999"^^xsd:gYear ]
    ] .

# --- trigger event ---
# Shared with troll.ttl (en): same Usenet trigger node powers the
# cross-lingual same-trigger query. Defined fully in troll.ttl.
# (wdr:trigger-troll-usenet, drift:eventDate 1992)

# --- drift event: metaphorization (causation lives in the hypothesis below) ---
wdr:drift-troll-de-online a drift:DriftEvent ;
    drift:affectsWord wdr:word-troll-de ;
    drift:senseFrom wdr:sense-troll-de-creature ;
    drift:senseTo wdr:sense-troll-de-online ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1999"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "2008"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-troll-de-dwds , wdr:src-troll-de-wikipedia .

# --- causal hypothesis (ADR 0004) ---
# DWDS is a lexicographic source -> LexicographicNote; Wikipedia is general -> Speculative.
wdr:hyp-troll-de-usenet a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-troll-de-online ;
    drift:proposedTrigger wdr:trigger-troll-usenet ;
    drift:evidenceType drift:LexicographicNote , drift:Speculative ;
    drift:confidence 0.78 ;
    drift:hasSource wdr:src-troll-de-dwds , wdr:src-troll-de-wikipedia ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-troll-de-dwds a drift:Source ;
    dct:title "DWDS - Troll"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Troll"^^xsd:anyURI .

wdr:src-troll-de-wikipedia a drift:Source ;
    dct:title "Troll (Netzkultur) - Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Troll_(Netzkultur)"^^xsd:anyURI .
