@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "spa" (en)
# Metonymization then Broadening: Spa, a Belgian town famous
# for its mineral springs, gave its name first to any mineral
# spring resort and then to any health and bathing establishment.
# =============================================================

wdr:word-spa a drift:Word ;
    drift:writtenForm "spa"@en ;
    drift:language "en" ;
    rdfs:label "spa"@en ;
    ontolex:sense wdr:sense-spa-town , wdr:sense-spa-resort .

wdr:sense-spa-town a drift:Sense ;
    drift:gloss "the town of Spa in the Ardennes (modern Belgium), renowned for its curative mineral springs"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1600"^^xsd:gYear .

wdr:sense-spa-resort a drift:Sense ;
    drift:gloss "any mineral spring or resort, health establishment, or bathing facility offering such waters or treatments"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1620"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1620"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-spa-town a drift:TriggerEvent ;
    rdfs:label "Fame of Spa's mineral springs"@en ;
    dct:description "The Belgian town of Spa became the leading European destination for mineral-water cures. English visitors generalised the place name to mean any such spring resort, and later any health and bathing establishment."@en ;
    drift:eventDate "1620"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-spa-town a drift:DriftEvent ;
    drift:affectsWord wdr:word-spa ;
    drift:senseFrom wdr:sense-spa-town ;
    drift:senseTo wdr:sense-spa-resort ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1600"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1700"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-spa-etym , wdr:src-spa-wikt .

# --- causal hypothesis ---
wdr:hyp-spa-town a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-spa-town ;
    drift:proposedTrigger wdr:trigger-spa-town ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-spa-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-spa-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- spa"@en ;
    drift:sourceURL "https://www.etymonline.com/word/spa"^^xsd:anyURI .

wdr:src-spa-wikt a drift:Source ;
    dct:title "Wiktionary -- spa"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/spa"^^xsd:anyURI .
