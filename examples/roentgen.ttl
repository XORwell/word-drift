@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Roentgen" (de, writtenForm "Roentgen")
# Metonymization: surname of the physicist Wilhelm Conrad
# Roentgen (1845-1923) -> the rays he discovered (Roentgen-
# strahlen) and, in everyday use, X-ray imaging itself. The
# November 1895 discovery is the identifiable trigger.
# =============================================================

wdr:word-roentgen a drift:Word ;
    drift:writtenForm "Roentgen"@de ;
    drift:language "de" ;
    rdfs:label "Roentgen"@de ;
    ontolex:sense wdr:sense-roentgen-name , wdr:sense-roentgen-rays .

wdr:sense-roentgen-name a drift:Sense ;
    drift:gloss "surname of the physicist Wilhelm Conrad Roentgen (1845-1923)"@en ;
    drift:gloss "Familienname des Physikers Wilhelm Conrad Roentgen (1845-1923)"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1845"^^xsd:gYear .

wdr:sense-roentgen-rays a drift:Sense ;
    drift:gloss "the X-rays discovered by Roentgen; by extension X-ray imaging and the act of taking such an image (German 'roentgen', verb)"@en ;
    drift:gloss "die von Roentgen entdeckten Strahlen (Roentgenstrahlen); uebertragen das Roentgenbild und das Roentgen (Verb)"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1895"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1895"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-roentgen-discovery a drift:TriggerEvent ;
    rdfs:label "Roentgen's discovery of X-rays at Wuerzburg"@en ;
    dct:description "On 8 November 1895 Wilhelm Conrad Roentgen discovered a new kind of radiation at the University of Wuerzburg. In German the rays and the resulting imaging were named after him (Roentgenstrahlen, roentgen), turning the surname into a generic medical and technical term."@en ;
    drift:eventDate "1895"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

# --- drift event ---
wdr:drift-roentgen-discovery a drift:DriftEvent ;
    drift:affectsWord wdr:word-roentgen ;
    drift:senseFrom wdr:sense-roentgen-name ;
    drift:senseTo wdr:sense-roentgen-rays ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1895"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1900"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-roentgen-dwds , wdr:src-roentgen-wiki .

# --- causal hypothesis ---
wdr:hyp-roentgen-discovery a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-roentgen-discovery ;
    drift:proposedTrigger wdr:trigger-roentgen-discovery ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-roentgen-wiki ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-roentgen-dwds a drift:Source ;
    dct:title "DWDS -- roentgen"@de ;
    drift:sourceURL "https://www.dwds.de/wb/r%C3%B6ntgen"^^xsd:anyURI .

wdr:src-roentgen-wiki a drift:Source ;
    dct:title "Wilhelm Conrad Roentgen -- Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Wilhelm_Conrad_R%C3%B6ntgen"^^xsd:anyURI .
