@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Proletariat" (de)
# Narrowing/Amelioration: from Latin "proletarius", the lowest
# Roman census class with nothing but offspring, the word is
# revived in the 1840s socialist movement as the modern industrial
# working class, a positively charged collective subject. The
# socialist movement and Marx/Engels are the identifiable trigger.
# =============================================================

wdr:word-proletariat a drift:Word ;
    drift:writtenForm "Proletariat"@de ;
    drift:language "de" ;
    rdfs:label "Proletariat"@de ;
    ontolex:sense wdr:sense-proletariat-roman , wdr:sense-proletariat-workers .

wdr:sense-proletariat-roman a drift:Sense ;
    drift:gloss "the propertyless lowest census class of ancient Rome, contributing nothing to the state but offspring"@en ;
    drift:gloss "die besitzlose unterste Zensusklasse des alten Rom, die dem Staat nur Nachkommen beisteuerte"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1800"^^xsd:gYear .

wdr:sense-proletariat-workers a drift:Sense ;
    drift:gloss "the modern industrial working class that owns no means of production and lives by selling its labour; a collective political subject"@en ;
    drift:gloss "die moderne industrielle Arbeiterklasse ohne Produktionsmittel, die von ihrer Arbeitskraft lebt; kollektives politisches Subjekt"@de ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1840"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1840"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-proletariat-sozialismus a drift:TriggerEvent ;
    rdfs:label "1840s socialist movement and the Communist Manifesto (1848)"@en ;
    dct:description "In the 1840s the early socialist movement, and the Communist Manifesto of 1848, revived 'Proletariat' for the modern industrial working class and recast it from a Roman class of paupers into a positively charged collective political subject."@en ;
    drift:eventDate "1840"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

# --- drift event ---
wdr:drift-proletariat-sozialismus a drift:DriftEvent ;
    drift:affectsWord wdr:word-proletariat ;
    drift:senseFrom wdr:sense-proletariat-roman ;
    drift:senseTo wdr:sense-proletariat-workers ;
    drift:driftType drift:Amelioration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1840"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1900"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-proletariat-dwds , wdr:src-proletariat-wiktionary .

# --- causal hypothesis ---
wdr:hyp-proletariat-sozialismus a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-proletariat-sozialismus ;
    drift:proposedTrigger wdr:trigger-proletariat-sozialismus ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.75 ;
    drift:hasSource wdr:src-proletariat-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-proletariat-dwds a drift:Source ;
    dct:title "DWDS -- Proletariat"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Proletariat"^^xsd:anyURI .

wdr:src-proletariat-wiktionary a drift:Source ;
    dct:title "Wiktionary -- Proletariat"@de ;
    drift:sourceURL "https://de.wiktionary.org/wiki/Proletariat"^^xsd:anyURI .
