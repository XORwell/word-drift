@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "kamikaze" (en)
# Metaphorization: Japanese term for the WWII suicide air attacks
# (literally "divine wind") broadened to a figurative adjective
# meaning "recklessly self-destructive". The 1944 Leyte Gulf
# attacks are the datable trigger for the English borrowing.
# =============================================================

wdr:word-kamikaze a drift:Word ;
    drift:writtenForm "kamikaze"@en ;
    drift:language "en" ;
    rdfs:label "kamikaze"@en ;
    ontolex:sense wdr:sense-kamikaze-pilot , wdr:sense-kamikaze-reckless .

wdr:sense-kamikaze-pilot a drift:Sense ;
    drift:gloss "a Japanese suicide pilot or aircraft of the Second World War; the suicide-attack corps"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1944"^^xsd:gYear .

wdr:sense-kamikaze-reckless a drift:Sense ;
    drift:gloss "recklessly self-destructive; undertaken with no regard for one's own safety"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1950"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1950"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-kamikaze-leyte a drift:TriggerEvent ;
    rdfs:label "Japanese kamikaze suicide attacks in the Pacific War"@en ;
    dct:description "Beginning at the Battle of Leyte Gulf in October 1944, organised Japanese suicide air attacks brought 'kamikaze' into English; the term later broadened to a figurative adjective for reckless self-destruction."@en ;
    drift:eventDate "1944"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

# --- drift event ---
wdr:drift-kamikaze-leyte a drift:DriftEvent ;
    drift:affectsWord wdr:word-kamikaze ;
    drift:senseFrom wdr:sense-kamikaze-pilot ;
    drift:senseTo wdr:sense-kamikaze-reckless ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1944"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1960"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-kamikaze-etym , wdr:src-kamikaze-wikt .

# --- causal hypothesis ---
wdr:hyp-kamikaze-leyte a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-kamikaze-leyte ;
    drift:proposedTrigger wdr:trigger-kamikaze-leyte ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-kamikaze-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-kamikaze-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- kamikaze"@en ;
    drift:sourceURL "https://www.etymonline.com/word/kamikaze"^^xsd:anyURI .

wdr:src-kamikaze-wikt a drift:Source ;
    dct:title "kamikaze -- Wiktionary"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/kamikaze"^^xsd:anyURI .
