@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "naughty" (en)
# Amelioration (weakening): from "naught" (nothing) -> "having
# nothing, poor, needy" -> "wicked, morally bad, given to vice"
# -> weakened to "mischievous, disobedient" (esp. of children)
# and "mildly improper". A gradual weakening of a moral term,
# no crisp datable event.
# =============================================================

wdr:word-naughty a drift:Word ;
    drift:writtenForm "naughty"@en ;
    drift:language "en" ;
    rdfs:label "naughty"@en ;
    ontolex:sense wdr:sense-naughty-wicked , wdr:sense-naughty-mischievous .

wdr:sense-naughty-wicked a drift:Sense ;
    drift:gloss "wicked, morally bad, given to vice or evil; (earlier) having naught, poor, needy (from 'naught', nothing)"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1380"^^xsd:gYear .

wdr:sense-naughty-mischievous a drift:Sense ;
    drift:gloss "mischievous, disobedient (esp. of a child); mildly improper or risque, but not gravely wicked"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1630"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1630"^^xsd:gYear ]
    ] .

# --- trigger event (gradual, undetermined driver) ---
wdr:trigger-naughty-weakening a drift:TriggerEvent ;
    rdfs:label "Gradual weakening of a moral condemnation"@en ;
    dct:description "No single datable event. The strong moral sense 'wicked' weakened over the 17th century to the milder 'mischievous, disobedient', a common softening of moral terms when applied colloquially and to children. The anchor year is a representative attestation, not a cause."@en ;
    drift:eventDate "1630"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-naughty-weakening a drift:DriftEvent ;
    drift:affectsWord wdr:word-naughty ;
    drift:senseFrom wdr:sense-naughty-wicked ;
    drift:senseTo wdr:sense-naughty-mischievous ;
    drift:driftType drift:Amelioration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1550"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1700"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-naughty-etymonline , wdr:src-naughty-oed .

# --- causal hypothesis ---
wdr:hyp-naughty-weakening a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-naughty-weakening ;
    drift:proposedTrigger wdr:trigger-naughty-weakening ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.6 ;
    drift:hasSource wdr:src-naughty-etymonline ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-naughty-etymonline a drift:Source ;
    dct:title "Etymonline - naughty (adj.)"@en ;
    drift:sourceURL "https://www.etymonline.com/word/naughty"^^xsd:anyURI .

wdr:src-naughty-oed a drift:Source ;
    dct:title "Oxford English Dictionary - naughty, adj."@en ;
    drift:sourceURL "https://www.oed.com/dictionary/naughty_adj"^^xsd:anyURI .
