    drift:byGroup wdr:group-de-creativity-community ;
    drift:atYear "2023"^^xsd:gYear ;
    drift:attributionWeight 0.85 ;
    drift:hasEvidence wdr:src-dwds-blog-2023 .

wdr:attrib-q-2023-cc-lateral a drift:MeaningAttribution ;
    drift:attributesWord wdr:word-querdenker ;
    drift:attributesSense wdr:sense-querdenker-lateral ;
    drift:byGroup wdr:group-de-creativity-community ;
    drift:atYear "2023"^^xsd:gYear ;
    drift:attributionWeight 0.15 ;
    drift:hasEvidence wdr:src-dwds-blog-2023 .

wdr:attrib-q-2023-al-covid a drift:MeaningAttribution ;
    drift:attributesWord wdr:word-querdenker ;
    drift:attributesSense wdr:sense-querdenker-covid ;
    drift:byGroup wdr:group-de-academic-linguistics ;
    drift:atYear "2023"^^xsd:gYear ;
    drift:attributionWeight 0.7 ;
    drift:hasEvidence wdr:src-dwds-blog-2023 .

wdr:attrib-q-2023-al-lateral a drift:MeaningAttribution ;
    drift:attributesWord wdr:word-querdenker ;
    drift:attributesSense wdr:sense-querdenker-lateral ;
    drift:byGroup wdr:group-de-academic-linguistics ;
    drift:atYear "2023"^^xsd:gYear ;
    drift:attributionWeight 0.3 ;
    drift:hasEvidence wdr:src-dwds-blog-2023 .

# --- Group hookup on the existing 2.x drift event --------------------------
# wdr:drift-querdenker-2020 is the 2.x DriftEvent; we attach
# drift:occurredInGroup to it for the press groups that *first* observed
# the shift. This is optional and additive: 2.x consumers ignoring this
# property still see the same drift event.

wdr:drift-querdenker-2020
    drift:occurredInGroup wdr:group-de-mainstream-press ,
                          wdr:group-de-leftist-press .
