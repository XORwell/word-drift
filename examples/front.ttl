@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Front" (de)
# Metonymization/Broadening: from a term for the foremost line of
# a military formation, the mass static-line warfare of WWI fixed
# "die Front" as the war zone where fighting happens, and from
# there it broadened metaphorically to any contested line
# (politische Front, Wetterfront). WWI is the identifiable trigger.
# =============================================================

wdr:word-front a drift:Word ;
    drift:writtenForm "Front"@de ;
    drift:language "de" ;
    rdfs:label "Front"@de ;
    ontolex:sense wdr:sense-front-formation , wdr:sense-front-warzone .

wdr:sense-front-formation a drift:Sense ;
    drift:gloss "the foremost line or face of a drawn-up military formation; the side a unit faces"@en ;
    drift:gloss "vorderste Linie oder Vorderseite einer aufgestellten Truppe; die Richtung, in die eine Einheit blickt"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1600"^^xsd:gYear .

wdr:sense-front-warzone a drift:Sense ;
    drift:gloss "the front line as the zone of combat; the contested line of confrontation, also figuratively (political front, weather front)"@en ;
    drift:gloss "Frontlinie als Kampfgebiet; umkaempfte Konfrontationslinie, auch uebertragen (politische Front, Wetterfront)"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1915"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1915"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-front-wwi a drift:TriggerEvent ;
    rdfs:label "First World War static trench warfare 1914-1918"@en ;
    dct:description "The static line warfare of the First World War (1914-1918) fixed 'die Front' as the term for the combat zone in everyday German. From this war usage the word broadened to any line of confrontation, political or meteorological."@en ;
    drift:eventDate "1914"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

# --- drift event ---
wdr:drift-front-wwi a drift:DriftEvent ;
    drift:affectsWord wdr:word-front ;
    drift:senseFrom wdr:sense-front-formation ;
    drift:senseTo wdr:sense-front-warzone ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1914"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1925"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-front-dwds , wdr:src-front-wiktionary .

# --- causal hypothesis ---
wdr:hyp-front-wwi a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-front-wwi ;
    drift:proposedTrigger wdr:trigger-front-wwi ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.7 ;
    drift:hasSource wdr:src-front-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-front-dwds a drift:Source ;
    dct:title "DWDS -- Front"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Front"^^xsd:anyURI .

wdr:src-front-wiktionary a drift:Source ;
    dct:title "Wiktionary -- Front"@de ;
    drift:sourceURL "https://de.wiktionary.org/wiki/Front"^^xsd:anyURI .
