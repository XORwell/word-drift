@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "slop" (en)
# Metaphorization: "watery mud / unappetising swill" (c. 1400) ->
# "low-quality mass-produced digital content, esp. AI-generated"
# ("AI slop"). The generative-AI boom is the proposed trigger; the
# term crystallised in the media in 2024.
# =============================================================

wdr:word-slop a drift:Word ;
    drift:writtenForm "slop"@en ;
    drift:language "en" ;
    rdfs:label "slop"@en ;
    ontolex:sense wdr:sense-slop-swill , wdr:sense-slop-aislop .

wdr:sense-slop-swill a drift:Sense ;
    drift:gloss "watery mud, slush, or spilled liquid; unappetising semi-liquid food, especially pig swill or poor-quality fare"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1400"^^xsd:gYear .

wdr:sense-slop-aislop a drift:Sense ;
    drift:gloss "low-quality, mass-produced digital content of little value, especially text or images churned out by generative AI"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "2024"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "2024"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-slop-genai a drift:TriggerEvent ;
    rdfs:label "Proliferation of generative AI content"@en ;
    dct:description "The public release of large generative models (ChatGPT, late 2022) and the flood of cheap machine-generated text and images that followed. By 2024 'AI slop' was an established label in technology and general press for this low-value output."@en ;
    drift:eventDate "2022"^^xsd:gYear ;
    drift:triggerCategory drift:Technology ;
    owl:sameAs wd:Q115564437 .

# --- drift event ---
wdr:drift-slop-aislop a drift:DriftEvent ;
    drift:affectsWord wdr:word-slop ;
    drift:senseFrom wdr:sense-slop-swill ;
    drift:senseTo wdr:sense-slop-aislop ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "2022"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "2024"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-slop-wiktionary , wdr:src-slop-wikipedia .

# --- causal hypothesis ---
wdr:hyp-slop-genai a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-slop-aislop ;
    drift:proposedTrigger wdr:trigger-slop-genai ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-slop-wikipedia ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-24"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-slop-wiktionary a drift:Source ;
    dct:title "Wiktionary -- slop"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/slop"^^xsd:anyURI .

wdr:src-slop-wikipedia a drift:Source ;
    dct:title "AI slop -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/AI_slop"^^xsd:anyURI .
