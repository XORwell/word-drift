@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "nylon" (en)
# Broadening: DuPont's 1938 coined name for its synthetic
# polyamide fibre -> generic term for the polymer and fabrics
# made from it. The 1938 DuPont launch is the commercial trigger.
# =============================================================

wdr:word-nylon a drift:Word ;
    drift:writtenForm "nylon"@en ;
    drift:language "en" ;
    rdfs:label "nylon"@en ;
    ontolex:sense wdr:sense-nylon-brand , wdr:sense-nylon-generic .

wdr:sense-nylon-brand a drift:Sense ;
    drift:gloss "DuPont's coined product name for its new synthetic polyamide fibre"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1938"^^xsd:gYear .

wdr:sense-nylon-generic a drift:Sense ;
    drift:gloss "any synthetic polyamide polymer; fabric or stockings made from it"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1940"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1940"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-nylon-dupont a drift:TriggerEvent ;
    rdfs:label "DuPont announces nylon"@en ;
    dct:description "In 1938 DuPont publicly announced nylon, a coined name for its new synthetic polyamide fibre, deliberately left as a generic descriptor rather than a registered trademark. It rapidly became the ordinary word for the polymer and the products made from it."@en ;
    drift:eventDate "1938"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-nylon-dupont a drift:DriftEvent ;
    drift:affectsWord wdr:word-nylon ;
    drift:senseFrom wdr:sense-nylon-brand ;
    drift:senseTo wdr:sense-nylon-generic ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1938"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1945"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-nylon-wikt , wdr:src-nylon-wiki .

# --- causal hypothesis ---
wdr:hyp-nylon-dupont a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-nylon-dupont ;
    drift:proposedTrigger wdr:trigger-nylon-dupont ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-nylon-wikt ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-nylon-wikt a drift:Source ;
    dct:title "nylon -- Wiktionary"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/nylon"^^xsd:anyURI .

wdr:src-nylon-wiki a drift:Source ;
    dct:title "Nylon -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Nylon"^^xsd:anyURI .
