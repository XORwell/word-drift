@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# =============================================================
# "schwul" (de) -- cross-lingual pair with "gay" (gay.ttl)
# Reappropriation:
#   originally a derogatory term for homosexual men ->
#   reclaimed as a neutral / positive self-identifier by the
#   German gay liberation movement after 1969 (Stonewall and
#   the founding of the Homosexuelle Aktion Westberlin 1971).
# =============================================================

wdr:word-schwul a drift:Word ;
    drift:writtenForm "schwul"@de ;
    drift:language "de" ;
    rdfs:label "schwul"@de ;
    ontolex:sense wdr:sense-schwul-derogatory , wdr:sense-schwul-reclaimed ;
    drift:crossLingualOf wdr:word-gay .

wdr:sense-schwul-derogatory a drift:Sense ;
    drift:gloss "homosexual (of a man), used contemptuously; a derogatory designation"@en ;
    drift:gloss "homosexuell (von Maennern), abwertend gebraucht; Schimpfwort"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1900"^^xsd:gYear .

wdr:sense-schwul-reclaimed a drift:Sense ;
    drift:gloss "gay: a neutral or positive self-identifier for homosexual men after reappropriation"@en ;
    drift:gloss "schwul als neutrale bis positive Selbstbezeichnung homosexueller Maenner nach der Wiederaneignung"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1971"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1971"^^xsd:gYear ]
    ] .

# --- trigger events ---
wdr:trigger-stonewall a drift:TriggerEvent ;
    rdfs:label "Stonewall Riots and gay liberation movement"@en ;
    dct:description "The 1969 Stonewall Riots and the subsequent gay liberation movement, including the founding of the Homosexuelle Aktion Westberlin in 1971, drove the reappropriation of 'schwul' as a neutral or positive self-identifier in German."@en ;
    drift:eventDate "1969"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

# --- drift event: reappropriation (causation lives in the hypothesis below) ---
wdr:drift-schwul-liberation a drift:DriftEvent ;
    drift:affectsWord wdr:word-schwul ;
    drift:senseFrom wdr:sense-schwul-derogatory ;
    drift:senseTo wdr:sense-schwul-reclaimed ;
    drift:driftType drift:Reappropriation , drift:Amelioration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1971"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1995"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-schwul-dwds , wdr:src-schwul-wikipedia .

# --- causal hypothesis (ADR 0004) ---
# DWDS is a lexicographic source -> LexicographicNote; Wikipedia is general -> Speculative.
wdr:hyp-schwul-stonewall a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-schwul-liberation ;
    drift:proposedTrigger wdr:trigger-stonewall ;
    drift:evidenceType drift:LexicographicNote , drift:Speculative ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-schwul-dwds , wdr:src-schwul-wikipedia ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-schwul-dwds a drift:Source ;
    dct:title "DWDS - schwul"@de ;
    drift:sourceURL "https://www.dwds.de/wb/schwul"^^xsd:anyURI .

wdr:src-schwul-wikipedia a drift:Source ;
    dct:title "Schwul - Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Schwul"^^xsd:anyURI .
