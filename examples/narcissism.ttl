@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "narcissism" (en)
# Metaphorization: the myth of Narcissus, who fell in love with
# his own reflection -> excessive self-love, later a clinical
# personality term. Ellis's 1898 comparison and Naecke's 1899
# coinage are the identifiable trigger.
# =============================================================

wdr:word-narcissism a drift:Word ;
    drift:writtenForm "narcissism"@en ;
    drift:language "en" ;
    rdfs:label "narcissism"@en ;
    ontolex:sense wdr:sense-narcissism-myth , wdr:sense-narcissism-clinical .

wdr:sense-narcissism-myth a drift:Sense ;
    drift:gloss "the condition of Narcissus, the youth of Greek myth who pined away in love with his own reflected image"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1898"^^xsd:gYear .

wdr:sense-narcissism-clinical a drift:Sense ;
    drift:gloss "excessive self-love or self-admiration; in psychology, a personality pattern of grandiosity, need for admiration, and lack of empathy"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1905"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1905"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-narcissism-coinage a drift:TriggerEvent ;
    rdfs:label "Coinage of 'Narcissism' as a clinical term"@en ;
    dct:description "Havelock Ellis in 1898 compared a form of self-absorbed sexuality to the myth of Narcissus; in 1899 the German psychiatrist Paul Naecke coined 'Narzissmus' in 'Die sexuellen Perversitaeten'. The term entered English by 1905 and Freud's later work fixed its clinical sense, turning the mythic figure into a psychological category."@en ;
    drift:eventDate "1899"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-narcissism-coinage a drift:DriftEvent ;
    drift:affectsWord wdr:word-narcissism ;
    drift:senseFrom wdr:sense-narcissism-myth ;
    drift:senseTo wdr:sense-narcissism-clinical ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1898"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1914"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-narcissism-etym , wdr:src-narcissism-wiki .

# --- causal hypothesis ---
wdr:hyp-narcissism-coinage a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-narcissism-coinage ;
    drift:proposedTrigger wdr:trigger-narcissism-coinage ;
    drift:evidenceType drift:ScholarlyAttestation ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-narcissism-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-narcissism-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- narcissism"@en ;
    drift:sourceURL "https://www.etymonline.com/word/narcissism"^^xsd:anyURI .

wdr:src-narcissism-wiki a drift:Source ;
    dct:title "Narcissism -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Narcissism"^^xsd:anyURI .
