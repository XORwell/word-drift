@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "lunatic" (en)
# Metaphorization: from Latin luna "moon" (Luna, Roman moon
# goddess), via the belief that the moon's phases caused
# recurring madness. The moon-word yielded a term for the
# insane, broadening to "wildly foolish, reckless".
# =============================================================

wdr:word-lunatic a drift:Word ;
    drift:writtenForm "lunatic"@en ;
    drift:language "en" ;
    rdfs:label "lunatic"@en ;
    ontolex:sense wdr:sense-lunatic-moonstruck , wdr:sense-lunatic-reckless .

wdr:sense-lunatic-moonstruck a drift:Sense ;
    drift:gloss "affected with periodic insanity believed to depend on the changes of the moon; moon-struck"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1290"^^xsd:gYear .

wdr:sense-lunatic-reckless a drift:Sense ;
    drift:gloss "wildly foolish, senseless, or recklessly extravagant; characteristic of a madman"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1290"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1290"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-lunatic-luna a drift:TriggerEvent ;
    rdfs:label "Belief that the moon (Luna) caused recurring madness"@en ;
    dct:description "Medieval medicine, following classical sources, held that fits of insanity recurred with the phases of the moon (Latin luna). This belief produced Late Latin lunaticus 'moon-struck', borrowed into English by the late 13th century; the sense later broadened to wild folly."@en ;
    drift:eventDate "1290"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-lunatic-luna a drift:DriftEvent ;
    drift:affectsWord wdr:word-lunatic ;
    drift:senseFrom wdr:sense-lunatic-moonstruck ;
    drift:senseTo wdr:sense-lunatic-reckless ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1290"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1700"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-lunatic-etym , wdr:src-lunatic-wikt .

# --- causal hypothesis ---
wdr:hyp-lunatic-luna a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-lunatic-luna ;
    drift:proposedTrigger wdr:trigger-lunatic-luna ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-lunatic-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-lunatic-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- lunatic"@en ;
    drift:sourceURL "https://www.etymonline.com/word/lunatic"^^xsd:anyURI .

wdr:src-lunatic-wikt a drift:Source ;
    dct:title "Wiktionary -- lunatic"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/lunatic"^^xsd:anyURI .
