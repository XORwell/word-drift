@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "thermos" (en)
# Broadening: Thermos GmbH's 1904 brand of vacuum flask
# -> generic term for any vacuum flask. The 1904 brand launch
# is the commercial trigger; ruled generic in the US in 1963.
# =============================================================

wdr:word-thermos a drift:Word ;
    drift:writtenForm "thermos"@en ;
    drift:language "en" ;
    rdfs:label "thermos"@en ;
    ontolex:sense wdr:sense-thermos-brand , wdr:sense-thermos-generic .

wdr:sense-thermos-brand a drift:Sense ;
    drift:gloss "the Thermos brand of vacuum flask for keeping liquids hot or cold"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1904"^^xsd:gYear .

wdr:sense-thermos-generic a drift:Sense ;
    drift:gloss "any vacuum flask, regardless of maker"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1910"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1910"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-thermos-brand a drift:TriggerEvent ;
    rdfs:label "Thermos brand vacuum flask launched"@en ;
    dct:description "In 1904 the brand Thermos was adopted for the commercialised vacuum flask (based on James Dewar's earlier invention). The brand spread so widely that the word came to mean any vacuum flask, and a US court ruled it generic in 1963."@en ;
    drift:eventDate "1904"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-thermos-brand a drift:DriftEvent ;
    drift:affectsWord wdr:word-thermos ;
    drift:senseFrom wdr:sense-thermos-brand ;
    drift:senseTo wdr:sense-thermos-generic ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1904"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1920"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-thermos-wikt , wdr:src-thermos-wiki .

# --- causal hypothesis ---
wdr:hyp-thermos-brand a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-thermos-brand ;
    drift:proposedTrigger wdr:trigger-thermos-brand ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-thermos-wikt ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-thermos-wikt a drift:Source ;
    dct:title "thermos -- Wiktionary"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/thermos"^^xsd:anyURI .

wdr:src-thermos-wiki a drift:Source ;
    dct:title "Vacuum flask -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Vacuum_flask"^^xsd:anyURI .
