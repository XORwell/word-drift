@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "cologne" (en)
# Metonymization: short for "eau de Cologne", the scented water
# made at Cologne from 1709. The city name became the name of a
# class of light perfume.
# =============================================================

wdr:word-cologne a drift:Word ;
    drift:writtenForm "cologne"@en ;
    drift:language "en" ;
    rdfs:label "cologne"@en ;
    ontolex:sense wdr:sense-cologne-city , wdr:sense-cologne-perfume .

wdr:sense-cologne-city a drift:Sense ;
    drift:gloss "the city of Cologne on the Rhine, where the scented eau de Cologne was first produced"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1709"^^xsd:gYear .

wdr:sense-cologne-perfume a drift:Sense ;
    drift:gloss "a light perfume of alcohol and aromatic oils; eau de Cologne"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1814"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1814"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-cologne-eau a drift:TriggerEvent ;
    rdfs:label "Production of eau de Cologne"@en ;
    dct:description "From 1709 a scented water marketed as 'eau de Cologne' was produced in the city. Its fame fixed the city name as the English word for a light perfume."@en ;
    drift:eventDate "1709"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-cologne-eau a drift:DriftEvent ;
    drift:affectsWord wdr:word-cologne ;
    drift:senseFrom wdr:sense-cologne-city ;
    drift:senseTo wdr:sense-cologne-perfume ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1709"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1850"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-cologne-etym , wdr:src-cologne-wikt .

# --- causal hypothesis ---
wdr:hyp-cologne-eau a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-cologne-eau ;
    drift:proposedTrigger wdr:trigger-cologne-eau ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-cologne-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-cologne-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- cologne"@en ;
    drift:sourceURL "https://www.etymonline.com/word/cologne"^^xsd:anyURI .

wdr:src-cologne-wikt a drift:Source ;
    dct:title "Wiktionary -- cologne"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/cologne"^^xsd:anyURI .
