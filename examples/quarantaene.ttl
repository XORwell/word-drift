@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Quarantaene" (de)
# Narrowing: Italian quarantina "a set of forty (days)", from
# quaranta "40", specialised into the technical sense of enforced
# isolation against contagion. The Venetian/Ragusan plague
# isolation regime of the late 14th century is the trigger.
# =============================================================

wdr:word-quarantaene a drift:Word ;
    drift:writtenForm "Quarantaene"@de ;
    drift:language "de" ;
    rdfs:label "Quarantaene"@de ;
    ontolex:sense wdr:sense-quarantaene-forty , wdr:sense-quarantaene-isolation .

wdr:sense-quarantaene-forty a drift:Sense ;
    drift:gloss "a span of forty days; a generic count of forty (Italian quarantina, from quaranta '40')"@en ;
    drift:gloss "Zeitraum von vierzig Tagen; allgemeine Menge von vierzig (italienisch quarantina)"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1300"^^xsd:gYear .

wdr:sense-quarantaene-isolation a drift:Sense ;
    drift:gloss "enforced isolation of persons, ships, or goods to prevent the spread of contagious disease"@en ;
    drift:gloss "behoerdlich angeordnete Absonderung von Personen, Schiffen oder Waren zur Verhinderung der Ausbreitung ansteckender Krankheiten"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1400"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1400"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-quarantaene-venice a drift:TriggerEvent ;
    rdfs:label "Venetian and Ragusan plague isolation regime"@en ;
    dct:description "In 1377 the Great Council of Ragusa (Dubrovnik) imposed a thirty-day (trentina) isolation on arrivals from plague areas; Venice and other ports extended it to forty days (quarantina). The fixed forty-day ship isolation against the Black Death attached the disease-control meaning to the number-word."@en ;
    drift:eventDate "1377"^^xsd:gYear ;
    drift:triggerCategory drift:Pandemic .

# --- drift event ---
wdr:drift-quarantaene-venice a drift:DriftEvent ;
    drift:affectsWord wdr:word-quarantaene ;
    drift:senseFrom wdr:sense-quarantaene-forty ;
    drift:senseTo wdr:sense-quarantaene-isolation ;
    drift:driftType drift:Narrowing ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1370"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1450"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-quarantaene-dwds , wdr:src-quarantaene-wiki .

# --- causal hypothesis ---
wdr:hyp-quarantaene-venice a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-quarantaene-venice ;
    drift:proposedTrigger wdr:trigger-quarantaene-venice ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-quarantaene-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-quarantaene-dwds a drift:Source ;
    dct:title "DWDS -- Quarantaene"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Quarant%C3%A4ne"^^xsd:anyURI .

wdr:src-quarantaene-wiki a drift:Source ;
    dct:title "Quarantine -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Quarantine"^^xsd:anyURI .
