@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "canary" (en)
# Metonymization: the songbird native to the Canary Islands was
# called "Canary-bird", shortened to "canary". The islands are
# the trigger (their own name is from Latin Insula Canaria,
# "island of dogs", though that origin is debated).
# =============================================================

wdr:word-canary a drift:Word ;
    drift:writtenForm "canary"@en ;
    drift:language "en" ;
    rdfs:label "canary"@en ;
    ontolex:sense wdr:sense-canary-islands , wdr:sense-canary-bird .

wdr:sense-canary-islands a drift:Sense ;
    drift:gloss "of or from the Canary Islands; short for 'Canary-bird', a finch native to those islands"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1570"^^xsd:gYear .

wdr:sense-canary-bird a drift:Sense ;
    drift:gloss "the small yellow song finch (Serinus canaria), widely kept as a cage bird"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1650"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1650"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-canary-islands a drift:TriggerEvent ;
    rdfs:label "Songbird of the Canary Islands"@en ;
    dct:description "The finch native to the Canary Islands was called 'Canary-bird' (1570s) for its place of origin, then shortened to 'canary' (1650s). The islands' Latin name Insula Canaria ('island of dogs') is itself debated."@en ;
    drift:eventDate "1570"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial ;
    owl:sameAs wd:Q5813 .

# --- drift event ---
wdr:drift-canary-islands a drift:DriftEvent ;
    drift:affectsWord wdr:word-canary ;
    drift:senseFrom wdr:sense-canary-islands ;
    drift:senseTo wdr:sense-canary-bird ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1570"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1650"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-canary-etym , wdr:src-canary-wikt .

# --- causal hypothesis ---
wdr:hyp-canary-islands a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-canary-islands ;
    drift:proposedTrigger wdr:trigger-canary-islands ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-canary-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-canary-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- canary"@en ;
    drift:sourceURL "https://www.etymonline.com/word/canary"^^xsd:anyURI .

wdr:src-canary-wikt a drift:Source ;
    dct:title "Wiktionary -- canary"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/canary"^^xsd:anyURI .
