@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Uhu" (de)
# Broadening: August Fischer's 1932 brand of clear synthetic
# adhesive (named after the eagle-owl) -> umgangssprachlich
# generic word for tube glue. The 1932 launch is the trigger.
# =============================================================

wdr:word-uhu-de a drift:Word ;
    drift:writtenForm "Uhu"@de ;
    drift:language "de" ;
    rdfs:label "Uhu"@de ;
    ontolex:sense wdr:sense-uhu-de-brand , wdr:sense-uhu-de-generic .

wdr:sense-uhu-de-brand a drift:Sense ;
    drift:gloss "August Fischer's brand of clear synthetic-resin adhesive"@en ;
    drift:gloss "die Marke Uhu fuer klaren Alleskleber von August Fischer"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1932"^^xsd:gYear .

wdr:sense-uhu-de-generic a drift:Sense ;
    drift:gloss "loosely, any clear tube glue (colloquial German)"@en ;
    drift:gloss "umgangssprachlich allgemein klarer Klebstoff aus der Tube"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1955"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1955"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-uhu-de-brand a drift:TriggerEvent ;
    rdfs:label "Fischer markets Uhu adhesive"@en ;
    dct:description "In 1932 the pharmacist August Fischer of Buehl presented the first ready-to-use clear synthetic-resin adhesive under the brand Uhu (named after the eagle-owl). The brand became a widely used colloquial label for clear tube glue."@en ;
    drift:eventDate "1932"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial ;
    owl:sameAs wd:Q63281550 .

# --- drift event ---
wdr:drift-uhu-de-brand a drift:DriftEvent ;
    drift:affectsWord wdr:word-uhu-de ;
    drift:senseFrom wdr:sense-uhu-de-brand ;
    drift:senseTo wdr:sense-uhu-de-generic ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1932"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1965"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-uhu-de-wikt , wdr:src-uhu-de-wiki .

# --- causal hypothesis ---
wdr:hyp-uhu-de-brand a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-uhu-de-brand ;
    drift:proposedTrigger wdr:trigger-uhu-de-brand ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.7 ;
    drift:hasSource wdr:src-uhu-de-wikt ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-uhu-de-wikt a drift:Source ;
    dct:title "Uhu -- Wiktionary"@de ;
    drift:sourceURL "https://de.wiktionary.org/wiki/Uhu"^^xsd:anyURI .

wdr:src-uhu-de-wiki a drift:Source ;
    dct:title "UHU -- Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/UHU"^^xsd:anyURI .
