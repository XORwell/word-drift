@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "currant" (en)
# Metonymization: from "raysyn of Curans", raisins of Corinth,
# the Greek port that exported the small dried grapes. The
# place name became the fruit name (with -s reanalysed as plural).
# =============================================================

wdr:word-currant a drift:Word ;
    drift:writtenForm "currant"@en ;
    drift:language "en" ;
    rdfs:label "currant"@en ;
    ontolex:sense wdr:sense-currant-corinth , wdr:sense-currant-fruit .

wdr:sense-currant-corinth a drift:Sense ;
    drift:gloss "raisin of Corinth; a small seedless dried grape exported from the Greek port of Corinth"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1400"^^xsd:gYear .

wdr:sense-currant-fruit a drift:Sense ;
    drift:gloss "a small dried grape; also the small round berry of the genus Ribes, named by resemblance"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1500"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1500"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-currant-corinth a drift:TriggerEvent ;
    rdfs:label "Corinth raisin trade"@en ;
    dct:description "Small dried grapes were exported from Corinth as 'raisins of Corauntz'. The place name was clipped to 'currant', with the final -s reanalysed as a plural ending, and became the fruit name."@en ;
    drift:eventDate "1500"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-currant-corinth a drift:DriftEvent ;
    drift:affectsWord wdr:word-currant ;
    drift:senseFrom wdr:sense-currant-corinth ;
    drift:senseTo wdr:sense-currant-fruit ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1400"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1580"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-currant-etym , wdr:src-currant-wikt .

# --- causal hypothesis ---
wdr:hyp-currant-corinth a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-currant-corinth ;
    drift:proposedTrigger wdr:trigger-currant-corinth ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-currant-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-currant-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- currant"@en ;
    drift:sourceURL "https://www.etymonline.com/word/currant"^^xsd:anyURI .

wdr:src-currant-wikt a drift:Source ;
    dct:title "Wiktionary -- currant"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/currant"^^xsd:anyURI .
