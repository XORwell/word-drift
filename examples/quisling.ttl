@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "quisling" (en)
# Metonymization with pejoration: surname of Vidkun Quisling,
# Norwegian collaborator with Nazi Germany, becomes a generic
# contemptuous noun for "traitor / collaborator". The German
# invasion of Norway in 1940 is the datable trigger.
# =============================================================

wdr:word-quisling a drift:Word ;
    drift:writtenForm "quisling"@en ;
    drift:language "en" ;
    rdfs:label "quisling"@en ;
    ontolex:sense wdr:sense-quisling-name , wdr:sense-quisling-traitor .

wdr:sense-quisling-name a drift:Sense ;
    drift:gloss "the surname of Vidkun Quisling (1887-1945), Norwegian politician who collaborated with Nazi Germany"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1887"^^xsd:gYear .

wdr:sense-quisling-traitor a drift:Sense ;
    drift:gloss "a traitor who collaborates with an occupying enemy power; a fifth columnist"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1940"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1940"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-quisling-invasion a drift:TriggerEvent ;
    rdfs:label "German invasion of Norway and Quisling's coup attempt"@en ;
    dct:description "On 9 April 1940 Germany invaded Norway; Vidkun Quisling proclaimed himself head of government. Within weeks Allied press, notably a 1940 leader in The Times, turned his name into a generic term for traitor."@en ;
    drift:eventDate "1940"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

# --- drift event ---
wdr:drift-quisling-invasion a drift:DriftEvent ;
    drift:affectsWord wdr:word-quisling ;
    drift:senseFrom wdr:sense-quisling-name ;
    drift:senseTo wdr:sense-quisling-traitor ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1940"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1941"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-quisling-etym , wdr:src-quisling-wiki .

# --- causal hypothesis ---
wdr:hyp-quisling-invasion a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-quisling-invasion ;
    drift:proposedTrigger wdr:trigger-quisling-invasion ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-quisling-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-quisling-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- quisling"@en ;
    drift:sourceURL "https://www.etymonline.com/word/quisling"^^xsd:anyURI .

wdr:src-quisling-wiki a drift:Source ;
    dct:title "Vidkun Quisling -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Vidkun_Quisling"^^xsd:anyURI .
