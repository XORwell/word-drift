@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "fuchsia" (en)
# Metonymization: the surname Fuchs (Leonhart Fuchs, 1501-1566,
# German botanist) was Latinized by Charles Plumier in 1703 to
# name the flowering shrub, in English by 1753. The honorific
# naming of the genus is the identifiable trigger.
# =============================================================

wdr:word-fuchsia a drift:Word ;
    drift:writtenForm "fuchsia"@en ;
    drift:language "en" ;
    rdfs:label "fuchsia"@en ;
    ontolex:sense wdr:sense-fuchsia-name , wdr:sense-fuchsia-plant .

wdr:sense-fuchsia-name a drift:Sense ;
    drift:gloss "the Latinized surname of the German botanist Leonhart Fuchs"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1501"^^xsd:gYear .

wdr:sense-fuchsia-plant a drift:Sense ;
    drift:gloss "an ornamental flowering shrub with drooping tubular flowers; also a vivid purplish-red colour"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1753"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1753"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-fuchsia-plumier a drift:TriggerEvent ;
    rdfs:label "Plumier names the genus Fuchsia for Leonhart Fuchs"@en ;
    dct:description "The French botanist Charles Plumier named the genus Fuchsia in 1703 in honour of the German botanist Leonhart Fuchs. The English word is attested by 1753, and the colour sense by 1921."@en ;
    drift:eventDate "1703"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural ;
    owl:sameAs wd:Q60756 .

# --- drift event ---
wdr:drift-fuchsia-plumier a drift:DriftEvent ;
    drift:affectsWord wdr:word-fuchsia ;
    drift:senseFrom wdr:sense-fuchsia-name ;
    drift:senseTo wdr:sense-fuchsia-plant ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1703"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1753"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-fuchsia-etym , wdr:src-fuchsia-wiki .

# --- causal hypothesis ---
wdr:hyp-fuchsia-plumier a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-fuchsia-plumier ;
    drift:proposedTrigger wdr:trigger-fuchsia-plumier ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-fuchsia-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-fuchsia-etym a drift:Source ;
    dct:title "fuchsia -- Online Etymology Dictionary"@en ;
    drift:sourceURL "https://www.etymonline.com/word/fuchsia"^^xsd:anyURI .

wdr:src-fuchsia-wiki a drift:Source ;
    dct:title "Leonhart Fuchs -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Leonhart_Fuchs"^^xsd:anyURI .
