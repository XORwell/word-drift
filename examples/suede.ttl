@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "suede" (en)
# Metonymization: French "gants de Suede", gloves of Sweden, gave
# English "suede" for the soft napped leather. The country name
# (Suede = Sweden) is the trigger.
# =============================================================

wdr:word-suede a drift:Word ;
    drift:writtenForm "suede"@en ;
    drift:language "en" ;
    rdfs:label "suede"@en ;
    ontolex:sense wdr:sense-suede-gloves , wdr:sense-suede-leather .

wdr:sense-suede-gloves a drift:Sense ;
    drift:gloss "from French 'gants de Suede', gloves of Sweden, made of soft undressed kidskin"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1859"^^xsd:gYear .

wdr:sense-suede-leather a drift:Sense ;
    drift:gloss "soft leather with a napped, velvety surface; undressed kid skin"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1884"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1884"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-suede-sweden a drift:TriggerEvent ;
    rdfs:label "Gloves of Sweden (gants de Suede)"@en ;
    dct:description "The French phrase 'gants de Suede', gloves of Sweden, named the soft napped leather; English took 'suede' from it (the phrase in English by 1859, the noun by 1884), the country name standing for the material."@en ;
    drift:eventDate "1884"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial ;
    owl:sameAs wd:Q34 .

# --- drift event ---
wdr:drift-suede-sweden a drift:DriftEvent ;
    drift:affectsWord wdr:word-suede ;
    drift:senseFrom wdr:sense-suede-gloves ;
    drift:senseTo wdr:sense-suede-leather ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1859"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1884"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-suede-etym , wdr:src-suede-wikt .

# --- causal hypothesis ---
wdr:hyp-suede-sweden a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-suede-sweden ;
    drift:proposedTrigger wdr:trigger-suede-sweden ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-suede-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-suede-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- suede"@en ;
    drift:sourceURL "https://www.etymonline.com/word/suede"^^xsd:anyURI .

wdr:src-suede-wikt a drift:Source ;
    dct:title "Wiktionary -- suede"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/suede"^^xsd:anyURI .
