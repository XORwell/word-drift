@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "jeans" (en)
# Metonymization: "jean" was a sturdy twilled cotton-linen
# fustian named for Genoa (Genes), the Italian port that traded
# it; the place name became the name of the cloth and then of
# the trousers made from it.
# =============================================================

wdr:word-jeans a drift:Word ;
    drift:writtenForm "jeans"@en ;
    drift:language "en" ;
    rdfs:label "jeans"@en ;
    ontolex:sense wdr:sense-jeans-place , wdr:sense-jeans-garment .

wdr:sense-jeans-place a drift:Sense ;
    drift:gloss "a heavy twilled cotton or fustian cloth named for Genoa, the port from which it was traded"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1567"^^xsd:gYear .

wdr:sense-jeans-garment a drift:Sense ;
    drift:gloss "casual trousers made of denim or similar hard-wearing cloth"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1843"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1843"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-jeans-genoa a drift:TriggerEvent ;
    rdfs:label "Genoese cloth trade"@en ;
    dct:description "Genoa (French Genes) was the European source of a sturdy fustian cloth. The fabric carried the city name into English as 'jean'; the trousers cut from it later took the same name."@en ;
    drift:eventDate "1567"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-jeans-genoa a drift:DriftEvent ;
    drift:affectsWord wdr:word-jeans ;
    drift:senseFrom wdr:sense-jeans-place ;
    drift:senseTo wdr:sense-jeans-garment ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1560"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1850"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-jeans-etym , wdr:src-jeans-wikt .

# --- causal hypothesis ---
wdr:hyp-jeans-genoa a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-jeans-genoa ;
    drift:proposedTrigger wdr:trigger-jeans-genoa ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-jeans-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-jeans-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- jean / jeans"@en ;
    drift:sourceURL "https://www.etymonline.com/word/jean"^^xsd:anyURI .

wdr:src-jeans-wikt a drift:Source ;
    dct:title "Wiktionary -- jeans"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/jeans"^^xsd:anyURI .
