@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "maverick" (en)
# Broadening: from Texas rancher Samuel A. Maverick, whose
# unbranded cattle gave the word for "unbranded calf" -> any
# independent, unconventional person. The mid-1860s ranching
# usage is the identifiable trigger.
# =============================================================

wdr:word-maverick a drift:Word ;
    drift:writtenForm "maverick"@en ;
    drift:language "en" ;
    rdfs:label "maverick"@en ;
    ontolex:sense wdr:sense-maverick-cattle , wdr:sense-maverick-person .

wdr:sense-maverick-cattle a drift:Sense ;
    drift:gloss "an unbranded calf or yearling found without an owner's mark, after rancher Samuel A. Maverick (1803-1870) who left his cattle unbranded"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1867"^^xsd:gYear .

wdr:sense-maverick-person a drift:Sense ;
    drift:gloss "an independent-minded, unconventional person who refuses to conform to a group or party"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1886"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1886"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-maverick-cattle a drift:TriggerEvent ;
    rdfs:label "Samuel Maverick's unbranded Texas cattle"@en ;
    dct:description "Texas landowner Samuel A. Maverick was known for not branding his cattle, so unmarked strays came to be called 'mavericks' by the mid-1860s. The cattle sense broadened to mean any unattached, independent individual."@en ;
    drift:eventDate "1867"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-maverick-cattle a drift:DriftEvent ;
    drift:affectsWord wdr:word-maverick ;
    drift:senseFrom wdr:sense-maverick-cattle ;
    drift:senseTo wdr:sense-maverick-person ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1867"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1890"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-maverick-etym , wdr:src-maverick-wiki .

# --- causal hypothesis ---
wdr:hyp-maverick-cattle a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-maverick-cattle ;
    drift:proposedTrigger wdr:trigger-maverick-cattle ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-maverick-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-maverick-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- maverick"@en ;
    drift:sourceURL "https://www.etymonline.com/word/maverick"^^xsd:anyURI .

wdr:src-maverick-wiki a drift:Source ;
    dct:title "Maverick (animal) -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Maverick_(animal)"^^xsd:anyURI .
