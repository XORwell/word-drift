@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "tesla" (en)
# Metonymization: the surname Tesla (Nikola Tesla, 1856-1943,
# electrical engineer) becomes the common name of the SI unit
# of magnetic flux density, adopted by 1960. His electromagnetic
# work is the identifiable trigger.
# =============================================================

wdr:word-tesla a drift:Word ;
    drift:writtenForm "tesla"@en ;
    drift:language "en" ;
    rdfs:label "tesla"@en ;
    ontolex:sense wdr:sense-tesla-name , wdr:sense-tesla-unit .

wdr:sense-tesla-name a drift:Sense ;
    drift:gloss "the surname of the Serbian-American engineer and inventor Nikola Tesla"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1856"^^xsd:gYear .

wdr:sense-tesla-unit a drift:Sense ;
    drift:gloss "the SI unit of magnetic flux density, equal to one weber per square metre"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1960"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1960"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-tesla-electromagnetism a drift:TriggerEvent ;
    rdfs:label "Tesla's work on electromagnetism and alternating current"@en ;
    dct:description "Nikola Tesla's pioneering work on alternating current and electromagnetic devices made his name a fitting honour for the unit of magnetic flux density, adopted by 1960 at the 11th General Conference on Weights and Measures."@en ;
    drift:eventDate "1888"^^xsd:gYear ;
    drift:triggerCategory drift:Technology ;
    owl:sameAs wd:Q9036 .

# --- drift event ---
wdr:drift-tesla-electromagnetism a drift:DriftEvent ;
    drift:affectsWord wdr:word-tesla ;
    drift:senseFrom wdr:sense-tesla-name ;
    drift:senseTo wdr:sense-tesla-unit ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1888"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1960"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-tesla-etym , wdr:src-tesla-wiki .

# --- causal hypothesis ---
wdr:hyp-tesla-electromagnetism a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-tesla-electromagnetism ;
    drift:proposedTrigger wdr:trigger-tesla-electromagnetism ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-tesla-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-tesla-etym a drift:Source ;
    dct:title "tesla -- Online Etymology Dictionary"@en ;
    drift:sourceURL "https://www.etymonline.com/word/tesla"^^xsd:anyURI .

wdr:src-tesla-wiki a drift:Source ;
    dct:title "Nikola Tesla -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Nikola_Tesla"^^xsd:anyURI .
