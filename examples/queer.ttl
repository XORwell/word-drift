@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# =============================================================
# WORKED EXAMPLE - "queer" (en)
# 1. 16c: "strange, peculiar, odd" (neutral-negative)
# 2. Early 20c: pejorative slur for homosexuals
# 3. 1990s: activist reappropriation; now positive/neutral
#    umbrella term for LGBTQ+ identities
# =============================================================

wdr:word-queer a drift:Word ;
    drift:writtenForm "queer"@en ;
    drift:language "en" ;
    rdfs:label "queer"@en ;
    ontolex:sense wdr:sense-queer-strange , wdr:sense-queer-slur , wdr:sense-queer-reclaimed .

wdr:sense-queer-strange a drift:Sense ;
    drift:gloss "strange, odd, peculiar; differing from the normal or expected"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1513"^^xsd:gYear .

wdr:sense-queer-slur a drift:Sense ;
    drift:gloss "derogatory slur targeting homosexual or gender-nonconforming people"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1894"^^xsd:gYear .

wdr:sense-queer-reclaimed a drift:Sense ;
    drift:gloss "umbrella term for non-heterosexual and non-cisgender identities, reclaimed as neutral or positive by the LGBTQ+ community"@en ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1990"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1990"^^xsd:gYear ]
    ] .

# --- trigger events ---
wdr:trigger-queer-nation a drift:TriggerEvent ;
    rdfs:label "Queer Nation and ACT UP activist reappropriation"@en ;
    dct:description "Queer Nation (founded 1990) and ACT UP activists deliberately reclaimed 'queer' as an empowering self-description, reversing its slur status."@en ;
    drift:eventDate "1990"^^xsd:gYear ;
    drift:triggerCategory drift:Political ;
    owl:sameAs wd:Q5687582 .

# --- drift event 1: pejoration (strange -> slur; no external trigger) ---
wdr:drift-queer-1890s a drift:DriftEvent ;
    drift:affectsWord wdr:word-queer ;
    drift:senseFrom wdr:sense-queer-strange ;
    drift:senseTo wdr:sense-queer-slur ;
    drift:driftType drift:Pejoration ;
    drift:driftYear "1894"^^xsd:gYear ;
    drift:hasSource wdr:src-queer-oed .

# --- drift event 2: reappropriation (causation lives in the hypothesis below) ---
wdr:drift-queer-1990 a drift:DriftEvent ;
    drift:affectsWord wdr:word-queer ;
    drift:senseFrom wdr:sense-queer-slur ;
    drift:senseTo wdr:sense-queer-reclaimed ;
    drift:driftType drift:Reappropriation , drift:Amelioration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1990"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "2000"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-queer-oed , wdr:src-queer-wikipedia .

# --- causal hypothesis (ADR 0004) ---
# OED is a dictionary source -> LexicographicNote; Wikipedia is general -> Speculative.
wdr:hyp-queer-nation a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-queer-1990 ;
    drift:proposedTrigger wdr:trigger-queer-nation ;
    drift:evidenceType drift:LexicographicNote , drift:Speculative ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-queer-oed , wdr:src-queer-wikipedia ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-queer-oed a drift:Source ;
    dct:title "Oxford English Dictionary - queer, adj."@en ;
    drift:sourceURL "https://www.oed.com/dictionary/queer_adj"^^xsd:anyURI .

wdr:src-queer-wikipedia a drift:Source ;
    dct:title "Queer - Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Queer"^^xsd:anyURI .
