@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "sick" (en)
# Amelioration (slang reappropriation): "ill, unwell; (later)
# disturbing, in poor taste, perverse" -> approving slang
# "excellent, impressive, awesome". A gradual slang reversal,
# popularised through skate / surf / youth culture, with no
# single crisp datable event.
# =============================================================

wdr:word-sick a drift:Word ;
    drift:writtenForm "sick"@en ;
    drift:language "en" ;
    rdfs:label "sick"@en ;
    ontolex:sense wdr:sense-sick-ill , wdr:sense-sick-excellent .

wdr:sense-sick-ill a drift:Sense ;
    drift:gloss "ill, unwell, affected by disease; (also, later) morally disturbing, perverse, in poor taste"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1000"^^xsd:gYear .

wdr:sense-sick-excellent a drift:Sense ;
    drift:gloss "(slang) excellent, impressive, awesome; remarkably good or skilful"@en ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1980"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1980"^^xsd:gYear ]
    ] .

# --- trigger event (gradual, undetermined driver) ---
wdr:trigger-sick-slang a drift:TriggerEvent ;
    rdfs:label "Youth-culture slang reversal of a negative term"@en ;
    dct:description "No single datable event. Like 'bad', 'wicked' and 'ill', 'sick' was reversed to a term of approval in late 20th-century youth slang (skate, surf, hip hop), where extremity itself is praised. The anchor year is a representative decade, not a cause."@en ;
    drift:eventDate "1980"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-sick-amelioration a drift:DriftEvent ;
    drift:affectsWord wdr:word-sick ;
    drift:senseFrom wdr:sense-sick-ill ;
    drift:senseTo wdr:sense-sick-excellent ;
    drift:driftType drift:Amelioration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1980"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "2000"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-sick-etymonline , wdr:src-sick-merriam .

# --- causal hypothesis ---
wdr:hyp-sick-slang a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-sick-amelioration ;
    drift:proposedTrigger wdr:trigger-sick-slang ;
    drift:evidenceType drift:Speculative ;
    drift:confidence 0.55 ;
    drift:hasSource wdr:src-sick-merriam ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-sick-etymonline a drift:Source ;
    dct:title "Etymonline - sick (adj.)"@en ;
    drift:sourceURL "https://www.etymonline.com/word/sick"^^xsd:anyURI .

wdr:src-sick-merriam a drift:Source ;
    dct:title "Merriam-Webster - sick"@en ;
    drift:sourceURL "https://www.merriam-webster.com/dictionary/sick"^^xsd:anyURI .
