@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Vandalismus" (de)
# Pejoration: an ethnonym (the Vandals, a Germanic people)
# reshaped into a term for wanton destruction. The abbe Henri
# Gregoire coined "vandalisme" in 1794 during the French
# Revolution. The coinage is the identifiable trigger.
# =============================================================

wdr:word-vandalismus a drift:Word ;
    drift:writtenForm "Vandalismus"@de ;
    drift:language "de" ;
    rdfs:label "Vandalismus"@de ;
    ontolex:sense wdr:sense-vandalismus-ethnonym , wdr:sense-vandalismus-destruction .

wdr:sense-vandalismus-ethnonym a drift:Sense ;
    drift:gloss "of or relating to the Vandals, a Germanic people of late antiquity who sacked Rome in 455"@en ;
    drift:gloss "die Vandalen betreffend, ein germanisches Volk der Spaetantike, das 455 Rom pluenderte"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1500"^^xsd:gYear .

wdr:sense-vandalismus-destruction a drift:Sense ;
    drift:gloss "wilful or malicious destruction or defacement of property, art, or public works"@en ;
    drift:gloss "mutwillige Zerstoerung oder Beschaedigung von Eigentum, Kunst oder oeffentlichen Anlagen"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1794"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1794"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-vandalismus-gregoire a drift:TriggerEvent ;
    rdfs:label "Henri Gregoire coins 'vandalisme' during the French Revolution"@en ;
    dct:description "In 1794 the abbe Henri Gregoire coined the French term 'vandalisme' to denounce the revolutionary destruction of monuments and artworks, invoking the Vandals' reputation for sacking Rome. The word spread into German as 'Vandalismus' with its negative sense."@en ;
    drift:eventDate "1794"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

# --- drift event ---
wdr:drift-vandalismus-gregoire a drift:DriftEvent ;
    drift:affectsWord wdr:word-vandalismus ;
    drift:senseFrom wdr:sense-vandalismus-ethnonym ;
    drift:senseTo wdr:sense-vandalismus-destruction ;
    drift:driftType drift:Pejoration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1794"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1800"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-vandalismus-etym , wdr:src-vandalismus-wiki .

# --- causal hypothesis ---
wdr:hyp-vandalismus-gregoire a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-vandalismus-gregoire ;
    drift:proposedTrigger wdr:trigger-vandalismus-gregoire ;
    drift:evidenceType drift:ScholarlyAttestation ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-vandalismus-wiki ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-vandalismus-etym a drift:Source ;
    dct:title "etymonline -- vandalism"@en ;
    drift:sourceURL "https://www.etymonline.com/word/vandalism"^^xsd:anyURI .

wdr:src-vandalismus-wiki a drift:Source ;
    dct:title "Vandalism -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Vandalism"^^xsd:anyURI .
