@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "egregious" (en)
# Reversal / Pejoration: Latin "egregius" (distinguished,
# illustrious; literally 'standing out from the flock') ->
# English "remarkably good, eminent" -> ironic use ->
# "remarkably bad, flagrant, conspicuously offensive". A
# polarity flip driven by ironic usage, with no crisp event.
# =============================================================

wdr:word-egregious a drift:Word ;
    drift:writtenForm "egregious"@en ;
    drift:language "en" ;
    rdfs:label "egregious"@en ;
    ontolex:sense wdr:sense-egregious-eminent , wdr:sense-egregious-flagrant .

wdr:sense-egregious-eminent a drift:Sense ;
    drift:gloss "remarkably good, distinguished, eminent; standing out from the crowd in a positive way (Latin egregius, 'out of the flock')"@en ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1534"^^xsd:gYear .

wdr:sense-egregious-flagrant a drift:Sense ;
    drift:gloss "remarkably bad; flagrant, conspicuously offensive; outrageously bad in a way that stands out"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1573"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1573"^^xsd:gYear ]
    ] .

# --- trigger event (gradual, undetermined driver) ---
wdr:trigger-egregious-irony a drift:TriggerEvent ;
    rdfs:label "Ironic reversal of a term of praise"@en ;
    dct:description "No single datable event. The positive 'distinguished' was applied ironically (egregiously bad), and the ironic, negative sense displaced the original within a few decades in the later 16th century. The anchor year is the earliest negative attestation, not a cause."@en ;
    drift:eventDate "1573"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-egregious-reversal a drift:DriftEvent ;
    drift:affectsWord wdr:word-egregious ;
    drift:senseFrom wdr:sense-egregious-eminent ;
    drift:senseTo wdr:sense-egregious-flagrant ;
    drift:driftType drift:Reversal ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1550"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1650"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-egregious-etymonline , wdr:src-egregious-oed .

# --- causal hypothesis ---
wdr:hyp-egregious-irony a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-egregious-reversal ;
    drift:proposedTrigger wdr:trigger-egregious-irony ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.62 ;
    drift:hasSource wdr:src-egregious-etymonline ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-egregious-etymonline a drift:Source ;
    dct:title "Etymonline - egregious (adj.)"@en ;
    drift:sourceURL "https://www.etymonline.com/word/egregious"^^xsd:anyURI .

wdr:src-egregious-oed a drift:Source ;
    dct:title "Oxford English Dictionary - egregious, adj."@en ;
    drift:sourceURL "https://www.oed.com/dictionary/egregious_adj"^^xsd:anyURI .
