@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "saxophone" (en)
# Metonymization: the surname Sax (Adolphe Sax, who patented the
# instrument in 1846) is fused with -phone to name the woodwind.
# The patent of the instrument is the identifiable trigger.
# =============================================================

wdr:word-saxophone a drift:Word ;
    drift:writtenForm "saxophone"@en ;
    drift:language "en" ;
    rdfs:label "saxophone"@en ;
    ontolex:sense wdr:sense-saxophone-name , wdr:sense-saxophone-instrument .

wdr:sense-saxophone-name a drift:Sense ;
    drift:gloss "formed from the surname of the Belgian instrument maker Adolphe Sax plus the Greek element -phone 'sound'"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1814"^^xsd:gYear .

wdr:sense-saxophone-instrument a drift:Sense ;
    drift:gloss "a single-reed woodwind instrument with a conical brass body; an everyday word central to jazz and popular music"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1846"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1846"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-saxophone-patent a drift:TriggerEvent ;
    rdfs:label "Sax patents the saxophone"@en ;
    dct:description "In 1846 Adolphe Sax obtained a French patent for the family of instruments he had designed. The instruments and the word formed from his name spread rapidly through military and later jazz ensembles."@en ;
    drift:eventDate "1846"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

# --- drift event ---
wdr:drift-saxophone-patent a drift:DriftEvent ;
    drift:affectsWord wdr:word-saxophone ;
    drift:senseFrom wdr:sense-saxophone-name ;
    drift:senseTo wdr:sense-saxophone-instrument ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1840"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1846"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-saxophone-etym , wdr:src-saxophone-wiki .

# --- causal hypothesis ---
wdr:hyp-saxophone-patent a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-saxophone-patent ;
    drift:proposedTrigger wdr:trigger-saxophone-patent ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-saxophone-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-saxophone-etym a drift:Source ;
    dct:title "saxophone -- Online Etymology Dictionary"@en ;
    drift:sourceURL "https://www.etymonline.com/word/saxophone"^^xsd:anyURI .

wdr:src-saxophone-wiki a drift:Source ;
    dct:title "Adolphe Sax -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Adolphe_Sax"^^xsd:anyURI .
