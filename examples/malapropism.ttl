@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "malapropism" (en)
# Metaphorization: eponym from Mrs Malaprop, a character in
# Sheridan's play "The Rivals" (1775) who comically misused
# words. Her name yielded the term for such blunders. The play
# is the identifiable origin.
# =============================================================

wdr:word-malapropism a drift:Word ;
    drift:writtenForm "malapropism"@en ;
    drift:language "en" ;
    rdfs:label "malapropism"@en ;
    ontolex:sense wdr:sense-malapropism-eponym , wdr:sense-malapropism-error .

wdr:sense-malapropism-eponym a drift:Sense ;
    drift:gloss "of or relating to Mrs Malaprop, the word-mangling character in Sheridan's comedy The Rivals"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1775"^^xsd:gYear .

wdr:sense-malapropism-error a drift:Sense ;
    drift:gloss "the mistaken use of a word in place of a similar-sounding one, often with comic effect"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1830"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1830"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-malapropism-rivals a drift:TriggerEvent ;
    rdfs:label "Premiere of Sheridan's The Rivals"@en ;
    dct:description "Richard Brinsley Sheridan's comedy The Rivals premiered in 1775. Its character Mrs Malaprop habitually confused similar-sounding words; her name (from French 'mal a propos') became the term for such verbal blunders by metaphor."@en ;
    drift:eventDate "1775"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-malapropism-rivals a drift:DriftEvent ;
    drift:affectsWord wdr:word-malapropism ;
    drift:senseFrom wdr:sense-malapropism-eponym ;
    drift:senseTo wdr:sense-malapropism-error ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1775"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1840"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-malapropism-etym , wdr:src-malapropism-wiki .

# --- causal hypothesis ---
wdr:hyp-malapropism-rivals a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-malapropism-rivals ;
    drift:proposedTrigger wdr:trigger-malapropism-rivals ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-malapropism-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-malapropism-etym a drift:Source ;
    dct:title "etymonline -- malapropism"@en ;
    drift:sourceURL "https://www.etymonline.com/word/malapropism"^^xsd:anyURI .

wdr:src-malapropism-wiki a drift:Source ;
    dct:title "Mrs. Malaprop -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Mrs._Malaprop"^^xsd:anyURI .
