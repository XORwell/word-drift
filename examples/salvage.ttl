@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "salvage" (en)
# Broadening: maritime-law term "payment for rescuing a ship or
# cargo from peril at sea" (c. 1645) -> the act of saving usable
# goods from wreckage or waste, and figuratively rescuing anything
# from failure ("salvage the deal"). Driven by marine-insurance and
# salvage law, then generalised; a gradual extension, so the causal
# claim is modest.
# =============================================================

wdr:word-salvage a drift:Word ;
    drift:writtenForm "salvage"@en ;
    drift:language "en" ;
    rdfs:label "salvage"@en ;
    ontolex:sense wdr:sense-salvage-maritime , wdr:sense-salvage-reclaim .

wdr:sense-salvage-maritime a drift:Sense ;
    drift:gloss "payment or compensation due to those who save a ship or its cargo from loss at sea; a maritime-law term"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1645"^^xsd:gYear .

wdr:sense-salvage-reclaim a drift:Sense ;
    drift:gloss "the act of saving goods or usable material from wreckage, fire, or waste; figuratively, to rescue something from failure or loss"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1880"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1880"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-salvage-marinelaw a drift:TriggerEvent ;
    rdfs:label "Marine insurance and salvage law"@en ;
    dct:description "The body of maritime salvage law and the marine-insurance market (notably Lloyd's of London) made 'salvage' a common commercial term for recovering property from peril. From this base the sense broadened in the 19th century to reclaiming usable material generally, and later to figurative rescue."@en ;
    drift:eventDate "1680"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-salvage-reclaim a drift:DriftEvent ;
    drift:affectsWord wdr:word-salvage ;
    drift:senseFrom wdr:sense-salvage-maritime ;
    drift:senseTo wdr:sense-salvage-reclaim ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1700"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1900"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-salvage-etymonline , wdr:src-salvage-oed .

# --- causal hypothesis ---
wdr:hyp-salvage-marinelaw a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-salvage-reclaim ;
    drift:proposedTrigger wdr:trigger-salvage-marinelaw ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.6 ;
    drift:hasSource wdr:src-salvage-etymonline ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-24"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-salvage-etymonline a drift:Source ;
    dct:title "Etymonline -- salvage"@en ;
    drift:sourceURL "https://www.etymonline.com/word/salvage"^^xsd:anyURI .

wdr:src-salvage-oed a drift:Source ;
    dct:title "Oxford English Dictionary -- salvage, n."@en ;
    drift:sourceURL "https://www.oed.com/dictionary/salvage_n"^^xsd:anyURI .
