@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "circle" (en) -- SemEval-2020 Task 1 English target word.
# Broadening: the geometric/round-shape sense broadens as the
# social sense ("a circle of friends", "literary circles", a
# group sharing an interest) gains relative weight across the
# 20th century.
# DETECTION-BENCHMARK WORD (ADR 0004): SemEval attests the change
# empirically (graded change 0.71, binary-changed gold label), but
# the CAUSE is gradual polysemy with no single datable trigger.
# ChangeSignalAlignment + honest Speculative cause at modest
# confidence: detection strength is NOT causal confidence.
# =============================================================

wdr:word-circle a drift:Word ;
    drift:writtenForm "circle"@en ;
    drift:language "en" ;
    rdfs:label "circle"@en ;
    ontolex:sense wdr:sense-circle-shape , wdr:sense-circle-social .

wdr:sense-circle-shape a drift:Sense ;
    drift:gloss "a round plane figure or ring; any roughly circular shape or arrangement"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1300"^^xsd:gYear .

wdr:sense-circle-social a drift:Sense ;
    drift:gloss "a group of people connected by shared interest, acquaintance or activity (a circle of friends, literary circles, inner circle)"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1900"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1900"^^xsd:gYear ]
    ] .

# --- trigger event (honest: gradual, undetermined) ---
wdr:trigger-circle-polysemy a drift:TriggerEvent ;
    rdfs:label "gradual polysemous extension of 'circle' across the 20th century"@en ;
    dct:description "No single datable event. The social-group sense of 'circle' gained relative weight gradually; the cause is undetermined polysemy. Recorded as a diffuse trigger so the change can be aligned with the SemEval signal without asserting a specific cause."@en ;
    drift:eventDate "1950"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-circle-broadening a drift:DriftEvent ;
    drift:affectsWord wdr:word-circle ;
    drift:senseFrom wdr:sense-circle-shape ;
    drift:senseTo wdr:sense-circle-social ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1860"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1960"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-circle-etymonline .

# --- causal hypothesis ---
# ChangeSignalAlignment from SemEval graded change 0.71 (changed
# gold label); Speculative cause -> confidence held modest (0.6).
wdr:hyp-circle-polysemy a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-circle-broadening ;
    drift:proposedTrigger wdr:trigger-circle-polysemy ;
    drift:evidenceType drift:ChangeSignalAlignment , drift:Speculative ;
    drift:confidence 0.6 ;
    drift:hasSource wdr:src-circle-semeval , wdr:src-circle-etymonline ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-circle-semeval a drift:Source ;
    dct:title "SemEval-2020 Task 1 (English) -- graded change 0.71 for 'circle'"@en ;
    drift:sourceURL "https://zenodo.org/records/3931969"^^xsd:anyURI ;
    rdfs:comment "Graded-change gold score 0.71 (binary label: changed) for 'circle'. In-repo as wdr:drift-semeval-circle (data/semeval.ttl). Used as ChangeSignalAlignment evidence; the score attests the change, not its cause."@en .

wdr:src-circle-etymonline a drift:Source ;
    dct:title "circle (n.) -- Online Etymology Dictionary"@en ;
    drift:sourceURL "https://www.etymonline.com/word/circle"^^xsd:anyURI .
