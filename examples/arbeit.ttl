@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Arbeit" (de)
# Amelioration + Broadening: OHG arebeit "toil, hardship,
# suffering; forced labour of an orphan or serf" -> MHG "pain,
# hardship" -> NHG "labour, work" (neutral to positive as a
# dignified economic and moral category).
# The Protestant work ethic and the emergence of industrial
# capitalism are the contested triggers.
# =============================================================

wdr:word-arbeit a drift:Word ;
    drift:writtenForm "Arbeit"@de ;
    drift:language "de" ;
    rdfs:label "Arbeit"@de ;
    ontolex:sense wdr:sense-arbeit-toil , wdr:sense-arbeit-labour .

wdr:sense-arbeit-toil a drift:Sense ;
    drift:gloss "toil, hardship, suffering; forced drudgery; associated with servitude and pain"@en ;
    drift:gloss "Muehsal, Plage, Not; Schwerstarbeit von Unfreien"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "0800"^^xsd:gYear .

wdr:sense-arbeit-labour a drift:Sense ;
    drift:gloss "work, labour; productive activity; a profession or occupation; a neutral or positive economic category"@en ;
    drift:gloss "Taetikeit, Beruf, Erwerbstaetigkeit; neutrale bis positive wirtschaftliche Kategorie"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1650"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1650"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-arbeit-protestant a drift:TriggerEvent ;
    rdfs:label "Protestant Reformation and the valorisation of secular vocation (Beruf)"@en ;
    dct:description "Luther's concept of the Beruf (calling/vocation) and the Protestant ethic elevated secular labour to a morally dignified activity, helping transform Arbeit from mere toil to valued work."@en ;
    drift:eventDate "1530"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural ;
    owl:sameAs wd:Q12562 .

# --- drift event ---
wdr:drift-arbeit-amelioration a drift:DriftEvent ;
    drift:affectsWord wdr:word-arbeit ;
    drift:senseFrom wdr:sense-arbeit-toil ;
    drift:senseTo wdr:sense-arbeit-labour ;
    drift:driftType drift:Amelioration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1500"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1700"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-arbeit-dwds , wdr:src-arbeit-wissen .

# --- causal hypothesis ---
wdr:hyp-arbeit-protestant a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-arbeit-amelioration ;
    drift:proposedTrigger wdr:trigger-arbeit-protestant ;
    drift:evidenceType drift:Speculative ;
    drift:confidence 0.5 ;
    drift:hasSource wdr:src-arbeit-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-arbeit-dwds a drift:Source ;
    dct:title "DWDS -- Arbeit"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Arbeit"^^xsd:anyURI .

wdr:src-arbeit-wissen a drift:Source ;
    dct:title "wissen.de -- Wortherkunft von Arbeit"@de ;
    drift:sourceURL "https://www.wissen.de/wortherkunft/arbeit"^^xsd:anyURI .
