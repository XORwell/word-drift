@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "ohm" (en)
# Metonymization: the surname Ohm (Georg Simon Ohm, who stated
# Ohm's law in 1827) becomes the common name of the SI unit of
# electrical resistance. The publication of the law is the
# identifiable trigger.
# =============================================================

wdr:word-ohm a drift:Word ;
    drift:writtenForm "ohm"@en ;
    drift:language "en" ;
    rdfs:label "ohm"@en ;
    ontolex:sense wdr:sense-ohm-name , wdr:sense-ohm-unit .

wdr:sense-ohm-name a drift:Sense ;
    drift:gloss "the surname of the German physicist Georg Simon Ohm"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1789"^^xsd:gYear .

wdr:sense-ohm-unit a drift:Sense ;
    drift:gloss "the SI unit of electrical resistance; an everyday word for resistance to current flow"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1867"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1867"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-ohm-law a drift:TriggerEvent ;
    rdfs:label "Ohm publishes Ohm's law"@en ;
    dct:description "In 1827 Georg Simon Ohm published 'Die galvanische Kette, mathematisch bearbeitet', stating the proportionality of current and voltage. His name was adopted for the unit of resistance by the British Association in the 1860s."@en ;
    drift:eventDate "1827"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

# --- drift event ---
wdr:drift-ohm-law a drift:DriftEvent ;
    drift:affectsWord wdr:word-ohm ;
    drift:senseFrom wdr:sense-ohm-name ;
    drift:senseTo wdr:sense-ohm-unit ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1827"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1867"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-ohm-etym , wdr:src-ohm-wiki .

# --- causal hypothesis ---
wdr:hyp-ohm-law a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-ohm-law ;
    drift:proposedTrigger wdr:trigger-ohm-law ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-ohm-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-ohm-etym a drift:Source ;
    dct:title "ohm -- Online Etymology Dictionary"@en ;
    drift:sourceURL "https://www.etymonline.com/word/ohm"^^xsd:anyURI .

wdr:src-ohm-wiki a drift:Source ;
    dct:title "Georg Ohm -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Georg_Ohm"^^xsd:anyURI .
