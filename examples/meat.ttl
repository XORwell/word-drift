@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# WORKED EXAMPLE - "meat" (en)
# Narrowing:
#   Old English "mete" = food in general; solid food
#   (still preserved in "sweetmeat", "mincemeat") ->
#   narrowed to flesh of animals as food.
#   Parallel to German "Mahl" (meal), "Speise" (food).
# =============================================================

wdr:word-meat a drift:Word ;
    drift:writtenForm "meat"@en ;
    drift:language "en" ;
    rdfs:label "meat"@en ;
    ontolex:sense wdr:sense-meat-food , wdr:sense-meat-flesh .

wdr:sense-meat-food a drift:Sense ;
    drift:gloss "food in general; solid nourishment (Old English 'mete'; preserved in 'sweetmeat', 'mincemeat')"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "0700"^^xsd:gYear .

wdr:sense-meat-flesh a drift:Sense ;
    drift:gloss "the flesh of an animal used as food; flesh-food as opposed to fish, vegetables, or dairy"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1300"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1300"^^xsd:gYear ]
    ] .

# --- drift event: narrowing (no external trigger; purely language-internal) ---
wdr:drift-meat-medieval a drift:DriftEvent ;
    drift:affectsWord wdr:word-meat ;
    drift:senseFrom wdr:sense-meat-food ;
    drift:senseTo wdr:sense-meat-flesh ;
    drift:driftType drift:Narrowing ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1200"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1500"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-meat-etymonline , wdr:src-meat-oed .

# --- sources ---
wdr:src-meat-etymonline a drift:Source ;
    dct:title "Etymonline - meat (n.)"@en ;
    drift:sourceURL "https://www.etymonline.com/word/meat"^^xsd:anyURI .

wdr:src-meat-oed a drift:Source ;
    dct:title "Oxford English Dictionary - meat, n."@en ;
    drift:sourceURL "https://www.oed.com/dictionary/meat_n"^^xsd:anyURI .
