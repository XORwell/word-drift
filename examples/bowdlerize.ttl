@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "bowdlerize" (en)
# Metonymization: from Thomas Bowdler, whose 1818 expurgated
# Shakespeare gave a verb (1836) for purging text of matter
# deemed offensive. Bowdler's "Family Shakespeare" is the
# identifiable trigger.
# =============================================================

wdr:word-bowdlerize a drift:Word ;
    drift:writtenForm "bowdlerize"@en ;
    drift:language "en" ;
    rdfs:label "bowdlerize"@en ;
    ontolex:sense wdr:sense-bowdlerize-name , wdr:sense-bowdlerize-verb .

wdr:sense-bowdlerize-name a drift:Sense ;
    drift:gloss "after Thomas Bowdler (1754-1825), editor of the 1818 'Family Shakespeare' from which matter judged unfit was removed"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1818"^^xsd:gYear .

wdr:sense-bowdlerize-verb a drift:Sense ;
    drift:gloss "to remove from a text material considered improper or offensive, often to its detriment; to expurgate"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1836"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1836"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-bowdlerize-shakespeare a drift:TriggerEvent ;
    rdfs:label "Thomas Bowdler's 'Family Shakespeare' (1818)"@en ;
    dct:description "In 1818 Thomas Bowdler published an expurgated 'Family Shakespeare' with passages deemed indecent removed. His name became a verb (attested 1836) for the practice of purging text of supposedly offensive content."@en ;
    drift:eventDate "1818"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-bowdlerize-shakespeare a drift:DriftEvent ;
    drift:affectsWord wdr:word-bowdlerize ;
    drift:senseFrom wdr:sense-bowdlerize-name ;
    drift:senseTo wdr:sense-bowdlerize-verb ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1818"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1840"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-bowdlerize-etym , wdr:src-bowdlerize-wiki .

# --- causal hypothesis ---
wdr:hyp-bowdlerize-shakespeare a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-bowdlerize-shakespeare ;
    drift:proposedTrigger wdr:trigger-bowdlerize-shakespeare ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-bowdlerize-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-bowdlerize-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- bowdlerize"@en ;
    drift:sourceURL "https://www.etymonline.com/word/bowdlerize"^^xsd:anyURI .

wdr:src-bowdlerize-wiki a drift:Source ;
    dct:title "Thomas Bowdler -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Thomas_Bowdler"^^xsd:anyURI .
