@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# =============================================================
# "Wolke" (de) -- cross-lingual pair with "cloud" (cloud.ttl)
# Metaphorization:
#   "a visible mass of water vapour" (Wetter) ->
#   "Cloud-Computing: vernetzte Rechenressourcen ueber das
#    Internet". The German "die Wolke / die Cloud" calque
#    followed the English term after the AWS launch (2006).
# =============================================================

wdr:word-wolke a drift:Word ;
    drift:writtenForm "Wolke"@de ;
    drift:language "de" ;
    rdfs:label "Wolke"@de ;
    ontolex:sense wdr:sense-wolke-weather , wdr:sense-wolke-computing ;
    drift:crossLingualOf wdr:word-cloud .

wdr:sense-wolke-weather a drift:Sense ;
    drift:gloss "a visible mass of condensed water vapour floating in the atmosphere"@en ;
    drift:gloss "sichtbare Masse aus kondensiertem Wasserdampf in der Atmosphaere"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1000"^^xsd:gYear .

wdr:sense-wolke-computing a drift:Sense ;
    drift:gloss "cloud computing: remote networked computing resources accessed via the internet"@en ;
    drift:gloss "Cloud-Computing: vernetzte Rechenressourcen (Server, Speicher, Software) ueber das Internet"@de ;
    drift:connotation drift:Positive ;
    drift:firstAttested "2007"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "2007"^^xsd:gYear ]
    ] .

# --- trigger events ---
wdr:trigger-aws-launch a drift:TriggerEvent ;
    rdfs:label "Amazon Web Services launch and popularisation of cloud computing (2006)"@en ;
    dct:description "Amazon's launch of AWS EC2 and S3 in 2006 and the global spread of 'cloud computing' anchored the metaphor; German adopted 'die Cloud / die Wolke' for networked storage and compute shortly afterwards."@en ;
    drift:eventDate "2006"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

# --- drift event: metaphorization (causation lives in the hypothesis below) ---
wdr:drift-wolke-cloud a drift:DriftEvent ;
    drift:affectsWord wdr:word-wolke ;
    drift:senseFrom wdr:sense-wolke-weather ;
    drift:senseTo wdr:sense-wolke-computing ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "2007"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "2012"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-wolke-dwds , wdr:src-wolke-wikipedia .

# --- causal hypothesis (ADR 0004) ---
# DWDS is a lexicographic source -> LexicographicNote; Wikipedia is general -> Speculative.
wdr:hyp-wolke-aws a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-wolke-cloud ;
    drift:proposedTrigger wdr:trigger-aws-launch ;
    drift:evidenceType drift:LexicographicNote , drift:Speculative ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-wolke-dwds , wdr:src-wolke-wikipedia ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-wolke-dwds a drift:Source ;
    dct:title "DWDS - Cloud"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Cloud"^^xsd:anyURI .

wdr:src-wolke-wikipedia a drift:Source ;
    dct:title "Cloud Computing - Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Cloud_Computing"^^xsd:anyURI .
