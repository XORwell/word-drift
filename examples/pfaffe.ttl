@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Pfaffe" (de)
# Pejoration: OHG phaffo "secular cleric" (neutral) -> MHG
# neutral occupational title for clergy -> post-Reformation
# derogatory label. The Reformation is the identifiable trigger.
# =============================================================

wdr:word-pfaffe a drift:Word ;
    drift:writtenForm "Pfaffe"@de ;
    drift:language "de" ;
    rdfs:label "Pfaffe"@de ;
    ontolex:sense wdr:sense-pfaffe-neutral , wdr:sense-pfaffe-derogatory .

wdr:sense-pfaffe-neutral a drift:Sense ;
    drift:gloss "a secular cleric; a (Roman Catholic) priest; neutral occupational term for a member of the clergy"@en ;
    drift:gloss "Weltgeistlicher, Kleriker; neutrale Berufsbezeichnung"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1000"^^xsd:gYear .

wdr:sense-pfaffe-derogatory a drift:Sense ;
    drift:gloss "a priest or clergyman (contemptuous); a disparaging designation for a cleric seen as worldly, corrupt, or meddlesome"@en ;
    drift:gloss "Kleriker (veraechlich, abwertend); Schimpfwort fuer Geistliche"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1520"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1520"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-pfaffe-reformation a drift:TriggerEvent ;
    rdfs:label "Protestant Reformation in the German lands"@en ;
    dct:description "The Reformation beginning 1517 sharply increased anticlericalism. Criticism of worldly, pluralist, and corrupt clergy made 'Pfaffe' a vehicle for contempt, fixing the pejorative sense."@en ;
    drift:eventDate "1517"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural ;
    owl:sameAs wd:Q12562 .

# --- drift event ---
wdr:drift-pfaffe-reformation a drift:DriftEvent ;
    drift:affectsWord wdr:word-pfaffe ;
    drift:senseFrom wdr:sense-pfaffe-neutral ;
    drift:senseTo wdr:sense-pfaffe-derogatory ;
    drift:driftType drift:Pejoration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1500"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1600"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-pfaffe-dwds , wdr:src-pfaffe-wiki .

# --- causal hypothesis ---
wdr:hyp-pfaffe-reformation a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-pfaffe-reformation ;
    drift:proposedTrigger wdr:trigger-pfaffe-reformation ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-pfaffe-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-pfaffe-dwds a drift:Source ;
    dct:title "DWDS -- Pfaffe"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Pfaffe"^^xsd:anyURI .

wdr:src-pfaffe-wiki a drift:Source ;
    dct:title "Pfaffe -- Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Pfaffe"^^xsd:anyURI .
