@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "tank" (en)
# Narrowing via metonymy: a generic word for a container of
# liquid acquires a specific military sense (armoured fighting
# vehicle) from the 1916 British secrecy codename. The Somme
# debut in September 1916 is the datable trigger.
# =============================================================

wdr:word-tank a drift:Word ;
    drift:writtenForm "tank"@en ;
    drift:language "en" ;
    rdfs:label "tank"@en ;
    ontolex:sense wdr:sense-tank-container , wdr:sense-tank-vehicle .

wdr:sense-tank-container a drift:Sense ;
    drift:gloss "a large receptacle or storage container for liquid or gas"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1610"^^xsd:gYear .

wdr:sense-tank-vehicle a drift:Sense ;
    drift:gloss "an armoured, tracked military fighting vehicle"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1916"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1916"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-tank-somme a drift:TriggerEvent ;
    rdfs:label "British 'tank' codename and combat debut on the Somme"@en ;
    dct:description "In 1915-1916 the British used 'tank' as a secrecy codename, disguising the new armoured vehicle as a water carrier. Its combat debut at the Somme in September 1916 fixed the military sense in public language."@en ;
    drift:eventDate "1916"^^xsd:gYear ;
    drift:triggerCategory drift:Technology ;
    owl:sameAs wd:Q1284532 .

# --- drift event ---
wdr:drift-tank-somme a drift:DriftEvent ;
    drift:affectsWord wdr:word-tank ;
    drift:senseFrom wdr:sense-tank-container ;
    drift:senseTo wdr:sense-tank-vehicle ;
    drift:driftType drift:Narrowing ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1915"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1918"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-tank-etym , wdr:src-tank-wiki .

# --- causal hypothesis ---
wdr:hyp-tank-somme a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-tank-somme ;
    drift:proposedTrigger wdr:trigger-tank-somme ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-tank-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-tank-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- tank"@en ;
    drift:sourceURL "https://www.etymonline.com/word/tank"^^xsd:anyURI .

wdr:src-tank-wiki a drift:Source ;
    dct:title "Tank -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Tank"^^xsd:anyURI .
