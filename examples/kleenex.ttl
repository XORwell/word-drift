@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "kleenex" (en)
# Broadening: Kimberly-Clark's 1924 brand of facial tissue
# -> generic term (esp. American English) for any paper tissue.
# The 1924 Kleenex brand launch is the commercial trigger.
# =============================================================

wdr:word-kleenex a drift:Word ;
    drift:writtenForm "kleenex"@en ;
    drift:language "en" ;
    rdfs:label "kleenex"@en ;
    ontolex:sense wdr:sense-kleenex-brand , wdr:sense-kleenex-generic .

wdr:sense-kleenex-brand a drift:Sense ;
    drift:gloss "Kimberly-Clark's brand of disposable facial tissue"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1924"^^xsd:gYear .

wdr:sense-kleenex-generic a drift:Sense ;
    drift:gloss "any disposable paper tissue or handkerchief"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1930"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1930"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-kleenex-kc a drift:TriggerEvent ;
    rdfs:label "Kimberly-Clark launches Kleenex"@en ;
    dct:description "Kleenex disposable facial tissue was introduced in 1924 (Cellucotton Products Co.; the Kleenex trademark is now held by Kimberly-Clark). The brand became so dominant that the name began to be used for any paper tissue, a usage the company has since fought to limit."@en ;
    drift:eventDate "1924"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-kleenex-kc a drift:DriftEvent ;
    drift:affectsWord wdr:word-kleenex ;
    drift:senseFrom wdr:sense-kleenex-brand ;
    drift:senseTo wdr:sense-kleenex-generic ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1924"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1940"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-kleenex-wikt , wdr:src-kleenex-wiki .

# --- causal hypothesis ---
wdr:hyp-kleenex-kc a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-kleenex-kc ;
    drift:proposedTrigger wdr:trigger-kleenex-kc ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-kleenex-wikt ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-kleenex-wikt a drift:Source ;
    dct:title "Kleenex -- Wiktionary"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/Kleenex"^^xsd:anyURI .

wdr:src-kleenex-wiki a drift:Source ;
    dct:title "Kleenex -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Kleenex"^^xsd:anyURI .
