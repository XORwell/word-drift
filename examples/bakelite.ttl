@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "bakelite" (en)
# Broadening: Leo Baekeland's 1909 brand name for his phenolic
# resin -> loose generic term for early hard plastics. The 1909
# brand launch is the commercial trigger.
# =============================================================

wdr:word-bakelite a drift:Word ;
    drift:writtenForm "bakelite"@en ;
    drift:language "en" ;
    rdfs:label "bakelite"@en ;
    ontolex:sense wdr:sense-bakelite-brand , wdr:sense-bakelite-generic .

wdr:sense-bakelite-brand a drift:Sense ;
    drift:gloss "Leo Baekeland's brand name for his phenol-formaldehyde synthetic resin"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1909"^^xsd:gYear .

wdr:sense-bakelite-generic a drift:Sense ;
    drift:gloss "loosely, any hard moulded phenolic plastic of the early-twentieth-century type"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1920"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1920"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-bakelite-baekeland a drift:TriggerEvent ;
    rdfs:label "Baekeland markets Bakelite resin"@en ;
    dct:description "In 1909 Leo Baekeland announced and branded Bakelite, the first fully synthetic plastic. The brand became widely used as a loose generic label for hard moulded phenolic plastics of the era."@en ;
    drift:eventDate "1909"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-bakelite-baekeland a drift:DriftEvent ;
    drift:affectsWord wdr:word-bakelite ;
    drift:senseFrom wdr:sense-bakelite-brand ;
    drift:senseTo wdr:sense-bakelite-generic ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1909"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1930"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-bakelite-wikt , wdr:src-bakelite-wiki .

# --- causal hypothesis ---
wdr:hyp-bakelite-baekeland a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-bakelite-baekeland ;
    drift:proposedTrigger wdr:trigger-bakelite-baekeland ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.75 ;
    drift:hasSource wdr:src-bakelite-wikt ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-bakelite-wikt a drift:Source ;
    dct:title "Bakelite -- Wiktionary"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/Bakelite"^^xsd:anyURI .

wdr:src-bakelite-wiki a drift:Source ;
    dct:title "Bakelite -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Bakelite"^^xsd:anyURI .
