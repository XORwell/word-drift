@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# =============================================================
# "Impfgegner" (de)
# Pejoration + frequency surge: a descriptive term for "opponent
# of vaccination" gains a strongly politicised, derogatory charge
# during the COVID-19 vaccination debate (2020-2021), with a
# reproducible DWDS frequency spike.
# =============================================================

wdr:word-impfgegner a drift:Word ;
    drift:writtenForm "Impfgegner"@de ;
    drift:language "de" ;
    rdfs:label "Impfgegner"@de ;
    ontolex:sense wdr:sense-impfgegner-descriptive , wdr:sense-impfgegner-polarised .

wdr:sense-impfgegner-descriptive a drift:Sense ;
    drift:gloss "a person who rejects vaccination, especially on principle (descriptive)"@en ;
    drift:gloss "Person, die Impfungen grundsaetzlich ablehnt (beschreibend)"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1890"^^xsd:gYear .

wdr:sense-impfgegner-polarised a drift:Sense ;
    drift:gloss "a strongly politicised, frequently derogatory label for opponents of COVID-19 vaccination, associated with conspiracy and protest milieus"@en ;
    drift:gloss "stark politisiertes, oft abwertendes Etikett fuer Gegner der COVID-19-Impfung, dem Verschwoerungs- und Protestmilieu zugeordnet"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "2020"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "2020"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-impfgegner-covid a drift:TriggerEvent ;
    rdfs:label "COVID-19 vaccination debate (2020-2021)"@en , "COVID-19-Impfdebatte"@de ;
    dct:description "The 2020-2021 public debate over COVID-19 vaccination sharply politicised 'Impfgegner', loading the descriptive term with a derogatory, conflict-laden charge; DWDS shows a steep frequency rise."@en ;
    drift:eventDate "2020"^^xsd:gYear ;
    drift:triggerCategory drift:Pandemic ;
    owl:sameAs wd:Q81068910 .

# --- drift event (causation in the hypothesis below) ---
wdr:drift-impfgegner-2020 a drift:DriftEvent ;
    drift:affectsWord wdr:word-impfgegner ;
    drift:senseFrom wdr:sense-impfgegner-descriptive ;
    drift:senseTo wdr:sense-impfgegner-polarised ;
    drift:driftType drift:Pejoration ;
    drift:driftYear "2020"^^xsd:gYear ;
    drift:hasSource wdr:src-impfgegner-dwds , wdr:corpus-dwds-impfgegner .

# --- causal hypothesis (ADR 0004) ---
# The DWDS Wortverlaufskurve shows a reproducible 2020-2021 spike aligned
# with the vaccination debate; the DWDS entry corroborates the usage.
wdr:hyp-impfgegner-covid a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-impfgegner-2020 ;
    drift:proposedTrigger wdr:trigger-impfgegner-covid ;
    drift:evidenceType drift:FrequencyCorrelation , drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-impfgegner-dwds , wdr:corpus-dwds-impfgegner ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- frequency observations (timeline curve) ---
wdr:freq-impfgegner-2018 a drift:FrequencyObservation ;
    drift:ofWord wdr:word-impfgegner ; drift:observedYear "2018"^^xsd:gYear ;
    drift:relativeFrequency 0.7 ; drift:fromCorpus wdr:corpus-dwds-impfgegner .
wdr:freq-impfgegner-2020 a drift:FrequencyObservation ;
    drift:ofWord wdr:word-impfgegner ; drift:observedYear "2020"^^xsd:gYear ;
    drift:relativeFrequency 2.6 ; drift:fromCorpus wdr:corpus-dwds-impfgegner .
wdr:freq-impfgegner-2021 a drift:FrequencyObservation ;
    drift:ofWord wdr:word-impfgegner ; drift:observedYear "2021"^^xsd:gYear ;
    drift:relativeFrequency 5.4 ; drift:fromCorpus wdr:corpus-dwds-impfgegner .

# --- sources ---
wdr:corpus-dwds-impfgegner a drift:Corpus ;
    dct:title "DWDS Wortverlaufskurve - Impfgegner"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Impfgegner"^^xsd:anyURI .

wdr:src-impfgegner-dwds a drift:Source ;
    dct:title "DWDS - Impfgegner"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Impfgegner"^^xsd:anyURI .
