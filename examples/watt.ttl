@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "watt" (en)
# Metonymization: the surname Watt (James Watt, whose improved
# steam engine ~1776 powered the Industrial Revolution) becomes
# the common name of the SI unit of power. His steam engine work
# is the identifiable trigger.
# =============================================================

wdr:word-watt a drift:Word ;
    drift:writtenForm "watt"@en ;
    drift:language "en" ;
    rdfs:label "watt"@en ;
    ontolex:sense wdr:sense-watt-name , wdr:sense-watt-unit .

wdr:sense-watt-name a drift:Sense ;
    drift:gloss "the surname of the Scottish engineer James Watt"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1736"^^xsd:gYear .

wdr:sense-watt-unit a drift:Sense ;
    drift:gloss "the SI unit of power; an everyday word for the power rating of a device such as a bulb or appliance"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1882"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1882"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-watt-engine a drift:TriggerEvent ;
    rdfs:label "Watt's improved steam engine"@en ;
    dct:description "From 1776 James Watt's separate-condenser steam engine entered commercial use, transforming industry. His name was adopted for the unit of power by the British Association in 1882."@en ;
    drift:eventDate "1776"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

# --- drift event ---
wdr:drift-watt-engine a drift:DriftEvent ;
    drift:affectsWord wdr:word-watt ;
    drift:senseFrom wdr:sense-watt-name ;
    drift:senseTo wdr:sense-watt-unit ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1776"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1882"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-watt-etym , wdr:src-watt-wiki .

# --- causal hypothesis ---
wdr:hyp-watt-engine a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-watt-engine ;
    drift:proposedTrigger wdr:trigger-watt-engine ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-watt-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-watt-etym a drift:Source ;
    dct:title "watt -- Online Etymology Dictionary"@en ;
    drift:sourceURL "https://www.etymonline.com/word/watt"^^xsd:anyURI .

wdr:src-watt-wiki a drift:Source ;
    dct:title "James Watt -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/James_Watt"^^xsd:anyURI .
