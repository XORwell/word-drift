@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Heimat" (de)
# Broadening/Metaphorization: a plain legal-territorial term for
# one's place of residence or right of domicile becomes, through
# Romanticism and 19th c. nationalism, an emotionally charged
# concept of belonging and origin. The Romantic movement around
# 1800 is the identifiable trigger.
# =============================================================

wdr:word-heimat a drift:Word ;
    drift:writtenForm "Heimat"@de ;
    drift:language "de" ;
    rdfs:label "Heimat"@de ;
    ontolex:sense wdr:sense-heimat-legal , wdr:sense-heimat-sentimental .

wdr:sense-heimat-legal a drift:Sense ;
    drift:gloss "place of residence or domicile; the locality where one has settlement rights; a neutral legal-territorial term"@en ;
    drift:gloss "Wohnort, Heimatort; Ort des Buergerrechts oder Wohnsitzes; neutraler rechtlich-territorialer Begriff"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1500"^^xsd:gYear .

wdr:sense-heimat-sentimental a drift:Sense ;
    drift:gloss "the place of one's roots and emotional belonging; an idealised concept of origin, landscape, and identity"@en ;
    drift:gloss "Ort der Herkunft und des Zugehoerigkeitsgefuehls; idealisierter Begriff von Ursprung, Landschaft und Identitaet"@de ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1800"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1800"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-heimat-romantik a drift:TriggerEvent ;
    rdfs:label "German Romanticism and 19th c. nationalism"@en ;
    dct:description "From around 1800 the Romantic movement and the subsequent national awakening invested 'Heimat' with sentimental and ideological meaning, turning a legal-territorial term into a concept of emotional belonging and origin."@en ;
    drift:eventDate "1800"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-heimat-romantik a drift:DriftEvent ;
    drift:affectsWord wdr:word-heimat ;
    drift:senseFrom wdr:sense-heimat-legal ;
    drift:senseTo wdr:sense-heimat-sentimental ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1800"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1900"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-heimat-dwds , wdr:src-heimat-wiki .

# --- causal hypothesis ---
wdr:hyp-heimat-romantik a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-heimat-romantik ;
    drift:proposedTrigger wdr:trigger-heimat-romantik ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.75 ;
    drift:hasSource wdr:src-heimat-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-heimat-dwds a drift:Source ;
    dct:title "DWDS -- Heimat"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Heimat"^^xsd:anyURI .

wdr:src-heimat-wiki a drift:Source ;
    dct:title "Heimat -- Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Heimat"^^xsd:anyURI .
