@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "bourbon" (en)
# Metonymization: Bourbon County, Kentucky, where the American
# corn whiskey was first made, gave its name to the spirit.
# The county (itself named for the French royal house) is the
# trigger.
# =============================================================

wdr:word-bourbon a drift:Word ;
    drift:writtenForm "bourbon"@en ;
    drift:language "en" ;
    rdfs:label "bourbon"@en ;
    ontolex:sense wdr:sense-bourbon-county , wdr:sense-bourbon-whiskey .

wdr:sense-bourbon-county a drift:Sense ;
    drift:gloss "Bourbon County, Kentucky, organized 1785 and named for the French royal house of Bourbon"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1785"^^xsd:gYear .

wdr:sense-bourbon-whiskey a drift:Sense ;
    drift:gloss "a type of American corn whiskey originally made in Bourbon County, Kentucky"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1840"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1840"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-bourbon-county a drift:TriggerEvent ;
    rdfs:label "Bourbon County, Kentucky"@en ;
    dct:description "American corn whiskey was first made in Bourbon County, Kentucky (organized 1785); the county name attached to the spirit, attested by 1840."@en ;
    drift:eventDate "1840"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial ;
    owl:sameAs wd:Q486105 .

# --- drift event ---
wdr:drift-bourbon-county a drift:DriftEvent ;
    drift:affectsWord wdr:word-bourbon ;
    drift:senseFrom wdr:sense-bourbon-county ;
    drift:senseTo wdr:sense-bourbon-whiskey ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1789"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1840"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-bourbon-etym , wdr:src-bourbon-wikt .

# --- causal hypothesis ---
wdr:hyp-bourbon-county a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-bourbon-county ;
    drift:proposedTrigger wdr:trigger-bourbon-county ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-bourbon-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-bourbon-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- bourbon"@en ;
    drift:sourceURL "https://www.etymonline.com/word/bourbon"^^xsd:anyURI .

wdr:src-bourbon-wikt a drift:Source ;
    dct:title "Wiktionary -- bourbon"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/bourbon"^^xsd:anyURI .
