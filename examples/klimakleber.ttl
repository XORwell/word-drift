@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# =============================================================
# "Klimakleber" (de)
# Neologism 2022: coined (by Bild) as a pejorative label for
# Letzte Generation activists who glue themselves to roads.
# The word started as a derogatory media term; the activists
# partially reappropriated it. Entered Duden 2024.
# The drift is from coinage-as-pejorative toward contested /
# partially neutralised self-label (Reappropriation in progress).
# =============================================================

wdr:word-klimakleber a drift:Word ;
    drift:writtenForm "Klimakleber"@de ;
    drift:language "de" ;
    rdfs:label "Klimakleber"@de ;
    ontolex:sense wdr:sense-klimakleber-pejorative , wdr:sense-klimakleber-neutral .

wdr:sense-klimakleber-pejorative a drift:Sense ;
    drift:gloss "a climate activist (Letzte Generation) who glues themselves to roads to block traffic; mocking derogatory label used by opponents"@en ;
    drift:gloss "Aktivist der Letzten Generation der sich auf Strassen klebt; veraechlicher Begriff der Gegner"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "2022"^^xsd:gYear .

wdr:sense-klimakleber-neutral a drift:Sense ;
    drift:gloss "a road-gluing climate activist (Letzte Generation); increasingly neutral self-designation and dictionary entry"@en ;
    drift:gloss "Strassenklebe-Aktivist; zunehmend neutrales Selbstbezeichnung"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "2023"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "2023"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-klimakleber-lg a drift:TriggerEvent ;
    rdfs:label "Letzte Generation street-blockade campaign from January 2022"@en ;
    dct:description "From 24 January 2022 the Letzte Generation began gluing themselves to streets in Berlin. The Bild newspaper coined 'Klimakleber' as a pejorative. By 2023 activists began using the term themselves, initiating partial reappropriation."@en ;
    drift:eventDate "2022"^^xsd:gYear ;
    drift:triggerCategory drift:Political ;
    owl:sameAs wd:Q110819215 .

# --- drift event ---
wdr:drift-klimakleber-2022 a drift:DriftEvent ;
    drift:affectsWord wdr:word-klimakleber ;
    drift:senseFrom wdr:sense-klimakleber-pejorative ;
    drift:senseTo wdr:sense-klimakleber-neutral ;
    drift:driftType drift:Reappropriation ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "2022"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "2024"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-klimakleber-wiktionary , wdr:src-klimakleber-tagesspiegel .

# --- causal hypothesis ---
wdr:hyp-klimakleber-lg a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-klimakleber-2022 ;
    drift:proposedTrigger wdr:trigger-klimakleber-lg ;
    drift:evidenceType drift:FrequencyCorrelation , drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-klimakleber-wiktionary ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-klimakleber-wiktionary a drift:Source ;
    dct:title "Wiktionary -- Klimakleber"@de ;
    drift:sourceURL "https://de.wiktionary.org/wiki/Klimakleber"^^xsd:anyURI .

wdr:src-klimakleber-tagesspiegel a drift:Source ;
    dct:title "Tagesspiegel -- Zwei Jahre Klimakleber: Ist die Letzte Generation am Ende?"@de ;
    drift:sourceURL "https://www.tagesspiegel.de/berlin/zwei-jahre-klimakleber-ist-die-letzte-generation-am-ende-11094580.html"^^xsd:anyURI .
