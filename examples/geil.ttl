@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# =============================================================
# WORKED EXAMPLE - "geil" (de)
# Amelioration:
#   Old High German: "wanton, lascivious, lewd" (negative)
#   1970s West German youth slang: "great, cool, awesome" (positive)
#   The shift is a clear amelioration driven by youth culture
#   and 1980s advertising (Veltins "Geil ist geil" campaign).
# =============================================================

wdr:word-geil a drift:Word ;
    drift:writtenForm "geil"@de ;
    drift:language "de" ;
    rdfs:label "geil"@de ;
    ontolex:sense wdr:sense-geil-lewd , wdr:sense-geil-great .

wdr:sense-geil-lewd a drift:Sense ;
    drift:gloss "lascivious, lewd, lustful; sexually aroused"@en ;
    drift:gloss "geil im Sinne von wolluestig, lasziv"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "0800"^^xsd:gYear .

wdr:sense-geil-great a drift:Sense ;
    drift:gloss "great, awesome, fantastic; colloquial expression of strong approval"@en ;
    drift:gloss "toll, super, klasse (Jugendsprache und Umgangssprache)"@de ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1970"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1970"^^xsd:gYear ]
    ] .

# --- trigger events ---
wdr:trigger-geil-youthslang a drift:TriggerEvent ;
    rdfs:label "West German youth slang of the 1970s-80s"@en ;
    dct:description "West German youth culture of the 1970s repurposed 'geil' as an intensifier of approval, analogous to English 'wicked' or 'sick'. The Veltins beer slogan 'Geil ist geil' (1990s) anchored the shift in mainstream usage."@en ;
    drift:eventDate "1975"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event: amelioration (causation lives in the hypothesis below) ---
wdr:drift-geil-1970s a drift:DriftEvent ;
    drift:affectsWord wdr:word-geil ;
    drift:senseFrom wdr:sense-geil-lewd ;
    drift:senseTo wdr:sense-geil-great ;
    drift:driftType drift:Amelioration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1970"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1990"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-geil-dwds , wdr:src-geil-duden .

# --- causal hypothesis (ADR 0004) ---
# DWDS and Duden are dictionary/lexicographic sources -> LexicographicNote.
wdr:hyp-geil-youthslang a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-geil-1970s ;
    drift:proposedTrigger wdr:trigger-geil-youthslang ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-geil-dwds , wdr:src-geil-duden ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-geil-dwds a drift:Source ;
    dct:title "DWDS Wortgeschichte - geil"@de ;
    drift:sourceURL "https://www.dwds.de/wb/geil"^^xsd:anyURI .

wdr:src-geil-duden a drift:Source ;
    dct:title "Duden - geil"@de ;
    drift:sourceURL "https://www.duden.de/rechtschreibung/geil"^^xsd:anyURI .
