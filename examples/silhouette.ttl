@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Silhouette" (en)
# Metonymization: eponym from Etienne de Silhouette, French
# controller-general of finances in 1759, whose name became
# attached to cheap shadow-outline portraits and then to any
# dark outline shape. The minister is the identifiable origin.
# =============================================================

wdr:word-silhouette a drift:Word ;
    drift:writtenForm "silhouette"@en ;
    drift:language "en" ;
    rdfs:label "silhouette"@en ;
    ontolex:sense wdr:sense-silhouette-eponym , wdr:sense-silhouette-outline .

wdr:sense-silhouette-eponym a drift:Sense ;
    drift:gloss "the surname of Etienne de Silhouette, French controller-general of finances in 1759, associated with cheap, austere economy"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1759"^^xsd:gYear .

wdr:sense-silhouette-outline a drift:Sense ;
    drift:gloss "a dark profile portrait or outline shape filled in with a solid colour; the outline of an object seen against lighter background"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1798"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1798"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-silhouette-minister a drift:TriggerEvent ;
    rdfs:label "Tenure of Etienne de Silhouette as controller-general of finances"@en ;
    dct:description "Etienne de Silhouette served briefly as French controller-general of finances in 1759. His name became a byword for cheapness and austerity, and was attached to the inexpensive shadow-outline portraits then in fashion, from which the general sense of an outline shape developed."@en ;
    drift:eventDate "1759"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-silhouette-minister a drift:DriftEvent ;
    drift:affectsWord wdr:word-silhouette ;
    drift:senseFrom wdr:sense-silhouette-eponym ;
    drift:senseTo wdr:sense-silhouette-outline ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1759"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1800"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-silhouette-etym , wdr:src-silhouette-wiki .

# --- causal hypothesis ---
wdr:hyp-silhouette-minister a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-silhouette-minister ;
    drift:proposedTrigger wdr:trigger-silhouette-minister ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-silhouette-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-silhouette-etym a drift:Source ;
    dct:title "etymonline -- silhouette"@en ;
    drift:sourceURL "https://www.etymonline.com/word/silhouette"^^xsd:anyURI .

wdr:src-silhouette-wiki a drift:Source ;
    dct:title "Etienne de Silhouette -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Etienne_de_Silhouette"^^xsd:anyURI .
