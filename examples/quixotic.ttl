@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "quixotic" (en)
# Metaphorization: eponym from Don Quixote, hero of Cervantes'
# novel (Part 1 published 1605). The character's idealistic,
# impractical chivalry yielded an adjective for unrealistically
# romantic schemes. The novel is the identifiable origin.
# =============================================================

wdr:word-quixotic a drift:Word ;
    drift:writtenForm "quixotic"@en ;
    drift:language "en" ;
    rdfs:label "quixotic"@en ;
    ontolex:sense wdr:sense-quixotic-eponym , wdr:sense-quixotic-idealistic .

wdr:sense-quixotic-eponym a drift:Sense ;
    drift:gloss "of or relating to Don Quixote, the deluded knight-errant of Cervantes' novel"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1605"^^xsd:gYear .

wdr:sense-quixotic-idealistic a drift:Sense ;
    drift:gloss "extravagantly idealistic and unrealistic; pursuing lofty but impractical goals"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1791"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1791"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-quixotic-cervantes a drift:TriggerEvent ;
    rdfs:label "Publication of Cervantes' Don Quixote"@en ;
    dct:description "The first part of Miguel de Cervantes' novel Don Quixote was published in 1605. The hero's idealistic but deluded chivalry made his name a byword for romantic impracticality, yielding the adjective 'quixotic' through metaphor."@en ;
    drift:eventDate "1605"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-quixotic-cervantes a drift:DriftEvent ;
    drift:affectsWord wdr:word-quixotic ;
    drift:senseFrom wdr:sense-quixotic-eponym ;
    drift:senseTo wdr:sense-quixotic-idealistic ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1605"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1800"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-quixotic-etym , wdr:src-quixotic-wiki .

# --- causal hypothesis ---
wdr:hyp-quixotic-cervantes a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-quixotic-cervantes ;
    drift:proposedTrigger wdr:trigger-quixotic-cervantes ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-quixotic-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-quixotic-etym a drift:Source ;
    dct:title "etymonline -- quixotic"@en ;
    drift:sourceURL "https://www.etymonline.com/word/quixotic"^^xsd:anyURI .

wdr:src-quixotic-wiki a drift:Source ;
    dct:title "Don Quixote -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Don_Quixote"^^xsd:anyURI .
