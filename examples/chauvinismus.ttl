@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Chauvinismus" (de)
# Pejoration: from the (semi-legendary) soldier Nicolas Chauvin,
# emblem of naive devotion to Napoleon, popularized by the
# Cogniard brothers' 1831 play "La cocarde tricolore" -> term of
# contempt for aggressive, blind nationalism. The stage
# popularization is the identifiable trigger.
# =============================================================

wdr:word-chauvinismus a drift:Word ;
    drift:writtenForm "Chauvinismus"@de ;
    drift:language "de" ;
    rdfs:label "Chauvinismus"@de ;
    ontolex:sense wdr:sense-chauvinismus-name , wdr:sense-chauvinismus-pejorative .

wdr:sense-chauvinismus-name a drift:Sense ;
    drift:gloss "from Nicolas Chauvin, a soldier of Napoleon I depicted as filled with uncritical devotion to the emperor"@en ;
    drift:gloss "nach Nicolas Chauvin, einem Soldaten Napoleons I., dargestellt als blind kaisertreu"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1831"^^xsd:gYear .

wdr:sense-chauvinismus-pejorative a drift:Sense ;
    drift:gloss "aggressive, exaggerated nationalism or group loyalty; uncritical belief in the superiority of one's own nation or group"@en ;
    drift:gloss "aggressiver, uebersteigerter Nationalismus; unkritischer Glaube an die Ueberlegenheit der eigenen Nation oder Gruppe (abwertend)"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1843"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1843"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-chauvinismus-play a drift:TriggerEvent ;
    rdfs:label "Cogniard brothers' play 'La cocarde tricolore' (1831)"@en ;
    dct:description "The 1831 vaudeville 'La cocarde tricolore' by the Cogniard brothers popularized the figure of Chauvin as the archetype of bellicose, boastful patriotism. From this the French 'chauvinisme' was coined (1843) and Latinized into German as 'Chauvinismus'."@en ;
    drift:eventDate "1831"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-chauvinismus-play a drift:DriftEvent ;
    drift:affectsWord wdr:word-chauvinismus ;
    drift:senseFrom wdr:sense-chauvinismus-name ;
    drift:senseTo wdr:sense-chauvinismus-pejorative ;
    drift:driftType drift:Pejoration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1831"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1870"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-chauvinismus-dwds , wdr:src-chauvinismus-wiki .

# --- causal hypothesis ---
wdr:hyp-chauvinismus-play a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-chauvinismus-play ;
    drift:proposedTrigger wdr:trigger-chauvinismus-play ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-chauvinismus-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-chauvinismus-dwds a drift:Source ;
    dct:title "DWDS -- Chauvinismus"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Chauvinismus"^^xsd:anyURI .

wdr:src-chauvinismus-wiki a drift:Source ;
    dct:title "Chauvinismus -- Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Chauvinismus"^^xsd:anyURI .
