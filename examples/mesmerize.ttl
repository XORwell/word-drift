@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "mesmerize" (en)
# Metaphorization: eponym from Franz Mesmer, whose "animal
# magnetism" therapy was prominent in the 1780s. "Mesmerize"
# first meant to hypnotise, then broadened by metaphor to
# "captivate, fascinate". Mesmer is the identifiable origin.
# =============================================================

wdr:word-mesmerize a drift:Word ;
    drift:writtenForm "mesmerize"@en ;
    drift:language "en" ;
    rdfs:label "mesmerize"@en ;
    ontolex:sense wdr:sense-mesmerize-hypnotise , wdr:sense-mesmerize-captivate .

wdr:sense-mesmerize-hypnotise a drift:Sense ;
    drift:gloss "to subject to Mesmer's animal magnetism; to hypnotise"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1785"^^xsd:gYear .

wdr:sense-mesmerize-captivate a drift:Sense ;
    drift:gloss "to hold someone's attention completely; to captivate or fascinate"@en ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1862"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1862"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-mesmerize-mesmer a drift:TriggerEvent ;
    rdfs:label "Franz Mesmer's animal magnetism in vogue in Paris"@en ;
    dct:description "In the 1780s the physician Franz Mesmer popularised 'animal magnetism' as a healing practice in Paris. The verb 'mesmerize' was formed from his name to mean 'to hypnotise', then broadened by metaphor to 'captivate, fascinate'."@en ;
    drift:eventDate "1784"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-mesmerize-mesmer a drift:DriftEvent ;
    drift:affectsWord wdr:word-mesmerize ;
    drift:senseFrom wdr:sense-mesmerize-hypnotise ;
    drift:senseTo wdr:sense-mesmerize-captivate ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1785"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1870"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-mesmerize-etym , wdr:src-mesmerize-wiki .

# --- causal hypothesis ---
wdr:hyp-mesmerize-mesmer a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-mesmerize-mesmer ;
    drift:proposedTrigger wdr:trigger-mesmerize-mesmer ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-mesmerize-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-mesmerize-etym a drift:Source ;
    dct:title "etymonline -- mesmerize"@en ;
    drift:sourceURL "https://www.etymonline.com/word/mesmerize"^^xsd:anyURI .

wdr:src-mesmerize-wiki a drift:Source ;
    dct:title "Franz Mesmer -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Franz_Mesmer"^^xsd:anyURI .
