@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "guy" (en)
# Broadening: eponym from Guy Fawkes (Gunpowder Plot, 1605).
# His effigy ("a guy") burned on 5 November led to a sense
# "grotesquely dressed person" and finally to the general
# sense "man, fellow". The Plot is the identifiable origin.
# =============================================================

wdr:word-guy a drift:Word ;
    drift:writtenForm "guy"@en ;
    drift:language "en" ;
    rdfs:label "guy"@en ;
    ontolex:sense wdr:sense-guy-effigy , wdr:sense-guy-man .

wdr:sense-guy-effigy a drift:Sense ;
    drift:gloss "an effigy of Guy Fawkes burned on 5 November; by extension a grotesquely or oddly dressed person"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1806"^^xsd:gYear .

wdr:sense-guy-man a drift:Sense ;
    drift:gloss "a man; a fellow; (in plural) people of any gender"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1847"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1847"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-guy-gunpowder a drift:TriggerEvent ;
    rdfs:label "The Gunpowder Plot of Guy Fawkes"@en ;
    dct:description "In 1605 Guy Fawkes was caught guarding explosives beneath the English Parliament in the Gunpowder Plot. The annual burning of his effigy ('a guy') on 5 November fixed his name to a grotesque figure, from which the broadened modern sense 'man, fellow' later developed."@en ;
    drift:eventDate "1605"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

# --- drift event ---
wdr:drift-guy-gunpowder a drift:DriftEvent ;
    drift:affectsWord wdr:word-guy ;
    drift:senseFrom wdr:sense-guy-effigy ;
    drift:senseTo wdr:sense-guy-man ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1806"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1850"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-guy-etym , wdr:src-guy-wiki .

# --- causal hypothesis ---
wdr:hyp-guy-gunpowder a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-guy-gunpowder ;
    drift:proposedTrigger wdr:trigger-guy-gunpowder ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-guy-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-guy-etym a drift:Source ;
    dct:title "etymonline -- guy"@en ;
    drift:sourceURL "https://www.etymonline.com/word/guy"^^xsd:anyURI .

wdr:src-guy-wiki a drift:Source ;
    dct:title "Guy Fawkes -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Guy_Fawkes"^^xsd:anyURI .
