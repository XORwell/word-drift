@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "rugby" (en)
# Metonymization: from Rugby School in Warwickshire, where the
# handling code of football was codified. The school name became
# the name of the sport.
# =============================================================

wdr:word-rugby a drift:Word ;
    drift:writtenForm "rugby"@en ;
    drift:language "en" ;
    rdfs:label "rugby"@en ;
    ontolex:sense wdr:sense-rugby-school , wdr:sense-rugby-sport .

wdr:sense-rugby-school a drift:Sense ;
    drift:gloss "Rugby School, the public school in Warwickshire where the handling game of football developed"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1823"^^xsd:gYear .

wdr:sense-rugby-sport a drift:Sense ;
    drift:gloss "the football code played by handling and carrying an oval ball, with tackling and scrummaging"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1864"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1864"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-rugby-school a drift:TriggerEvent ;
    rdfs:label "Handling code at Rugby School"@en ;
    dct:description "The distinctive handling game of football was associated with Rugby School from the 1820s. As football codes diverged, the school name was adopted for the handling code and its game."@en ;
    drift:eventDate "1823"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-rugby-school a drift:DriftEvent ;
    drift:affectsWord wdr:word-rugby ;
    drift:senseFrom wdr:sense-rugby-school ;
    drift:senseTo wdr:sense-rugby-sport ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1823"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1880"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-rugby-etym , wdr:src-rugby-wikt .

# --- causal hypothesis ---
wdr:hyp-rugby-school a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-rugby-school ;
    drift:proposedTrigger wdr:trigger-rugby-school ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-rugby-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-rugby-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- rugby"@en ;
    drift:sourceURL "https://www.etymonline.com/word/rugby"^^xsd:anyURI .

wdr:src-rugby-wikt a drift:Source ;
    dct:title "Wiktionary -- rugby"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/rugby"^^xsd:anyURI .
