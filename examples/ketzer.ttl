@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Ketzer" (de)
# Broadening: an onomastic group label ("Katharer", the Cathar
# sect, from Greek katharos "pure") generalised into the common
# noun "Ketzer" = any heretic. The Church campaign against the
# Cathars (Albigensian Crusade, from 1209) is the trigger.
# =============================================================

wdr:word-ketzer a drift:Word ;
    drift:writtenForm "Ketzer"@de ;
    drift:language "de" ;
    rdfs:label "Ketzer"@de ;
    ontolex:sense wdr:sense-ketzer-cathar , wdr:sense-ketzer-heretic .

wdr:sense-ketzer-cathar a drift:Sense ;
    drift:gloss "a member of the Cathar (Albigensian) sect; the specific dualist movement of southern France and northern Italy"@en ;
    drift:gloss "Angehoeriger der Katharer; die dualistische Sekte Suedfrankreichs und Oberitaliens"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1200"^^xsd:gYear .

wdr:sense-ketzer-heretic a drift:Sense ;
    drift:gloss "a heretic; any person whose religious teaching is condemned as deviant by the Church"@en ;
    drift:gloss "Haeretiker, Irrglaeubiger; allgemein jeder von der Kirche als abweichend verurteilte Glaeubige"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1250"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1250"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-ketzer-albigensian a drift:TriggerEvent ;
    rdfs:label "Albigensian Crusade against the Cathars"@en ;
    dct:description "Pope Innocent III launched the Albigensian Crusade in 1209 to suppress the Cathar sect. The sustained inquisitorial campaign made the group name (Latin Cathari, German Katzer/Ketzer) the standard word for heretics in general."@en ;
    drift:eventDate "1209"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-ketzer-albigensian a drift:DriftEvent ;
    drift:affectsWord wdr:word-ketzer ;
    drift:senseFrom wdr:sense-ketzer-cathar ;
    drift:senseTo wdr:sense-ketzer-heretic ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1200"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1300"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-ketzer-dwds , wdr:src-ketzer-wikt .

# --- causal hypothesis ---
wdr:hyp-ketzer-albigensian a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-ketzer-albigensian ;
    drift:proposedTrigger wdr:trigger-ketzer-albigensian ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.8 ;
    drift:hasSource wdr:src-ketzer-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-ketzer-dwds a drift:Source ;
    dct:title "DWDS -- Ketzer"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Ketzer"^^xsd:anyURI .

wdr:src-ketzer-wikt a drift:Source ;
    dct:title "Ketzer -- Wiktionary"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/Ketzer"^^xsd:anyURI .
