@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Ohm" (de)
# Metonymization: the surname Ohm (Georg Simon Ohm, who stated
# Ohm's law in 1827) becomes the German name of the SI unit of
# electrical resistance. The publication of the law is the
# identifiable trigger.
# =============================================================

wdr:word-ohm-de a drift:Word ;
    drift:writtenForm "Ohm"@de ;
    drift:language "de" ;
    rdfs:label "Ohm"@de ;
    ontolex:sense wdr:sense-ohm-de-name , wdr:sense-ohm-de-unit .

wdr:sense-ohm-de-name a drift:Sense ;
    drift:gloss "the surname of the German physicist Georg Simon Ohm"@en ;
    drift:gloss "Familienname des deutschen Physikers Georg Simon Ohm"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1789"^^xsd:gYear .

wdr:sense-ohm-de-unit a drift:Sense ;
    drift:gloss "the SI unit of electrical resistance"@en ;
    drift:gloss "die SI-Einheit des elektrischen Widerstands; alltagssprachlich fuer den Widerstand eines Bauteils"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1881"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1881"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-ohm-de-law a drift:TriggerEvent ;
    rdfs:label "Ohm publishes Ohm's law"@en ;
    dct:description "In 1827 Georg Simon Ohm published 'Die galvanische Kette, mathematisch bearbeitet', stating the proportionality of current and voltage. His name became the unit of resistance, developed through the British Association unit work of the 1860s and internationally established in 1881 (per DWDS)."@en ;
    drift:eventDate "1827"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

# --- drift event ---
wdr:drift-ohm-de-law a drift:DriftEvent ;
    drift:affectsWord wdr:word-ohm-de ;
    drift:senseFrom wdr:sense-ohm-de-name ;
    drift:senseTo wdr:sense-ohm-de-unit ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1827"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1881"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-ohm-de-dwds , wdr:src-ohm-de-wiki .

# --- causal hypothesis ---
wdr:hyp-ohm-de-law a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-ohm-de-law ;
    drift:proposedTrigger wdr:trigger-ohm-de-law ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-ohm-de-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-ohm-de-dwds a drift:Source ;
    dct:title "DWDS -- Ohm"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Ohm"^^xsd:anyURI .

wdr:src-ohm-de-wiki a drift:Source ;
    dct:title "Georg Simon Ohm -- Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Georg_Simon_Ohm"^^xsd:anyURI .
