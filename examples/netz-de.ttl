@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# =============================================================
# "Netz" (de) -- cross-lingual pair with "web" (web.ttl)
# Metaphorization:
#   "a mesh for catching fish or game; an interwoven network" ->
#   "the internet / the World Wide Web" (im Netz, das Netz).
#   The German "das Netz" mirrors the English "the web" sense
#   extension after the browser boom of the mid-1990s.
# =============================================================

wdr:word-netz a drift:Word ;
    drift:writtenForm "Netz"@de ;
    drift:language "de" ;
    rdfs:label "Netz"@de ;
    ontolex:sense wdr:sense-netz-mesh , wdr:sense-netz-internet ;
    drift:crossLingualOf wdr:word-web .

wdr:sense-netz-mesh a drift:Sense ;
    drift:gloss "a net or mesh of knotted cord for catching fish or game; any interwoven network"@en ;
    drift:gloss "geknuepftes Maschenwerk zum Fangen von Fischen oder Wild; Geflecht"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "0800"^^xsd:gYear .

wdr:sense-netz-internet a drift:Sense ;
    drift:gloss "the internet / the World Wide Web (das Netz, im Netz)"@en ;
    drift:gloss "das Internet bzw. das World Wide Web (das Netz, im Netz)"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1994"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1994"^^xsd:gYear ]
    ] .

# --- trigger events ---
wdr:trigger-www-mosaic a drift:TriggerEvent ;
    rdfs:label "World Wide Web and Mosaic browser launch"@en ;
    dct:description "The public launch of the WWW and graphical browsers (Mosaic 1993, Netscape 1994) brought the internet to a mass audience; German adopted 'das Netz' for the internet and the web, mirroring the English 'web' metaphor."@en ;
    drift:eventDate "1993"^^xsd:gYear ;
    drift:triggerCategory drift:Technology ;
    owl:sameAs wd:Q381047 .

# --- drift event: metaphorization (causation lives in the hypothesis below) ---
wdr:drift-netz-internet a drift:DriftEvent ;
    drift:affectsWord wdr:word-netz ;
    drift:senseFrom wdr:sense-netz-mesh ;
    drift:senseTo wdr:sense-netz-internet ;
    drift:driftType drift:Metaphorization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1994"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "2000"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-netz-dwds , wdr:src-netz-duden .

# --- causal hypothesis (ADR 0004) ---
# DWDS and Duden are dictionary/lexicographic sources -> LexicographicNote.
wdr:hyp-netz-www a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-netz-internet ;
    drift:proposedTrigger wdr:trigger-www-mosaic ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-netz-dwds , wdr:src-netz-duden ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-netz-dwds a drift:Source ;
    dct:title "DWDS - Netz"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Netz"^^xsd:anyURI .

wdr:src-netz-duden a drift:Source ;
    dct:title "Duden - Netz"@de ;
    drift:sourceURL "https://www.duden.de/rechtschreibung/Netz"^^xsd:anyURI .
