@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "joule" (en)
# Metonymization: the surname Joule (James Prescott Joule,
# 1818-1889, physicist of energy and heat) becomes the common
# name of the unit of energy, coined 1882. His work on the
# mechanical equivalent of heat is the identifiable trigger.
# =============================================================

wdr:word-joule a drift:Word ;
    drift:writtenForm "joule"@en ;
    drift:language "en" ;
    rdfs:label "joule"@en ;
    ontolex:sense wdr:sense-joule-name , wdr:sense-joule-unit .

wdr:sense-joule-name a drift:Sense ;
    drift:gloss "the surname of the British physicist James Prescott Joule"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1818"^^xsd:gYear .

wdr:sense-joule-unit a drift:Sense ;
    drift:gloss "the SI unit of energy, work and heat"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1882"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1882"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-joule-heat a drift:TriggerEvent ;
    rdfs:label "Joule's work on the mechanical equivalent of heat"@en ;
    dct:description "James Prescott Joule established the mechanical equivalent of heat in the 1840s, a foundation of the conservation of energy. His name was coined as the unit of electrical energy in 1882."@en ;
    drift:eventDate "1843"^^xsd:gYear ;
    drift:triggerCategory drift:Technology ;
    owl:sameAs wd:Q8962 .

# --- drift event ---
wdr:drift-joule-heat a drift:DriftEvent ;
    drift:affectsWord wdr:word-joule ;
    drift:senseFrom wdr:sense-joule-name ;
    drift:senseTo wdr:sense-joule-unit ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1843"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1882"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-joule-etym , wdr:src-joule-wiki .

# --- causal hypothesis ---
wdr:hyp-joule-heat a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-joule-heat ;
    drift:proposedTrigger wdr:trigger-joule-heat ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-joule-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-joule-etym a drift:Source ;
    dct:title "joule -- Online Etymology Dictionary"@en ;
    drift:sourceURL "https://www.etymonline.com/word/joule"^^xsd:anyURI .

wdr:src-joule-wiki a drift:Source ;
    dct:title "James Prescott Joule -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/James_Prescott_Joule"^^xsd:anyURI .
