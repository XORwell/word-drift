@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "curie" (en)
# Metonymization: the surname Curie (Pierre Curie, 1859-1906,
# who with Marie discovered radium) becomes the common name of
# a unit of radioactivity, first attested 1910. The Curies'
# radioactivity research is the identifiable trigger.
# =============================================================

wdr:word-curie a drift:Word ;
    drift:writtenForm "curie"@en ;
    drift:language "en" ;
    rdfs:label "curie"@en ;
    ontolex:sense wdr:sense-curie-name , wdr:sense-curie-unit .

wdr:sense-curie-name a drift:Sense ;
    drift:gloss "the surname of the French physicist Pierre Curie, who with his wife Marie discovered radium"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1859"^^xsd:gYear .

wdr:sense-curie-unit a drift:Sense ;
    drift:gloss "a unit of radioactivity, the activity of one gram of radium-226"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1910"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1910"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-curie-radioactivity a drift:TriggerEvent ;
    rdfs:label "The Curies' discovery of radium"@en ;
    dct:description "Pierre and Marie Curie discovered radium and polonium in 1898 and pioneered the study of radioactivity. The unit of radioactivity was named in honour of Pierre Curie, first attested 1910."@en ;
    drift:eventDate "1898"^^xsd:gYear ;
    drift:triggerCategory drift:Technology ;
    owl:sameAs wd:Q37463 .

# --- drift event ---
wdr:drift-curie-radioactivity a drift:DriftEvent ;
    drift:affectsWord wdr:word-curie ;
    drift:senseFrom wdr:sense-curie-name ;
    drift:senseTo wdr:sense-curie-unit ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1898"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1910"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-curie-etym , wdr:src-curie-wiki .

# --- causal hypothesis ---
wdr:hyp-curie-radioactivity a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-curie-radioactivity ;
    drift:proposedTrigger wdr:trigger-curie-radioactivity ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-curie-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-curie-etym a drift:Source ;
    dct:title "curie -- Online Etymology Dictionary"@en ;
    drift:sourceURL "https://www.etymonline.com/word/curie"^^xsd:anyURI .

wdr:src-curie-wiki a drift:Source ;
    dct:title "Pierre Curie -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Pierre_Curie"^^xsd:anyURI .
