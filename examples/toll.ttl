@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "toll" (de)
# Amelioration: OHG/MHG "mad, rabid, reckless" -> 1950s/1960s
# youth slang "great, wonderful, fantastic".
# A clear case of amelioration via youth culture resemanticization.
# =============================================================

wdr:word-toll a drift:Word ;
    drift:writtenForm "toll"@de ;
    drift:language "de" ;
    rdfs:label "toll"@de ;
    ontolex:sense wdr:sense-toll-mad , wdr:sense-toll-great .

wdr:sense-toll-mad a drift:Sense ;
    drift:gloss "mad, reckless, rabid; out of one's mind; wild and uncontrolled"@en ;
    drift:gloss "wahnsinnig, tollwuetig, rasend; voellig unbeherrscht"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "0900"^^xsd:gYear .

wdr:sense-toll-great a drift:Sense ;
    drift:gloss "great, fantastic, wonderful, impressive (colloquial positive)"@en ;
    drift:gloss "grossartig, wunderbar, fantastisch (umgangssprachlich positiv)"@de ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1960"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1960"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-toll-youth a drift:TriggerEvent ;
    rdfs:label "Post-war West German youth culture and rock music"@en ;
    dct:description "The emergence of rock and roll in West Germany in the late 1950s/early 1960s led young people to resemanticize 'toll' (the wild-ones/tolle quality) from a negative to an enthusiastically positive colloquial marker."@en ;
    drift:eventDate "1960"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-toll-1960s a drift:DriftEvent ;
    drift:affectsWord wdr:word-toll ;
    drift:senseFrom wdr:sense-toll-mad ;
    drift:senseTo wdr:sense-toll-great ;
    drift:driftType drift:Amelioration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1955"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1975"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-toll-dwds .

# --- causal hypothesis ---
wdr:hyp-toll-youth a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-toll-1960s ;
    drift:proposedTrigger wdr:trigger-toll-youth ;
    drift:evidenceType drift:Speculative ;
    drift:confidence 0.55 ;
    drift:hasSource wdr:src-toll-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-toll-dwds a drift:Source ;
    dct:title "DWDS -- toll"@de ;
    drift:sourceURL "https://www.dwds.de/wb/toll"^^xsd:anyURI .
