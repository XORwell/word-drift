@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "bikini" (en)
# Metonymization: Bikini Atoll, site of the 1946 US nuclear
# tests. The designer named the swimsuit after the atoll,
# expecting its "explosive" effect; the place name became the
# garment name.
# =============================================================

wdr:word-bikini a drift:Word ;
    drift:writtenForm "bikini"@en ;
    drift:language "en" ;
    rdfs:label "bikini"@en ;
    ontolex:sense wdr:sense-bikini-atoll , wdr:sense-bikini-swimsuit .

wdr:sense-bikini-atoll a drift:Sense ;
    drift:gloss "Bikini Atoll in the Marshall Islands, site of United States nuclear weapon tests from 1946"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1946"^^xsd:gYear .

wdr:sense-bikini-swimsuit a drift:Sense ;
    drift:gloss "a brief two-piece swimsuit for women"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1946"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1946"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-bikini-tests a drift:TriggerEvent ;
    rdfs:label "Operation Crossroads nuclear tests at Bikini Atoll"@en ;
    dct:description "The United States conducted nuclear tests at Bikini Atoll in July 1946. Designer Louis Reard named his new swimsuit 'bikini' the same month, trading on the explosive notoriety of the place name."@en ;
    drift:eventDate "1946"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-bikini-tests a drift:DriftEvent ;
    drift:affectsWord wdr:word-bikini ;
    drift:senseFrom wdr:sense-bikini-atoll ;
    drift:senseTo wdr:sense-bikini-swimsuit ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1946"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1947"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-bikini-etym , wdr:src-bikini-wikt .

# --- causal hypothesis ---
wdr:hyp-bikini-tests a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-bikini-tests ;
    drift:proposedTrigger wdr:trigger-bikini-tests ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-bikini-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-bikini-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- bikini"@en ;
    drift:sourceURL "https://www.etymonline.com/word/bikini"^^xsd:anyURI .

wdr:src-bikini-wikt a drift:Source ;
    dct:title "Wiktionary -- bikini"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/bikini"^^xsd:anyURI .
