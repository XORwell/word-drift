@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "brutal" (en)
# Broadening: "savagely cruel, beastly, like a brute" -> a
# weakened colloquial intensifier "extremely harsh, severe,
# unpleasant" (brutal weather, the brutal truth, a brutal mistake;
# senses attested by Merriam-Webster). A gradual colloquial
# bleaching with no crisp datable event.
# =============================================================

wdr:word-brutal a drift:Word ;
    drift:writtenForm "brutal"@en ;
    drift:language "en" ;
    rdfs:label "brutal"@en ;
    ontolex:sense wdr:sense-brutal-cruel , wdr:sense-brutal-intensifier .

wdr:sense-brutal-cruel a drift:Sense ;
    drift:gloss "savagely cruel, violent, beastly; like a brute, lacking human feeling (etymonline: 'fierce, savage, cruel' 1640s; earlier 'bestial' mid-15c.)"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1450"^^xsd:gYear .

wdr:sense-brutal-intensifier a drift:Sense ;
    drift:gloss "as a colloquial intensifier: extremely harsh, severe, intense or unpleasant (brutal weather, the brutal truth, a brutal mistake)"@en ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1970"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1970"^^xsd:gYear ]
    ] .

# --- trigger event (gradual, undetermined driver) ---
wdr:trigger-brutal-intensifier a drift:TriggerEvent ;
    rdfs:label "Colloquial bleaching of a cruelty word into an intensifier"@en ;
    dct:description "No single datable event. 'Brutal' weakened in 20th-century colloquial speech from literal cruelty to a generic intensifier of harshness or unpleasantness (brutal weather, the brutal truth). The anchor year is a representative attestation of the intensifier use, not a cause."@en ;
    drift:eventDate "1970"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

# --- drift event ---
wdr:drift-brutal-intensifier a drift:DriftEvent ;
    drift:affectsWord wdr:word-brutal ;
    drift:senseFrom wdr:sense-brutal-cruel ;
    drift:senseTo wdr:sense-brutal-intensifier ;
    drift:driftType drift:Broadening ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1900"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "2000"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-brutal-etymonline , wdr:src-brutal-merriam .

# --- causal hypothesis ---
wdr:hyp-brutal-intensifier a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-brutal-intensifier ;
    drift:proposedTrigger wdr:trigger-brutal-intensifier ;
    drift:evidenceType drift:Speculative ;
    drift:confidence 0.55 ;
    drift:hasSource wdr:src-brutal-merriam ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-brutal-etymonline a drift:Source ;
    dct:title "Etymonline - brutal (adj.)"@en ;
    drift:sourceURL "https://www.etymonline.com/word/brutal"^^xsd:anyURI .

wdr:src-brutal-merriam a drift:Source ;
    dct:title "Merriam-Webster - brutal"@en ;
    drift:sourceURL "https://www.merriam-webster.com/dictionary/brutal"^^xsd:anyURI .
