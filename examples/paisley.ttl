@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "paisley" (en)
# Metonymization: Paisley, a town in southwest Scotland that mass
# produced shawls with the curved teardrop pattern, gave its name
# to the cloth and then the pattern itself. The town is the
# trigger.
# =============================================================

wdr:word-paisley a drift:Word ;
    drift:writtenForm "paisley"@en ;
    drift:language "en" ;
    rdfs:label "paisley"@en ;
    ontolex:sense wdr:sense-paisley-town , wdr:sense-paisley-pattern .

wdr:sense-paisley-town a drift:Sense ;
    drift:gloss "of or from Paisley, a town in southwest Scotland where the patterned cloth was made"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1834"^^xsd:gYear .

wdr:sense-paisley-pattern a drift:Sense ;
    drift:gloss "the curved, teardrop-shaped figured pattern (and cloth bearing it) produced at Paisley"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1834"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1834"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-paisley-town a drift:TriggerEvent ;
    rdfs:label "Shawl production at Paisley, Scotland"@en ;
    dct:description "The Scottish town of Paisley mass produced shawls with the curved teardrop motif; the place name became the name of the cloth and then the pattern, attested in English from 1834."@en ;
    drift:eventDate "1834"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial ;
    owl:sameAs wd:Q211870 .

# --- drift event ---
wdr:drift-paisley-town a drift:DriftEvent ;
    drift:affectsWord wdr:word-paisley ;
    drift:senseFrom wdr:sense-paisley-town ;
    drift:senseTo wdr:sense-paisley-pattern ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1834"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1900"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-paisley-etym , wdr:src-paisley-wikt .

# --- causal hypothesis ---
wdr:hyp-paisley-town a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-paisley-town ;
    drift:proposedTrigger wdr:trigger-paisley-town ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-paisley-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-paisley-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- paisley"@en ;
    drift:sourceURL "https://www.etymonline.com/word/paisley"^^xsd:anyURI .

wdr:src-paisley-wikt a drift:Source ;
    dct:title "Wiktionary -- paisley"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/paisley"^^xsd:anyURI .
