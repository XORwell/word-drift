@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Zeppelin" (de)
# Metonymization: proper name of Graf Ferdinand von Zeppelin ->
# generic term for the rigid lighter-than-air airship. The first
# flight of LZ 1 in 1900 fixed the eponymous common-noun sense.
# =============================================================

wdr:word-zeppelin a drift:Word ;
    drift:writtenForm "Zeppelin"@de ;
    drift:language "de" ;
    rdfs:label "Zeppelin"@de ;
    ontolex:sense wdr:sense-zeppelin-name , wdr:sense-zeppelin-airship .

wdr:sense-zeppelin-name a drift:Sense ;
    drift:gloss "the family name of Graf Ferdinand von Zeppelin (1838-1917), German general and airship pioneer"@en ;
    drift:gloss "Familienname des Grafen Ferdinand von Zeppelin, Luftschiffpionier"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1838"^^xsd:gYear .

wdr:sense-zeppelin-airship a drift:Sense ;
    drift:gloss "a rigid lighter-than-air airship; by extension any large dirigible"@en ;
    drift:gloss "starres Luftschiff; allgemein ein grosses lenkbares Luftfahrzeug"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1900"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1900"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-zeppelin-lz1 a drift:TriggerEvent ;
    rdfs:label "First flight of the airship LZ 1 over Lake Constance"@en ;
    dct:description "On 2 July 1900 the first Zeppelin rigid airship, LZ 1, made its maiden flight near Friedrichshafen. The inventor's name became the everyday term for the airship type."@en ;
    drift:eventDate "1900"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

# --- drift event ---
wdr:drift-zeppelin-lz1 a drift:DriftEvent ;
    drift:affectsWord wdr:word-zeppelin ;
    drift:senseFrom wdr:sense-zeppelin-name ;
    drift:senseTo wdr:sense-zeppelin-airship ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1900"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1910"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-zeppelin-dwds , wdr:src-zeppelin-wiki .

# --- causal hypothesis ---
wdr:hyp-zeppelin-lz1 a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-zeppelin-lz1 ;
    drift:proposedTrigger wdr:trigger-zeppelin-lz1 ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.9 ;
    drift:hasSource wdr:src-zeppelin-dwds ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-zeppelin-dwds a drift:Source ;
    dct:title "DWDS -- Zeppelin"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Zeppelin"^^xsd:anyURI .

wdr:src-zeppelin-wiki a drift:Source ;
    dct:title "Zeppelin -- Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Zeppelin"^^xsd:anyURI .
