@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "sherry" (en)
# Metonymization: the fortified wine "(vino de) Xeres", wine of
# Xeres (modern Jerez de la Frontera, Spain), gave English first
# "sherris", then the back-formed singular "sherry". The town is
# the trigger.
# =============================================================

wdr:word-sherry a drift:Word ;
    drift:writtenForm "sherry"@en ;
    drift:language "en" ;
    rdfs:label "sherry"@en ;
    ontolex:sense wdr:sense-sherry-xeres , wdr:sense-sherry-wine .

wdr:sense-sherry-xeres a drift:Sense ;
    drift:gloss "wine of Xeres (Spanish 'vino de Xeres'), borrowed into English as 'sherris'"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1530"^^xsd:gYear .

wdr:sense-sherry-wine a drift:Sense ;
    drift:gloss "a fortified white wine from the Jerez region of Spain; the singular 'sherry' back-formed from 'sherris'"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1600"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1600"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-sherry-jerez a drift:TriggerEvent ;
    rdfs:label "Wine of Xeres (Jerez de la Frontera)"@en ;
    dct:description "The Spanish town of Xeres (modern Jerez de la Frontera) near Cadiz produced the fortified wine; its name entered English as 'sherris', from which 'sherry' was back-formed as a mistaken singular."@en ;
    drift:eventDate "1600"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial ;
    owl:sameAs wd:Q12303 .

# --- drift event ---
wdr:drift-sherry-jerez a drift:DriftEvent ;
    drift:affectsWord wdr:word-sherry ;
    drift:senseFrom wdr:sense-sherry-xeres ;
    drift:senseTo wdr:sense-sherry-wine ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1530"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1600"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-sherry-etym , wdr:src-sherry-wikt .

# --- causal hypothesis ---
wdr:hyp-sherry-jerez a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-sherry-jerez ;
    drift:proposedTrigger wdr:trigger-sherry-jerez ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-sherry-etym ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-sherry-etym a drift:Source ;
    dct:title "Online Etymology Dictionary -- sherry"@en ;
    drift:sourceURL "https://www.etymonline.com/word/sherry"^^xsd:anyURI .

wdr:src-sherry-wikt a drift:Source ;
    dct:title "Wiktionary -- sherry"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/sherry"^^xsd:anyURI .
