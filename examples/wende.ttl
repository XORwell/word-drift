@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# =============================================================
# WORKED EXAMPLE - "Wende" (de)
# Metonymization:
#   General German: "turn, turning point, reversal" (any domain)
#   Post-1989: the specific historical turning point of the
#   German reunification; capitalised "die Wende" became a
#   proper metonym for that entire political event complex.
# =============================================================

wdr:word-wende a drift:Word ;
    drift:writtenForm "Wende"@de ;
    drift:language "de" ;
    rdfs:label "Wende"@de ;
    ontolex:sense wdr:sense-wende-general , wdr:sense-wende-1989 .

wdr:sense-wende-general a drift:Sense ;
    drift:gloss "a turn, turning point, or reversal; change of direction (general)"@en ;
    drift:gloss "allgemeine Bedeutung: Wendepunkt, Kehrtwende"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1000"^^xsd:gYear .

wdr:sense-wende-1989 a drift:Sense ;
    drift:gloss "the (German) Wende: the political transformation of 1989/90, encompassing the fall of the Berlin Wall, the end of the GDR, and German reunification"@en ;
    drift:gloss "die Wende als Eigenname fuer die Ereignisse 1989/90: Mauerfall, DDR-Ende, Wiedervereinigung"@de ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1989"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1989"^^xsd:gYear ]
    ] .

# --- trigger events ---
wdr:trigger-mauerfall a drift:TriggerEvent ;
    rdfs:label "Fall of the Berlin Wall (Mauerfall)"@en ;
    dct:description "The opening of the Berlin Wall on 9 November 1989 and the subsequent collapse of the GDR gave 'die Wende' its specific historical referent."@en ;
    drift:eventDate "1989"^^xsd:gYear ;
    drift:triggerCategory drift:Political ;
    owl:sameAs wd:Q69163529 .

# --- drift event: metonymization (causation lives in the hypothesis below) ---
wdr:drift-wende-1989 a drift:DriftEvent ;
    drift:affectsWord wdr:word-wende ;
    drift:senseFrom wdr:sense-wende-general ;
    drift:senseTo wdr:sense-wende-1989 ;
    drift:driftType drift:Metonymization ;
    drift:driftYear "1989"^^xsd:gYear ;
    drift:hasSource wdr:src-wende-dwds , wdr:src-wende-wikipedia .

# --- causal hypothesis (ADR 0004) ---
# Frequency observations (DWDS) spike in 1990 -> FrequencyCorrelation.
# DWDS is also a lexicographic/etymological source -> LexicographicNote.
wdr:hyp-wende-mauerfall a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-wende-1989 ;
    drift:proposedTrigger wdr:trigger-mauerfall ;
    drift:evidenceType drift:FrequencyCorrelation , drift:LexicographicNote ;
    drift:confidence 0.95 ;
    drift:hasSource wdr:src-wende-dwds , wdr:src-wende-wikipedia ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- frequency observations (timeline curve) ---
wdr:freq-wende-1988 a drift:FrequencyObservation ;
    drift:ofWord wdr:word-wende ; drift:observedYear "1988"^^xsd:gYear ;
    drift:relativeFrequency 0.5 ; drift:fromCorpus wdr:corpus-dwds-de .
wdr:freq-wende-1990 a drift:FrequencyObservation ;
    drift:ofWord wdr:word-wende ; drift:observedYear "1990"^^xsd:gYear ;
    drift:relativeFrequency 4.2 ; drift:fromCorpus wdr:corpus-dwds-de .
wdr:freq-wende-1995 a drift:FrequencyObservation ;
    drift:ofWord wdr:word-wende ; drift:observedYear "1995"^^xsd:gYear ;
    drift:relativeFrequency 2.1 ; drift:fromCorpus wdr:corpus-dwds-de .

# --- sources ---
wdr:corpus-dwds-de a drift:Corpus ;
    dct:title "DWDS Wortverlaufskurve (BBAW)"@de ;
    drift:sourceURL "https://www.dwds.de/r/plot"^^xsd:anyURI .

wdr:src-wende-dwds a drift:Source ;
    dct:title "DWDS - Wende"@de ;
    drift:sourceURL "https://www.dwds.de/wb/Wende"^^xsd:anyURI .

wdr:src-wende-wikipedia a drift:Source ;
    dct:title "Die Wende - Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Wende_(1989/1990)"^^xsd:anyURI .
