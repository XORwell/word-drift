@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "zipper" (en)
# Broadening: B.F. Goodrich's 1923 brand name for galoshes with
# a hookless slide fastener -> generic name for the fastener
# itself. The 1923 Goodrich brand launch is the trigger.
# =============================================================

wdr:word-zipper a drift:Word ;
    drift:writtenForm "zipper"@en ;
    drift:language "en" ;
    rdfs:label "zipper"@en ;
    ontolex:sense wdr:sense-zipper-brand , wdr:sense-zipper-generic .

wdr:sense-zipper-brand a drift:Sense ;
    drift:gloss "B.F. Goodrich's brand name for rubber galoshes closed by a hookless slide fastener"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1923"^^xsd:gYear .

wdr:sense-zipper-generic a drift:Sense ;
    drift:gloss "a slide fastener with interlocking teeth, used on clothing, bags, and other goods"@en ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1925"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1925"^^xsd:gYear ]
    ] .

# --- trigger event ---
wdr:trigger-zipper-goodrich a drift:TriggerEvent ;
    rdfs:label "B.F. Goodrich markets the Zipper boot"@en ;
    dct:description "In 1923 the B.F. Goodrich Company adopted the name Zipper for rubber boots fitted with a hookless slide fastener. The catchy brand name was quickly transferred from the boots to the fastener, becoming the generic English word for the device."@en ;
    drift:eventDate "1923"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

# --- drift event ---
wdr:drift-zipper-goodrich a drift:DriftEvent ;
    drift:affectsWord wdr:word-zipper ;
    drift:senseFrom wdr:sense-zipper-brand ;
    drift:senseTo wdr:sense-zipper-generic ;
    drift:driftType drift:Metonymization ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1923"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1930"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-zipper-wikt , wdr:src-zipper-wiki .

# --- causal hypothesis ---
wdr:hyp-zipper-goodrich a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-zipper-goodrich ;
    drift:proposedTrigger wdr:trigger-zipper-goodrich ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.85 ;
    drift:hasSource wdr:src-zipper-wikt ;
    prov:wasAttributedTo wdr:curator ;
    dct:date "2026-05-23"^^xsd:date .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-zipper-wikt a drift:Source ;
    dct:title "zipper -- Wiktionary"@en ;
    drift:sourceURL "https://en.wiktionary.org/wiki/zipper"^^xsd:anyURI .

wdr:src-zipper-wiki a drift:Source ;
    dct:title "Zipper -- Wikipedia"@en ;
    drift:sourceURL "https://en.wikipedia.org/wiki/Zipper"^^xsd:anyURI .
