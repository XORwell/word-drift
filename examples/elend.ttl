@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# "Elend" (de)
# Narrowing + Pejoration: OHG eli-lenti "foreign land, exile"
# -> MHG "banishment, homelessness" -> NHG "misery, wretchedness"
# The shift encodes the medieval equation of exile with
# the greatest human suffering.
# =============================================================

wdr:word-elend a drift:Word ;
    drift:writtenForm "Elend"@de ;
    drift:language "de" ;
    rdfs:label "Elend"@de ;
    ontolex:sense wdr:sense-elend-exile , wdr:sense-elend-misery .

wdr:sense-elend-exile a drift:Sense ;
    drift:gloss "foreign land; exile; the state of living outside one's homeland or community"@en ;
    drift:gloss "Fremde, Verbannung; Aufenthalt im anderen Land"@de ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "0800"^^xsd:gYear .

wdr:sense-elend-misery a drift:Sense ;
    drift:gloss "misery, wretchedness, suffering; a wretched or pitiable state"@en ;
    drift:gloss "Jammer, Not, grosses Leid"@de ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1000"^^xsd:gYear ;
    drift:attestedDuring [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1000"^^xsd:gYear ]
    ] .

# --- drift event ---
wdr:drift-elend-medieval a drift:DriftEvent ;
    drift:affectsWord wdr:word-elend ;
    drift:senseFrom wdr:sense-elend-exile ;
    drift:senseTo wdr:sense-elend-misery ;
    drift:driftType drift:Pejoration ;
    drift:driftInterval [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDgYear "1000"^^xsd:gYear ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDgYear "1300"^^xsd:gYear ]
    ] ;
    drift:hasSource wdr:src-elend-dwds , wdr:src-elend-wiki .

# --- no datable trigger; no CausalHypothesis for this gradual shift ---

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

# --- sources ---
wdr:src-elend-dwds a drift:Source ;
    dct:title "DWDS -- elend (Etymologie)"@de ;
    drift:sourceURL "https://www.dwds.de/wb/elend"^^xsd:anyURI .

wdr:src-elend-wiki a drift:Source ;
    dct:title "Elend -- Wikipedia"@de ;
    drift:sourceURL "https://de.wikipedia.org/wiki/Elend"^^xsd:anyURI .
