wdr:sense-edge-figurative a drift:Sense ;
    drift:attestedDuring [ a time:Interval ;
            time:hasBeginning [ a time:Instant ;
                    time:inXSDgYear "1900"^^xsd:gYear ] ] ;
    drift:connotation drift:Neutral ;
    drift:firstAttested "1900"^^xsd:gYear ;
    drift:gloss "figurative uses: a competitive advantage (to have the edge); tense irritability (on edge, edgy); the leading front of innovation (the cutting edge)"@en .

wdr:sense-egregious-eminent a drift:Sense ;
    drift:connotation drift:Positive ;
    drift:firstAttested "1534"^^xsd:gYear ;
    drift:gloss "remarkably good, distinguished, eminent; standing out from the crowd in a positive way (Latin egregius, 'out of the flock')"@en .

wdr:sense-egregious-flagrant a drift:Sense ;
    drift:attestedDuring [ a time:Interval ;
            time:hasBeginning [ a time:Instant ;
                    time:inXSDgYear "1573"^^xsd:gYear ] ] ;
    drift:connotation drift:Negative ;
    drift:firstAttested "1573"^^xsd:gYear ;
    drift:gloss "remarkably bad; flagrant, conspicuously offensive; outrageously bad in a way that stands out"@en .

wdr:sense-elend-exile a drift:Sense ;
