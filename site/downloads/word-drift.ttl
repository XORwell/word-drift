drift:Media a skos:Concept ;
    skos:inScheme drift:TriggerCategoryScheme ;
    skos:prefLabel "media / internet"@en .

drift:Speculative a skos:Concept ;
    skos:definition "Drift year roughly coincides with the event, asserted by the curator only. Correlation, easily spurious. Never sufficient alone."@en ;
    skos:inScheme drift:EvidenceTypeScheme ;
    skos:prefLabel "speculative (temporal coincidence)"@en .

wdr:corpus-dwds a drift:Corpus ;
    dct:title "DWDS Wortverlaufskurve (BBAW)"@de ;
    drift:sourceURL "https://www.dwds.de/r/plot"^^xsd:anyURI .

drift:Commercial a skos:Concept ;
    skos:inScheme drift:TriggerCategoryScheme ;
    skos:prefLabel "commercial / brand"@en .

drift:Pejoration a skos:Concept ;
    skos:broader drift:ValenceShift ;
    skos:definition "The sense acquires a more negative connotation over time."@en ;
    skos:inScheme drift:DriftTypeScheme ;
    skos:prefLabel "Bedeutungsverschlechterung"@de,
        "pejoration"@en .

drift:Narrowing a skos:Concept ;
    skos:broader drift:ScopeShift ;
    skos:definition "The sense specialises to cover a narrower range of referents."@en ;
    skos:inScheme drift:DriftTypeScheme ;
    skos:prefLabel "Bedeutungsverengung"@de,
        "narrowing"@en .

wdr:src-wugs-durel a drift:Corpus ;
    rdfs:label "DURel"@en ;
    dct:identifier "doi:10.5281/zenodo.5541274" ;
    dct:title "DURel German (Diachronic Usage Relatedness, Schlechtweg et al.)"@en ;
    rdfs:comment "Benchmark (gold human-annotated lexical semantic change). Ingested as detection-grade backbone: derived target-word + gold graded-change only, no raw usage graphs, no causal claim (ADR 0004)."@en ;
    drift:sourceURL "https://zenodo.org/records/5784453"^^xsd:anyURI .

wdr:src-wugs-surel a drift:Corpus ;
    rdfs:label "SURel"@en ;
    dct:identifier "doi:10.5281/zenodo.5543306" ;
    dct:title "SURel German (Synchronic Usage Relatedness, Schlechtweg et al.)"@en ;
    rdfs:comment "Benchmark (gold human-annotated lexical semantic change). Ingested as detection-grade backbone: derived target-word + gold graded-change only, no raw usage graphs, no causal claim (ADR 0004)."@en ;
    drift:sourceURL "https://zenodo.org/records/5784569"^^xsd:anyURI .

drift:Metonymization a skos:Concept ;
    skos:broader drift:Mechanism ;
    skos:definition "A new sense arises by metonymic transfer (contiguity)."@en ;
    skos:inScheme drift:DriftTypeScheme ;
    skos:prefLabel "metonymization"@en .

wdr:curator-gfds a prov:Agent ;
    rdfs:label "WORD-DRIFT GfdS curator"@en ;
    dct:description "Automated GfdS ingest pipeline (gfds_import.py)"@en .

drift:Political a skos:Concept ;
    skos:inScheme drift:TriggerCategoryScheme ;
    skos:prefLabel "political"@en .

drift:Technology a skos:Concept ;
    skos:inScheme drift:TriggerCategoryScheme ;
    skos:prefLabel "technological"@en .

drift:UnspecifiedShift a skos:Concept ;
    skos:definition "A semantic change attested by a detection benchmark (graded change score) whose direction and type are not specified by the source."@en ;
    skos:inScheme drift:DriftTypeScheme ;
    skos:prefLabel "unspezifizierter Wandel"@de,
        "unspecified shift"@en ;
    skos:topConceptOf drift:DriftTypeScheme .

drift:Metaphorization a skos:Concept ;
    skos:broader drift:Mechanism ;
    skos:definition "A new sense arises by metaphorical transfer (similarity)."@en ;
    skos:inScheme drift:DriftTypeScheme ;
    skos:prefLabel "metaphorization"@en .

