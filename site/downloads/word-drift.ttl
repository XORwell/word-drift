@prefix dct: <http://purl.org/dc/terms/> .
@prefix drift: <https://w3id.org/word-drift/ontology#> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix wdr: <https://w3id.org/word-drift/resource/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

drift: a owl:Ontology ;
    dct:creator "Christian Nennemann" ;
    dct:description "OWL 2 vocabulary aligned to OntoLex-Lemon, OWL-Time, PROV-O and SKOS. Its novel layer reifies causation as an evidenced, graded drift:CausalHypothesis rather than asserting a triggered-by fact (ADR 0004). External vocabularies are referenced by IRI, not physically imported (ADR 0002), so no owl:imports is declared."@en ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:source <https://github.com/XORwell/word-drift> ;
    dct:title "WORD-DRIFT ontology"@en ;
    rdfs:comment "A knowledge graph vocabulary for lexical semantic change (Bedeutungswandel): senses over time, typed drift events, and the historical events that trigger them."@en ;
    rdfs:seeAlso <http://www.w3.org/2004/02/skos/core>,
        <http://www.w3.org/2006/time>,
        <http://www.w3.org/ns/lemon/ontolex>,
        <http://www.w3.org/ns/prov-o> ;
    owl:versionIRI <https://w3id.org/word-drift/ontology/0.3.0> ;
    owl:versionInfo "0.3.0" .

drift:aboutDrift a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "about drift"@en ;
    rdfs:comment "Functional: a hypothesis explains exactly one drift event. A claim spanning several events is split into one hypothesis each."@en,
        "Links a causal hypothesis to the drift event it tries to explain (ADR 0004)."@en ;
    rdfs:domain drift:CausalHypothesis ;
    rdfs:range drift:DriftEvent .

drift:attestedDuring a owl:ObjectProperty ;
    rdfs:label "attested during"@en ;
    rdfs:comment "Time interval in which the sense is attested in corpora. Open-ended intervals (still in use) omit the end."@en ;
    rdfs:domain drift:Sense ;
    rdfs:range time:Interval .

drift:confidence a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "confidence"@en ;
    rdfs:comment "Confidence (0.0 to 1.0) that the proposed trigger is associated with the shift. A graded claim, never a proof. Functional: exactly one confidence per hypothesis (SHACL maxCount 1); competing assessments are separate drift:CausalHypothesis nodes."@en ;
    rdfs:domain drift:CausalHypothesis ;
    rdfs:range xsd:decimal .

drift:connotation a owl:ObjectProperty ;
    rdfs:label "connotation"@en ;
    rdfs:comment "Social evaluation carried by the sense (drift:Positive / drift:Neutral / drift:Negative). The axis on which pejoration and amelioration are measured."@en ;
    rdfs:domain drift:Sense ;
    rdfs:range skos:Concept .

drift:crossLingualOf a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "sprachübergreifend gleich"@de,
        "cross-lingual of"@en ;
    rdfs:comment "Links two Words that are the same concept across languages (translation equivalents, e.g. \"mouse\"@en and \"Maus\"@de); not mere co-occurrence under a shared trigger. Symmetric: if A drift:crossLingualOf B then B drift:crossLingualOf A."@en ;
    rdfs:domain drift:Word ;
    rdfs:range drift:Word .

drift:driftInterval a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "drift interval"@en ;
    rdfs:comment "Period over which the shift unfolded, when a single year is too sharp. Functional: one drift event has at most one interval."@en ;
    rdfs:domain drift:DriftEvent ;
    rdfs:range time:Interval .

drift:driftType a owl:ObjectProperty ;
    rdfs:label "drift type"@en ;
    rdfs:comment "Classification of the change, drawn from drift:DriftTypeScheme."@en ;
    rdfs:domain drift:DriftEvent ;
    rdfs:range skos:Concept .

drift:driftYear a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "drift year"@en ;
    rdfs:comment "Approximate year the shift became salient. Coarse anchor for the timeline. Functional: one drift event has a single year anchor (use drift:driftInterval for spans)."@en ;
    rdfs:domain drift:DriftEvent ;
    rdfs:range xsd:gYear .

drift:eventDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "event date"@en ;
    rdfs:comment "Year (or onset year) of the trigger event. Functional: a convenience single-year anchor cross-checked against the external source (P585/P571, ADR 0004)."@en ;
    rdfs:domain drift:TriggerEvent ;
    rdfs:range xsd:gYear .

drift:evidenceType a owl:ObjectProperty ;
    rdfs:label "evidence type"@en ;
    rdfs:comment "What kind of evidence backs this hypothesis, from drift:EvidenceTypeScheme."@en ;
    rdfs:domain drift:CausalHypothesis ;
    rdfs:range skos:Concept .

drift:firstAttested a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "first attested"@en ;
    rdfs:comment "Earliest year the sense is documented. Coarse anchor for the timeline when no full interval is known. Functional: a sense has a single earliest attestation year."@en ;
    rdfs:domain drift:Sense ;
    rdfs:range xsd:gYear .

drift:fromCorpus a owl:ObjectProperty ;
    rdfs:label "from corpus"@en ;
    rdfs:comment "The corpus the observation is drawn from. Domain is drift:FrequencyObservation (all observed usages); attestation-level provenance uses drift:hasSource instead."@en ;
    rdfs:domain drift:FrequencyObservation ;
    rdfs:range drift:Corpus .

drift:gloss a owl:DatatypeProperty ;
    rdfs:label "gloss"@en ;
    rdfs:comment "Short human-readable definition of the sense."@en ;
    rdfs:domain drift:Sense ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf skos:definition .

drift:gradedChange a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "graded change"@en ;
    rdfs:comment "SemEval-style graded-change magnitude (0.0 to 1.0) measuring HOW MUCH a word changed between periods. A detection signal from the source data, NOT a causal confidence (which lives on drift:CausalHypothesis, ADR 0004)."@en ;
    rdfs:domain drift:DriftEvent ;
    rdfs:range xsd:decimal .

drift:hasSource a owl:ObjectProperty ;
    rdfs:label "has source"@en ;
    rdfs:comment "Links any drift event or attestation to the source that supports it."@en ;
    rdfs:range drift:Source ;
    rdfs:subPropertyOf prov:wasDerivedFrom .

drift:language a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "language"@en ;
    rdfs:comment "BCP-47 language code of the word (e.g. \"de\", \"en\"). Functional: a word has exactly one language."@en ;
    rdfs:domain drift:Word ;
    rdfs:range xsd:language ;
    rdfs:subPropertyOf dct:language .

drift:observedYear a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "observed year"@en ;
    rdfs:comment "Calendar year (xsd:gYear) for which a frequency observation reports its value."@en ;
    rdfs:domain drift:FrequencyObservation ;
    rdfs:range xsd:gYear .

drift:ofSense a owl:ObjectProperty ;
    rdfs:label "of sense"@en ;
    rdfs:comment "Links a frequency observation to the specific sense it measures, when the count is sense-disambiguated rather than form-level."@en ;
    rdfs:domain drift:FrequencyObservation ;
    rdfs:range drift:Sense .

drift:ofWord a owl:ObjectProperty ;
    rdfs:label "of word"@en ;
    rdfs:comment "Links a frequency observation to the word it measures."@en ;
    rdfs:domain drift:FrequencyObservation ;
    rdfs:range drift:Word .

drift:proposedTrigger a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "proposed trigger"@en ;
    rdfs:comment "The event this hypothesis proposes as associated with the shift. Proposed, not proven. Functional: one hypothesis proposes one trigger; competing triggers are competing hypotheses."@en ;
    rdfs:domain drift:CausalHypothesis ;
    rdfs:range drift:TriggerEvent .

drift:relativeFrequency a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "relative frequency"@en ;
    rdfs:comment "Relative frequency (e.g. per million tokens) in the source corpus for the observed year. Functional: one reified observation reports one value for one (word/sense, year)."@en ;
    rdfs:domain drift:FrequencyObservation ;
    rdfs:range xsd:decimal .

drift:senseFrom a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "sense from"@en ;
    rdfs:comment "The prior sense/connotation. May be absent when a wholly new sense emerges. Functional: a single drift event has at most one prior sense."@en ;
    rdfs:domain drift:DriftEvent ;
    rdfs:range drift:Sense .

drift:senseTo a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "sense to"@en ;
    rdfs:comment "The resulting sense/connotation after the shift. Functional: a single drift event resolves to one resulting sense."@en ;
    rdfs:domain drift:DriftEvent ;
    rdfs:range drift:Sense .

drift:sourceURL a owl:DatatypeProperty ;
    rdfs:label "source URL"@en ;
    rdfs:comment "Dereferenceable URL of the source (corpus query, dictionary entry, dataset record, or publication)."@en ;
    rdfs:domain drift:Source ;
    rdfs:range xsd:anyURI .

drift:triggerCategory a owl:ObjectProperty ;
    rdfs:label "trigger category"@en ;
    rdfs:comment "Classifies a trigger event by the kind of real-world event it is, drawn from drift:TriggerCategoryScheme (political, pandemic, technological, cultural, media, commercial)."@en ;
    rdfs:domain drift:TriggerEvent ;
    rdfs:range skos:Concept .

drift:writtenForm a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "written form"@en ;
    rdfs:comment "The orthographic form, language-tagged (e.g. \"Querdenker\"@de). Functional: each word carries exactly one canonical written form (SHACL minCount 1; data maxCount 1)."@en ;
    rdfs:domain drift:Word ;
    rdfs:range rdfs:Literal .

wdr:agent-freq-pipeline a prov:Agent ;
    rdfs:label "WORD-DRIFT Tier-B frequency pipeline (auto)"@en .

wdr:alignment-curator a prov:Agent ;
    rdfs:label "WORD-DRIFT ChangeSignalAlignment curator (WS-EVAL-ALIGN, 2026-05-24)"@en .

wdr:drift-awful-1800s a drift:DriftEvent ;
    drift:affectsWord wdr:word-awful ;
    drift:driftInterval [ a time:Interval ;
            time:hasBeginning [ a time:Instant ;
                    time:inXSDgYear "1750"^^xsd:gYear ] ;
            time:hasEnd [ a time:Instant ;
                    time:inXSDgYear "1850"^^xsd:gYear ] ] ;
    drift:driftType drift:Pejoration ;
    drift:hasSource wdr:src-awful-etymonline,
        wdr:src-awful-oed ;
    drift:senseFrom wdr:sense-awful-awe ;
    drift:senseTo wdr:sense-awful-bad .

wdr:drift-bloed-pejoration a drift:DriftEvent ;
    drift:affectsWord wdr:word-bloed ;
    drift:driftInterval [ a time:Interval ;
            time:hasBeginning [ a time:Instant ;
                    time:inXSDgYear "1400"^^xsd:gYear ] ;
            time:hasEnd [ a time:Instant ;
                    time:inXSDgYear "1600"^^xsd:gYear ] ] ;
    drift:driftType drift:Pejoration ;
    drift:hasSource wdr:src-bloed-dwds ;
    drift:senseFrom wdr:sense-bloed-weak ;
    drift:senseTo wdr:sense-bloed-stupid .

wdr:drift-deer-medieval a drift:DriftEvent ;
    drift:affectsWord wdr:word-deer ;
    drift:driftInterval [ a time:Interval ;
            time:hasBeginning [ a time:Instant ;
                    time:inXSDgYear "1100"^^xsd:gYear ] ;
            time:hasEnd [ a time:Instant ;
                    time:inXSDgYear "1400"^^xsd:gYear ] ] ;
    drift:driftType drift:Narrowing ;
    drift:hasSource wdr:src-deer-etymonline,
        wdr:src-deer-oed ;
    drift:senseFrom wdr:sense-deer-animal ;
    drift:senseTo wdr:sense-deer-cervid .

wdr:drift-dirne-narrowing a drift:DriftEvent ;
    drift:affectsWord wdr:word-dirne ;
    drift:driftInterval [ a time:Interval ;
            time:hasBeginning [ a time:Instant ;
                    time:inXSDgYear "1200"^^xsd:gYear ] ;
            time:hasEnd [ a time:Instant ;
                    time:inXSDgYear "1400"^^xsd:gYear ] ] ;
    drift:driftType drift:Narrowing ;
    drift:hasSource wdr:src-dirne-dwds ;
    drift:senseFrom wdr:sense-dirne-girl ;
    drift:senseTo wdr:sense-dirne-maid .

wdr:drift-dirne-pejoration a drift:DriftEvent ;
    drift:affectsWord wdr:word-dirne ;
    drift:driftInterval [ a time:Interval ;
            time:hasBeginning [ a time:Instant ;
                    time:inXSDgYear "1450"^^xsd:gYear ] ;
            time:hasEnd [ a time:Instant ;
                    time:inXSDgYear "1600"^^xsd:gYear ] ] ;
    drift:driftType drift:Pejoration ;
    drift:hasSource wdr:src-dirne-dwds,
        wdr:src-dirne-nubling ;
    drift:senseFrom wdr:sense-dirne-maid ;
    drift:senseTo wdr:sense-dirne-prostitute .

