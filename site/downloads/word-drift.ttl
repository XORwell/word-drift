    drift:driftInterval [ a time:Interval ;
            time:hasBeginning [ a time:Instant ;
                    time:inXSDgYear "1991"^^xsd:gYear ] ;
            time:hasEnd [ a time:Instant ;
                    time:inXSDgYear "1998"^^xsd:gYear ] ] ;
    drift:driftType drift:Metaphorization ;
    drift:hasSource wdr:src-web-etymonline,
        wdr:src-web-oed ;
    drift:senseFrom wdr:sense-web-spider ;
    drift:senseTo wdr:sense-web-www .

