    dct:title "SemEval-2020 Task 1 (English)"@en ;
    drift:sourceURL "https://zenodo.org/records/3931969"^^xsd:anyURI .

wdr:src-wugs-dwug-de a drift:Corpus ;
    rdfs:label "DWUG"@en ;
