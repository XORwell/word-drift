drift:LexicographicNote a skos:Concept ;
    skos:definition "A dictionary etymology note states the link. Attributed evidence, not the curator's own claim."@en ;
    skos:inScheme drift:EvidenceTypeScheme ;
    skos:prefLabel "lexicographic note"@en .

wdr:curator a prov:Agent ;
    rdfs:label "WORD-DRIFT curators"@en .

wdr:corpus-dwug-de a drift:Corpus ;
    dct:title "DWUG German"@en ;
    drift:sourceURL "https://zenodo.org/records/14028509"^^xsd:anyURI .

drift:Negative a skos:Concept ;
    skos:inScheme drift:ConnotationScheme ;
    skos:prefLabel "negative"@en .

drift:Broadening a skos:Concept ;
    skos:broader drift:ScopeShift ;
    skos:definition "The sense generalises to cover a wider range of referents."@en ;
    skos:inScheme drift:DriftTypeScheme ;
    skos:prefLabel "Bedeutungserweiterung"@de,
        "broadening"@en .

wdr:curator-owid a prov:Agent ;
    rdfs:label "IDS Mannheim OWID curators"@en .

drift:ScholarlyAttestation a skos:Concept ;
    skos:definition "A peer-reviewed study states the link. Strongest attributed evidence."@en ;
    skos:inScheme drift:EvidenceTypeScheme ;
    skos:prefLabel "scholarly attestation"@en .

drift:TriggerEvent a owl:Class ;
    rdfs:label "Auslöser-Ereignis"@de,
        "trigger event"@en ;
    rdfs:comment "A datable real-world event proposed as the cause of a semantic shift (e.g. the COVID-19 pandemic, the rise of funk music). Linkable to Wikidata via owl:sameAs."@en ;
    rdfs:subClassOf prov:Activity .

drift:CausalHypothesis a owl:Class ;
    rdfs:label "Kausalhypothese"@de,
        "causal hypothesis"@en ;
    rdfs:comment "A reified, evidenced proposal that a drift event is associated with a trigger event. The authoritative carrier of confidence and evidence; drift:triggeredBy is only its human-readable shortcut. Several may compete for one drift event."@en ;
    rdfs:subClassOf prov:Entity .

drift:Source a owl:Class ;
    rdfs:label "source"@en ;
    rdfs:comment "A citable origin for an assertion: a corpus query, dictionary entry, dataset record, or publication."@en ;
    rdfs:subClassOf prov:Entity .

drift:DriftEvent a owl:Class ;
    rdfs:label "Bedeutungswandel-Ereignis"@de,
        "drift event"@en ;
    rdfs:comment "A documented semantic shift affecting one word: a change of sense, scope, or connotation, classified by drift:driftType and optionally tied to a triggering event."@en .

drift:Word a owl:Class ;
    rdfs:label "Wort"@de,
        "Word"@en ;
    rdfs:comment "A lexical entry under study. Carries a written form and a language tag, and is linked to one or more senses."@en ;
    rdfs:subClassOf ontolex:LexicalEntry .

drift:Neutral a skos:Concept ;
    skos:inScheme drift:ConnotationScheme ;
    skos:prefLabel "neutral"@en .

drift:Sense a owl:Class ;
    rdfs:label "Bedeutung"@de,
        "Sense"@en ;
    rdfs:comment "A distinguishable meaning of a word. The unit that gains, loses, or shifts connotation over time."@en ;
    rdfs:subClassOf ontolex:LexicalSense .

drift:FrequencyObservation a owl:Class ;
    rdfs:label "frequency observation"@en ;
    rdfs:comment "A single (year, value) measurement of how often a word or sense occurs in a named corpus. Reified so each point carries its own provenance."@en .

wdr:corpus-google-ngrams-de a drift:Corpus ;
    dct:title "Google Books Ngrams German (de-2019)"@en ;
    drift:sourceURL "https://books.google.com/ngrams"^^xsd:anyURI .

[] a owl:AllDisjointClasses ;
    owl:members ( drift:Word drift:Sense drift:DriftEvent drift:TriggerEvent drift:CausalHypothesis drift:Source drift:FrequencyObservation ) .

