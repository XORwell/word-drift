    rdfs:label "workplace flexibility"@en ;
    drift:eventDate "1995"^^xsd:gYear ;
    drift:triggerCategory drift:Economic .

wdr:trigger-owid-workplace-flexibility-reforms a drift:TriggerEvent ;
    rdfs:label "workplace flexibility reforms"@en ;
    drift:eventDate "1995"^^xsd:gYear ;
    drift:triggerCategory drift:Economic .

wdr:trigger-owid-workplace-policy a drift:TriggerEvent ;
    rdfs:label "workplace policy"@en ;
    drift:eventDate "2014"^^xsd:gYear ;
    drift:triggerCategory drift:Economic .

wdr:trigger-owid-workplace-psychology a drift:TriggerEvent ;
    rdfs:label "workplace psychology"@en ;
    drift:eventDate "2004"^^xsd:gYear ;
    drift:triggerCategory drift:Health .

wdr:trigger-owid-youth-subculture a drift:TriggerEvent ;
    rdfs:label "youth subculture"@en ;
    drift:eventDate "1995"^^xsd:gYear ;
    drift:triggerCategory drift:Social .

wdr:trigger-owid-youth-subculture-slang a drift:TriggerEvent ;
    rdfs:label "youth subculture slang"@en ;
    drift:eventDate "2004"^^xsd:gYear ;
    drift:triggerCategory drift:Linguistic .

wdr:trigger-paisley-town a drift:TriggerEvent ;
    rdfs:label "Shawl production at Paisley, Scotland"@en ;
    dct:description "The Scottish town of Paisley mass produced shawls with the curved teardrop motif; the place name became the name of the cloth and then the pattern, attested in English from 1834."@en ;
    owl:sameAs wd:Q211870 ;
    drift:eventDate "1834"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

wdr:trigger-panic-pan a drift:TriggerEvent ;
    rdfs:label "Greek myth of the god Pan and 'panic' fear"@en ;
    dct:description "In Greek myth the god Pan inhabited wild and lonely places and was held to inspire a sudden, irrational, contagious terror, the 'panikon deima'. Through Greek and Latin the adjective passed into English as 'panic', and the standalone noun for sudden fright emerged by the early eighteenth century."@en ;
    drift:eventDate "1600"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-pascal-unit-pressure a drift:TriggerEvent ;
    rdfs:label "Pascal's work on hydrostatics and pressure"@en ;
    dct:description "Blaise Pascal's experiments on hydrostatics, the barometer and the transmission of fluid pressure made his name a fitting honour for the unit of pressure, adopted in 1971 at the 14th General Conference on Weights and Measures."@en ;
    owl:sameAs wd:Q1290 ;
    drift:eventDate "1648"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-pasteurize-heat a drift:TriggerEvent ;
    rdfs:label "Pasteur develops controlled heat treatment of liquids"@en ;
    dct:description "Around 1864 Louis Pasteur showed that gentle heating of wine and beer killed spoilage microbes without ruining the product. The process and the verb derived from his name spread once the germ theory of disease was accepted."@en ;
    owl:sameAs wd:Q529 ;
    drift:eventDate "1864"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-pfaffe-reformation a drift:TriggerEvent ;
    rdfs:label "Protestant Reformation in the German lands"@en ;
    dct:description "The Reformation beginning 1517 sharply increased anticlericalism. Criticism of worldly, pluralist, and corrupt clergy made 'Pfaffe' a vehicle for contempt, fixing the pejorative sense."@en ;
    owl:sameAs wd:Q12562 ;
    drift:eventDate "1517"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-philippic-demosthenes a drift:TriggerEvent ;
    rdfs:label "Demosthenes' Philippics against Philip II (from 351 BC)"@en ;
    dct:description "From 351 BC the Athenian orator Demosthenes delivered a series of vehement speeches urging resistance to Philip II of Macedon; these were called the 'Philippics'. Cicero later borrowed the name for his attacks on Mark Antony. The proper name generalized to mean any bitter denunciatory oration."@en ;
    owl:sameAs wd:Q117253 ;
    drift:eventDate "0351"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-philister-studentensprache a drift:TriggerEvent ;
    rdfs:label "German university student slang, late 17th century"@en ;
    dct:description "In German university towns students adopted 'Philister' as a label for townsmen and non-students, opposing themselves to the Biblical enemies of the chosen people. A 1693 Jena funeral sermon for a student killed by townsmen is a frequently cited early attestation. The sense broadened to the narrow-minded, unintellectual person."@en ;
    drift:eventDate "1693"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-pretty-bleaching a drift:TriggerEvent ;
    rdfs:label "Bleaching of a degree adverb into a downtoner"@en ;
    dct:description "No single datable event. The adverbial 'pretty' weakened gradually from 'in a clever or fine manner' to a moderating downtoner over the 16th-17th centuries, a routine path for degree adverbs. The anchor year is the earliest adverbial attestation, not a cause."@en ;
    drift:eventDate "1565"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-procrustean-procrustes a drift:TriggerEvent ;
    rdfs:label "Procrustes, the bed-stretcher of Greek myth"@en ;
    dct:description "Procrustes, the mythical robber of Attica, forced victims to fit his bed by stretching or maiming them. The figure (known from classical sources and revived in English use of the 1580s, with the adjective recorded from 1822) became a byword for enforced, arbitrary conformity."@en ;
    owl:sameAs wd:Q271949 ;
    drift:eventDate "1822"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-proletariat-sozialismus a drift:TriggerEvent ;
    rdfs:label "1840s socialist movement and the Communist Manifesto (1848)"@en ;
    dct:description "In the 1840s the early socialist movement, and the Communist Manifesto of 1848, revived 'Proletariat' for the modern industrial working class and recast it from a Roman class of paupers into a positively charged collective political subject."@en ;
    drift:eventDate "1840"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-propaganda-congregatio a drift:TriggerEvent ;
    rdfs:label "Founding of the Congregatio de Propaganda Fide"@en ;
    dct:description "In 1622 Pope Gregory XV established the Congregatio de Propaganda Fide to coordinate Catholic missionary activity during the Counter-Reformation. Etymonline records the secular sense 'movement to propagate an ideology' from 1790 and the political sense from the First World War, which was 'originally not pejorative'; the manipulative, negative sense settled in the 20th century. The Roman institution is the lexical origin."@en ;
    owl:sameAs wd:Q386359 ;
    drift:eventDate "1622"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-protean-proteus a drift:TriggerEvent ;
    rdfs:label "Proteus, the shape-shifting sea-god"@en ;
    dct:description "Proteus, the Greek sea-god of Homeric and later myth, could elude capture by changing into any shape. The figure lent his name to the adjective 'protean', recorded in the 1590s, for anything endlessly variable or versatile."@en ;
    owl:sameAs wd:Q191481 ;
    drift:eventDate "1590"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-quarantaene-venice a drift:TriggerEvent ;
    rdfs:label "Venetian and Ragusan plague isolation regime"@en ;
    dct:description "In 1377 the Great Council of Ragusa (Dubrovnik) imposed a thirty-day (trentina) isolation on arrivals from plague areas; Venice and other ports extended it to forty days (quarantina). The fixed forty-day ship isolation against the Black Death attached the disease-control meaning to the number-word."@en ;
    drift:eventDate "1377"^^xsd:gYear ;
    drift:triggerCategory drift:Pandemic .

wdr:trigger-queer-nation a drift:TriggerEvent ;
    rdfs:label "Queer Nation and ACT UP activist reappropriation"@en ;
    dct:description "Queer Nation (founded 1990) and ACT UP activists deliberately reclaimed 'queer' as an empowering self-description, reversing its slur status."@en ;
    owl:sameAs wd:Q5687582 ;
    drift:eventDate "1990"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-querdenken-711 a drift:TriggerEvent ;
    rdfs:label "Querdenken-711-Bewegung"@de,
        "Querdenken 711 protest movement"@en ;
    dct:description "Anti-lockdown protest movement founded in Stuttgart in 2020, which fixed the new pejorative reading of the word."@en ;
    owl:sameAs wd:Q115500066 ;
    drift:eventDate "2020"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-quisling-invasion a drift:TriggerEvent ;
    rdfs:label "German invasion of Norway and Quisling's coup attempt"@en ;
    dct:description "On 9 April 1940 Germany invaded Norway; Vidkun Quisling proclaimed himself head of government. Within weeks Allied press, notably a 1940 leader in The Times, turned his name into a generic term for traitor."@en ;
    owl:sameAs wd:Q151364 ;
    drift:eventDate "1940"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-quixotic-cervantes a drift:TriggerEvent ;
    rdfs:label "Publication of Cervantes' Don Quixote"@en ;
    dct:description "The first part of Miguel de Cervantes' novel Don Quixote was published in 1605. The hero's idealistic but deluded chivalry made his name a byword for romantic impracticality, yielding the adjective 'quixotic' through metaphor."@en ;
    owl:sameAs wd:Q480 ;
    drift:eventDate "1605"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-robot-rur a drift:TriggerEvent ;
    rdfs:label "Coining of 'robot' in Karel Capek's play R.U.R."@en ;
    dct:description "Karel Capek's 1920 play R.U.R. (Rossum's Universal Robots) introduced 'robot', from Czech 'robota' (forced labour). The neologism rapidly spread and broadened to mechanical and automated devices."@en ;
    owl:sameAs wd:Q1164094 ;
    drift:eventDate "1920"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-roentgen-discovery a drift:TriggerEvent ;
    rdfs:label "Roentgen's discovery of X-rays at Wuerzburg"@en ;
    dct:description "On 8 November 1895 Wilhelm Conrad Roentgen discovered a new kind of radiation at the University of Wuerzburg. In German the rays and the resulting imaging were named after him (Roentgenstrahlen, roentgen), turning the surname into a generic medical and technical term."@en ;
    owl:sameAs wd:Q35149 ;
    drift:eventDate "1895"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-rugby-school a drift:TriggerEvent ;
    rdfs:label "Handling code at Rugby School"@en ;
    dct:description "The distinctive handling game of football was associated with Rugby School from the 1820s. As football codes diverged, the school name was adopted for the handling code and its game."@en ;
    owl:sameAs wd:Q1143281 ;
    drift:eventDate "1823"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-sabotage-cgt a drift:TriggerEvent ;
    rdfs:label "French syndicalist promotion of 'sabotage' as industrial action"@en ;
    dct:description "Around 1910 the French syndicalist movement (CGT) openly advocated 'sabotage' as a tactic, popularising the word; English borrowed it in this narrow labour sense before broadening it during and after the First World War."@en ;
    drift:eventDate "1910"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-sadism-sade a drift:TriggerEvent ;
    rdfs:label "The novels of the Marquis de Sade"@en ;
    dct:description "The Marquis de Sade became notorious for the cruel sexual practices described in his novels. His name was taken into French as 'sadisme' and into English by 1888 as the term for pleasure in cruelty."@en ;
    owl:sameAs wd:Q123867 ;
    drift:eventDate "1791"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-salvage-marinelaw a drift:TriggerEvent ;
    rdfs:label "Marine insurance and salvage law"@en ;
    dct:description "The body of maritime salvage law and the marine-insurance market (notably Lloyd's of London) made 'salvage' a common commercial term for recovering property from peril. From this base the sense broadened in the 19th century to reclaiming usable material generally, and later to figurative rescue."@en ;
    drift:eventDate "1680"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

wdr:trigger-sandwich-earl a drift:TriggerEvent ;
    rdfs:label "John Montagu, 4th Earl of Sandwich, popularises bread-and-filling meals"@en ;
    dct:description "Around 1762 John Montagu, 4th Earl of Sandwich, was reported to order meat served between bread so he could eat without leaving the gaming table. His title became attached to the food, producing the modern food sense via metonymy."@en ;
    drift:eventDate "1762"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-sardonic-sardinia a drift:TriggerEvent ;
    rdfs:label "Belief in a Sardinian plant causing a fatal grin"@en ;
    dct:description "Greek 'sardonios' (scornful laughter) was reshaped under the influence of 'Sardonios', Sardinian, from a belief that eating a plant called 'sardonion' (plant from Sardinia) produced facial convulsions resembling laughter, usually followed by death. The ancient etymology is disputed."@en ;
    owl:sameAs wd:Q1462 ;
    drift:eventDate "1630"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-saturnine-saturn a drift:TriggerEvent ;
    rdfs:label "Astrological temperament of those born under Saturn"@en ;
    dct:description "In medieval astrology Saturn was the most remote, coldest, and slowest of the known planets, and those born under it were held to be gloomy, grave, and sluggish. The planetary adjective (mid-15c.) carried this morose sense from the outset."@en ;
    drift:eventDate "1450"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-saxophone-patent a drift:TriggerEvent ;
    rdfs:label "Sax patents the saxophone"@en ;
    dct:description "In 1846 Adolphe Sax obtained a French patent for the family of instruments he had designed. The instruments and the word formed from his name spread rapidly through military and later jazz ensembles."@en ;
    owl:sameAs wd:Q181995 ;
    drift:eventDate "1846"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-schuetzengraben-wwi a drift:TriggerEvent ;
    rdfs:label "First World War trench warfare on the Western Front 1914-1918"@en ;
    dct:description "After the front stalemated in late 1914, the war became a war of trenches. 'Schuetzengraben' became the emblematic word of the First World War (1914-1918) and later a figure for entrenched, irreconcilable positions."@en ;
    owl:sameAs wd:Q361 ;
    drift:eventDate "1914"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-schwurbler-covid a drift:TriggerEvent ;
    rdfs:label "COVID-19 pandemic and Querdenken protests in Germany"@en ;
    dct:description "The COVID-19 pandemic and associated anti-vaccination and lockdown-sceptic movements, including Querdenken, drove the narrowing of Schwurbler to a specifically political pejorative label for conspiracy theorists."@en ;
    owl:sameAs wd:Q81068910 ;
    drift:eventDate "2020"^^xsd:gYear ;
    drift:triggerCategory drift:Pandemic .

wdr:trigger-sherry-jerez a drift:TriggerEvent ;
    rdfs:label "Wine of Xeres (Jerez de la Frontera)"@en ;
    dct:description "The Spanish town of Xeres (modern Jerez de la Frontera) near Cadiz produced the fortified wine; its name entered English as 'sherris', from which 'sherry' was back-formed as a mistaken singular."@en ;
    owl:sameAs wd:Q12303 ;
    drift:eventDate "1600"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

wdr:trigger-shrapnel-shell a drift:TriggerEvent ;
    rdfs:label "Shrapnel develops the bursting case shot"@en ;
    dct:description "From 1784 Henry Shrapnel developed a shell filled with shot that burst in flight; the British Army adopted it in 1803 and it carried his name. By the 1940s (the Blitz) the word had broadened to mean shell fragments in general (a use lexicographers note as strictly erroneous)."@en ;
    owl:sameAs wd:Q941215 ;
    drift:eventDate "1784"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-sick-slang a drift:TriggerEvent ;
    rdfs:label "Youth-culture slang reversal of a negative term"@en ;
    dct:description "No single datable event. Like 'bad', 'wicked' and 'ill', 'sick' was reversed to a term of approval in late 20th-century youth slang (skate, surf, hip hop), where extremity itself is praised. The anchor year is a representative decade, not a cause."@en ;
    drift:eventDate "1980"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-silhouette-minister a drift:TriggerEvent ;
    rdfs:label "Tenure of Etienne de Silhouette as controller-general of finances"@en ;
    dct:description "Etienne de Silhouette served briefly as French controller-general of finances in 1759. His name became a byword for cheapness and austerity, and was attached to the inexpensive shadow-outline portraits then in fashion, from which the general sense of an outline shape developed."@en ;
    owl:sameAs wd:Q290240 ;
    drift:eventDate "1759"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-siren-sirens a drift:TriggerEvent ;
    rdfs:label "The Sirens of Greek myth"@en ;
    dct:description "In Greek myth the Sirens lured passing sailors to wreck with their song, as in the Odyssey. The mythical name, in English from the mid-14th century, yielded by the 1580s the figurative sense of a dangerously alluring woman or temptation."@en ;
    owl:sameAs wd:Q150986 ;
    drift:eventDate "1580"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-slop-genai a drift:TriggerEvent ;
    rdfs:label "Proliferation of generative AI content"@en ;
    dct:description "The public release of large generative models (ChatGPT, late 2022) and the flood of cheap machine-generated text and images that followed. By 2024 'AI slop' was an established label in technology and general press for this low-value output."@en ;
    owl:sameAs wd:Q115564437 ;
    drift:eventDate "2022"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-sophisticated-revaluation a drift:TriggerEvent ;
    rdfs:label "Revaluation of worldliness from corruption to refinement"@en ;
    dct:description "No single datable event. The loss of naive purity, once a defect (adulteration), was gradually reinterpreted as the positive quality of worldly refinement; the favourable 'worldly-wise' sense of persons is attested by 1895 (Etymonline). The anchor year marks the established positive sense, not a cause."@en ;
    drift:eventDate "1895"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-spa-town a drift:TriggerEvent ;
    rdfs:label "Fame of Spa's mineral springs"@en ;
    dct:description "The Belgian town of Spa became the leading European destination for mineral-water cures. English visitors generalised the place name to mean any such spring resort, and later any health and bathing establishment."@en ;
    owl:sameAs wd:Q39865 ;
    drift:eventDate "1620"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

wdr:trigger-spartan-sparta a drift:TriggerEvent ;
    rdfs:label "Reputation of Spartan austerity"@en ;
    dct:description "Ancient accounts of Sparta's harsh military upbringing and plain living made the civic name a byword for austerity. The adjective generalised to mean severe simplicity and frugal endurance."@en ;
    drift:eventDate "1640"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-spiesser-buergerkritik a drift:TriggerEvent ;
    rdfs:label "Student slang and 19th c. critique of the bourgeoisie"@en ;
    dct:description "From the 18th c. students used 'Spiessbuerger' to mock the settled townsman as the opposite of the free academic. The 19th c. intellectual and artistic critique of bourgeois conformism fixed the short form 'Spiesser' as a pejorative for the narrow, philistine conformist."@en ;
    drift:eventDate "1840"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-stan-eminem a drift:TriggerEvent ;
    rdfs:label "Eminem's song 'Stan' (2000)"@en ;
    dct:description "Eminem's 2000 song 'Stan', about a fan whose devotion turns deadly, gave its name to the common noun for an obsessive fan; social-media fandom later generalised it into the verb 'to stan'."@en ;
    owl:sameAs wd:Q312122 ;
    drift:eventDate "2000"^^xsd:gYear ;
    drift:triggerCategory drift:Media .

wdr:trigger-stentorian-stentor a drift:TriggerEvent ;
    rdfs:label "Stentor, the loud-voiced herald of Homer's Iliad"@en ;
    dct:description "Stentor was the herald of the Greek forces at Troy, described by Homer as having a voice as loud as fifty men. The figure, known from the eighth-century BC epic, lent his name to the adjective for a powerful voice."@en ;
    drift:eventDate "1600"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-streik-arbeiterbewegung a drift:TriggerEvent ;
    rdfs:label "German labour movement and trade unions, 1860s-1870s"@en ;
    dct:description "From the 1860s the rising German labour movement and the founding of trade unions fixed the English loan 'Streik' as the technical term for an organised collective stoppage of work to enforce demands."@en ;
    drift:eventDate "1865"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-suede-sweden a drift:TriggerEvent ;
    rdfs:label "Gloves of Sweden (gants de Suede)"@en ;
    dct:description "The French phrase 'gants de Suede', gloves of Sweden, named the soft napped leather; English took 'suede' from it (the phrase in English by 1859, the noun by 1884), the country name standing for the material."@en ;
    owl:sameAs wd:Q34 ;
    drift:eventDate "1884"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

wdr:trigger-sus-amongus a drift:TriggerEvent ;
    rdfs:label "Among Us popularity surge (2020)"@en ;
    dct:description "The social-deduction game Among Us, released in 2018, exploded in popularity during the 2020 lockdowns; players accusing each other of being 'sus' (suspicious) propelled the clipped form into mainstream internet slang."@en ;
    owl:sameAs wd:Q96417649 ;
    drift:eventDate "2020"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-tank-somme a drift:TriggerEvent ;
    rdfs:label "British 'tank' codename and combat debut on the Somme"@en ;
    dct:description "In 1915-1916 the British used 'tank' as a secrecy codename, disguising the new armoured vehicle as a water carrier. Its combat debut at the Somme in September 1916 fixed the military sense in public language."@en ;
    owl:sameAs wd:Q1284532 ;
    drift:eventDate "1916"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-tantalize-tantalus a drift:TriggerEvent ;
    rdfs:label "Greek myth of Tantalus"@en ;
    dct:description "In Greek myth Tantalus was condemned in the underworld to stand in a pool beneath fruit-laden boughs, both of which drew away whenever he reached to drink or eat. The verb 'tantalize' was coined in late sixteenth-century English directly from his name to mean teasing with the unattainable."@en ;
    drift:eventDate "1590"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-tempo-de-brand a drift:TriggerEvent ;
    rdfs:label "Tempo paper handkerchief brand registered"@en ;
    dct:description "In 1929 the Vereinigte Papierwerke registered the Tempo brand of disposable paper handkerchief at the Reichspatentamt in Berlin. The brand became the colloquial German word for any paper tissue."@en ;
    drift:eventDate "1929"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

wdr:trigger-terrific-hyperbole a drift:TriggerEvent ;
    rdfs:label "Hyperbolic bleaching of a fear word into praise"@en ;
    dct:description "No single datable event. Like 'awful', 'tremendous' and 'dreadful', the word weakened through colloquial hyperbole from 'frightful' to 'very great' to 'excellent' over the 19th century. The anchor year marks the colloquial positive attestation, not a cause."@en ;
    drift:eventDate "1888"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-tesla-electromagnetism a drift:TriggerEvent ;
    rdfs:label "Tesla's work on electromagnetism and alternating current"@en ;
    dct:description "Nikola Tesla's pioneering work on alternating current and electromagnetic devices made his name a fitting honour for the unit of magnetic flux density, adopted by 1960 at the 11th General Conference on Weights and Measures."@en ;
    owl:sameAs wd:Q9036 ;
    drift:eventDate "1888"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-thermos-brand a drift:TriggerEvent ;
    rdfs:label "Thermos brand vacuum flask launched"@en ;
    dct:description "In 1904 the brand Thermos was adopted for the commercialised vacuum flask (based on James Dewar's earlier invention). The brand spread so widely that the word came to mean any vacuum flask, and a US court ruled it generic in 1963."@en ;
    drift:eventDate "1904"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

wdr:trigger-tierc-chernobyl-nuclear-disaster-april-1986 a drift:TriggerEvent ;
    rdfs:label "Chernobyl nuclear disaster April 1986"@en ;
    drift:eventDate "1986"^^xsd:gYear ;
