    rdfs:label "German immigration and integration debate"@en ;
    drift:eventDate "2000"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-tierc-greta-thunberg-climate-activism-and-fridaysforfuture a drift:TriggerEvent ;
    rdfs:label "Greta Thunberg climate activism and FridaysForFuture"@en ;
    drift:eventDate "2018"^^xsd:gYear ;
    drift:triggerCategory drift:Environmental .

wdr:trigger-tierc-social-media-and-digital-platform-emergence a drift:TriggerEvent ;
    rdfs:label "Social media and digital platform emergence"@en ;
    drift:eventDate "2004"^^xsd:gYear ;
    drift:triggerCategory drift:Technological .

wdr:trigger-toll-youth a drift:TriggerEvent ;
    rdfs:label "Post-war West German youth culture and rock music"@en ;
    dct:description "The emergence of rock and roll in West Germany in the late 1950s/early 1960s led young people to resemanticize 'toll' (the wild-ones/tolle quality) from a negative to an enthusiastically positive colloquial marker."@en ;
    drift:eventDate "1960"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-trommelfeuer-wwi a drift:TriggerEvent ;
    rdfs:label "First World War material battles, Verdun and the Somme 1916"@en ;
    dct:description "The great material battles of 1916 (Verdun, the Somme) made sustained barrage fire a defining experience of the First World War. The artillery term 'Trommelfeuer' passed into figurative use for any relentless verbal barrage."@en ;
    owl:sameAs wd:Q361 ;
    drift:eventDate "1916"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-turkey-trade a drift:TriggerEvent ;
    rdfs:label "Confusion of guinea fowl with the American bird"@en ;
    dct:description "Guinea fowl reached England through Turkish merchants and were called 'turkey'. When the larger New World bird arrived in the 16th century it was conflated with that fowl and inherited the country name."@en ;
    drift:eventDate "1555"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

wdr:trigger-tuxedo-park a drift:TriggerEvent ;
    rdfs:label "Dinner jacket worn at Tuxedo Park"@en ;
    dct:description "The semiformal evening jacket was first worn at the Tuxedo Park country club around 1886. The resort name attached to the garment and entered general use by 1889."@en ;
    owl:sameAs wd:Q3273900 ;
    drift:eventDate "1886"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-twitter-launch a drift:TriggerEvent ;
    rdfs:label "Launch of Twitter social media platform (2006)"@en ;
    dct:description "Twitter launched in 2006 with a deliberate bird metaphor; users organically adopted 'tweet' for a post by 2007, which Twitter later formalised in its UI."@en ;
    owl:sameAs wd:Q918 ;
    drift:eventDate "2006"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-uhu-de-brand a drift:TriggerEvent ;
    rdfs:label "Fischer markets Uhu adhesive"@en ;
    dct:description "In 1932 the pharmacist August Fischer of Buehl presented the first ready-to-use clear synthetic-resin adhesive under the brand Uhu (named after the eagle-owl). The brand became a widely used colloquial label for clear tube glue."@en ;
    owl:sameAs wd:Q63281550 ;
    drift:eventDate "1932"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

wdr:trigger-unfriend-facebook a drift:TriggerEvent ;
    rdfs:label "Facebook 'friend' / 'unfriend' interface (mid-2000s)"@en ;
    dct:description "Facebook's friends model, opened to the general public in 2006, gave 'friend' and 'unfriend' precise platform meanings; 'unfriend' was named New Oxford American Dictionary Word of the Year in 2009."@en ;
    owl:sameAs wd:Q355 ;
    drift:eventDate "2008"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-usenet-spam a drift:TriggerEvent ;
    rdfs:label "Usenet bulk posting incidents (early 1990s)"@en ;
    dct:description "Early Usenet flooding incidents (notably Canter and Siegel's 1994 bulk posting) were labelled 'spamming' by analogy with the Monty Python sketch, cementing the digital sense."@en ;
    drift:eventDate "1993"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-vandalismus-gregoire a drift:TriggerEvent ;
    rdfs:label "Henri Gregoire coins 'vandalisme' during the French Revolution"@en ;
    dct:description "In 1794 the abbe Henri Gregoire coined the French term 'vandalisme' to denounce the revolutionary destruction of monuments and artworks, invoking the Vandals' reputation for sacking Rome. The word spread into German as 'Vandalismus' with its negative sense."@en ;
    owl:sameAs wd:Q561218 ;
    drift:eventDate "1794"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-viral-web a drift:TriggerEvent ;
    rdfs:label "rise of the World Wide Web and email forwarding culture"@en ;
    dct:description "The 1990s web popularised the concept of content spreading exponentially like a biological virus. The term 'viral marketing' (Jurvetson/Draper 1997) anchored the metaphor."@en ;
    drift:eventDate "1999"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-volt-pile a drift:TriggerEvent ;
    rdfs:label "Volta invents the voltaic pile"@en ;
    dct:description "In 1800 Alessandro Volta announced the voltaic pile, the first continuous source of electric current. His name was later attached to the unit of electric potential, adopted internationally in the 1880s."@en ;
    owl:sameAs wd:Q680 ;
    drift:eventDate "1800"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-wahnsinn-ausruf a drift:TriggerEvent ;
    rdfs:label "Umgangssprachliche Aufwertung eines Negativworts zum Ausruf"@en ;
    dct:description "Kein einzelnes datierbares Ereignis. 'Wahnsinn' verblasste umgangssprachlich von 'Irrsinn' zum positiven Ausruf der Bewunderung, aehnlich wie 'irre' oder 'verrueckt'. Das Ankerjahr ist eine repraesentative Belegstelle, keine Ursache."@de ;
    drift:eventDate "1960"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-watt-engine a drift:TriggerEvent ;
    rdfs:label "Watt's improved steam engine"@en ;
    dct:description "From 1776 James Watt's separate-condenser steam engine entered commercial use, transforming industry. His name was adopted for the unit of power by the British Association in 1882."@en ;
    owl:sameAs wd:Q9041 ;
    drift:eventDate "1776"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-wutbuerger-spiegel a drift:TriggerEvent ;
    rdfs:label "Spiegel essay 'Der Wutbuerger' by Dirk Kurbjuweit"@en ;
    dct:description "The essay in Der Spiegel Issue 41 of 11 October 2010 coined the term and made it immediately prominent, tying it to Stuttgart 21 protests."@en ;
    drift:eventDate "2010"^^xsd:gYear ;
    drift:triggerCategory drift:Media .

wdr:trigger-xerox-914 a drift:TriggerEvent ;
    rdfs:label "Xerox launches the 914 copier"@en ;
    dct:description "In 1959 Haloid Xerox launched the Xerox 914, the first successful plain-paper office copier. The brand became so identified with photocopying that 'xerox' entered general use as a verb and noun, a usage the company actively discouraged."@en ;
    owl:sameAs wd:Q3570933 ;
    drift:eventDate "1959"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

wdr:trigger-yahoo-gulliver a drift:TriggerEvent ;
    rdfs:label "Swift's 'Gulliver's Travels' (1726)"@en ;
    dct:description "In Jonathan Swift's satire 'Gulliver's Travels' (1726) the Yahoos are vicious, filthy creatures of human form, contrasted with the rational Houyhnhnms. Swift coined the name; it passed into general English as a term of contempt for a brutish or loutish person."@en ;
    owl:sameAs wd:Q181488 ;
    drift:eventDate "1726"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-zeppelin-lz1 a drift:TriggerEvent ;
    rdfs:label "First flight of the airship LZ 1 over Lake Constance"@en ;
    dct:description "On 2 July 1900 the first Zeppelin rigid airship, LZ 1, made its maiden flight near Friedrichshafen. The inventor's name became the everyday term for the airship type."@en ;
    owl:sameAs wd:Q75780 ;
    drift:eventDate "1900"^^xsd:gYear ;
    drift:triggerCategory drift:Technology .

wdr:trigger-zipper-goodrich a drift:TriggerEvent ;
    rdfs:label "B.F. Goodrich markets the Zipper boot"@en ;
    dct:description "In 1923 the B.F. Goodrich Company adopted the name Zipper for rubber boots fitted with a hookless slide fastener. The catchy brand name was quickly transferred from the boots to the fastener, becoming the generic English word for the device."@en ;
    owl:sameAs wd:Q1537591 ;
    drift:eventDate "1923"^^xsd:gYear ;
    drift:triggerCategory drift:Commercial .

