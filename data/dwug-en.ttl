wdr:sense-dwug-en-attack-nn-c3 a drift:Sense ;
    drift:gloss "DWUG cluster 3 for attack (en); definition derived from the cluster's usage cohort."@en ;
    skos:notation "dwug-en-attack-nn-c3" .

wdr:attrib-dwug-en-attack-nn-annotator0-c0-g1 a drift:MeaningAttribution ;
    drift:attributesWord wdr:word-dwug-en-attack-nn ;
    drift:attributesSense wdr:sense-dwug-en-attack-nn-c0 ;
    drift:byGroup wdr:group-dwug-en-annotator0 ;
    drift:atYear "1845"^^xsd:gYear ;
    drift:attributionWeight 0.6453 ;
    prov:wasDerivedFrom <https://www2.ims.uni-stuttgart.de/data/wugs/dwug_en_v2.4.0/> ;
    skos:note "derived from 109 in-cluster pair judgment(s)" .

