# --- attack (en) ---------------------------------
wdr:word-dwug-en-attack-nn a drift:Word ;
    drift:writtenForm "attack"@en ;
    drift:language "en" ;
    ontolex:sense wdr:sense-dwug-en-attack-nn-c0, wdr:sense-dwug-en-attack-nn-c1, wdr:sense-dwug-en-attack-nn-c2, wdr:sense-dwug-en-attack-nn-c3 ;
    rdfs:label "attack"@en .

wdr:sense-dwug-en-attack-nn-c0 a drift:Sense ;
    drift:gloss "DWUG cluster 0 for attack (en); definition derived from the cluster's usage cohort."@en ;
    skos:notation "dwug-en-attack-nn-c0" .

wdr:sense-dwug-en-attack-nn-c1 a drift:Sense ;
    drift:gloss "DWUG cluster 1 for attack (en); definition derived from the cluster's usage cohort."@en ;
    skos:notation "dwug-en-attack-nn-c1" .

wdr:sense-dwug-en-attack-nn-c2 a drift:Sense ;
    drift:gloss "DWUG cluster 2 for attack (en); definition derived from the cluster's usage cohort."@en ;
