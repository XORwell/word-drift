@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
# DWUG EN → drift:MeaningAttribution (W12 ingest)
# Generated by etl/dwug_ingest.py. Input: etl/.cache/dwug_en/.
# Words: attack, ball, bit, chef, circle, donkey, edge, face.
# Each cluster in the DWUG usage graph becomes a drift:Sense; each
# DWUG annotator becomes a drift:Group; each in-cluster pair
# judgment contributes to that (annotator, cluster, grouping)'s
# drift:attributionWeight via (judgment-1)/3.
# =============================================================

<https://www2.ims.uni-stuttgart.de/data/wugs/dwug_en_v2.4.0/> a prov:Entity ;
    rdfs:label "DWUG EN v2.4.0 (Schlechtweg et al.)"@en ;
    dct:source "https://www2.ims.uni-stuttgart.de/data/wugs/" .

wdr:group-dwug-en-annotator0 a drift:Group ;
    rdfs:label "DWUG EN annotator0"@en ;
    drift:groupKind drift:Professional ;
    skos:note "Pseudonymous DWUG-EN annotator handle; used here as a Group proxy for inter-rater attribution weighting."@en .

