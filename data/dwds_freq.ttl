wdr:sense-dwds-geil-default a drift:Sense ;
    drift:connotation drift:Neutral ;
    drift:gloss "Default sense placeholder for 'geil' (DWDS frequency data)"@en .

wdr:sense-dwds-querdenker-default a drift:Sense ;
    drift:connotation drift:Neutral ;
    drift:gloss "Default sense placeholder for 'Querdenker' (DWDS frequency data)"@en .

wdr:sense-dwds-wende-default a drift:Sense ;
    drift:connotation drift:Neutral ;
    drift:gloss "Default sense placeholder for 'Wende' (DWDS frequency data)"@en .

wdr:word-dwds-geil a drift:Word ;
    rdfs:label "geil"@de ;
    ontolex:sense wdr:sense-dwds-geil-default ;
    drift:language "de"^^xsd:language ;
    drift:writtenForm "geil"@de .

wdr:word-dwds-wende a drift:Word ;
    rdfs:label "Wende"@de ;
    ontolex:sense wdr:sense-dwds-wende-default ;
    drift:language "de"^^xsd:language ;
    drift:writtenForm "Wende"@de .

wdr:word-dwds-querdenker a drift:Word ;
    rdfs:label "Querdenker"@de ;
    ontolex:sense wdr:sense-dwds-querdenker-default ;
    drift:language "de"^^xsd:language ;
    drift:writtenForm "Querdenker"@de .

wdr:corpus-dwds a drift:Corpus ;
    dct:title "DWDS Wortverlaufskurve (BBAW)"@de ;
    drift:sourceURL "https://www.dwds.de/r/plot"^^xsd:anyURI .

