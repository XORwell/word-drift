# =============================================================
# DWUG DE → drift:MeaningAttribution (W12 ingest)
# Generated by etl/dwug_ingest.py. Input: etl/.cache/dwug_de/.
# Words: Abgesang, Armenhaus, Dynamik, Eintagsfliege, Engpaß, Fuß, Knotenpunkt, Lyzeum.
# Each cluster in the DWUG usage graph becomes a drift:Sense; each
# DWUG annotator becomes a drift:Group; each in-cluster pair
# judgment contributes to that (annotator, cluster, grouping)'s
# drift:attributionWeight via (judgment-1)/3.
# =============================================================

<https://www2.ims.uni-stuttgart.de/data/wugs/dwug_de_v2.4.0/> a prov:Entity ;
    rdfs:label "DWUG DE v2.4.0 (Schlechtweg et al.)"@en ;
    dct:source "https://www2.ims.uni-stuttgart.de/data/wugs/" .

