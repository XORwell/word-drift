# --- Abgesang (de) ---------------------------------
wdr:word-dwug-de-abgesang a drift:Word ;
    drift:writtenForm "Abgesang"@de ;
    drift:language "de" ;
    ontolex:sense wdr:sense-dwug-de-abgesang-c0, wdr:sense-dwug-de-abgesang-c1, wdr:sense-dwug-de-abgesang-c2 ;
    rdfs:label "Abgesang"@de .

wdr:sense-dwug-de-abgesang-c0 a drift:Sense ;
    drift:gloss "DWUG cluster 0 for Abgesang (de); definition derived from the cluster's usage cohort."@en ;
    skos:notation "dwug-de-abgesang-c0" .

wdr:sense-dwug-de-abgesang-c1 a drift:Sense ;
    drift:gloss "DWUG cluster 1 for Abgesang (de); definition derived from the cluster's usage cohort."@en ;
