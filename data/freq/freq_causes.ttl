    drift:proposedTrigger wdr:trigger-tierc-german-green-party-founding-and-grassroots-activism ;
    drift:evidenceType drift:LexicographicNote ;
    drift:confidence 0.6 ;
    drift:hasSource wdr:src-tierc-german-green-party-founding-and-grassroots-activism ;
