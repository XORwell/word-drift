@prefix drift:   <https://w3id.org/word-drift/ontology#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wd:      <http://www.wikidata.org/entity/> .

# ================================================================
# WORD-DRIFT - Tier C causal hypotheses
# Generated: 2026-05-23
# Method: batched Haiku (gated 3-question protocol, ADR 0004)
# Restraint principle: only genuine semantic change with specific,
# datable, sourceable trigger events. Most of the 175 freq-shift
# candidates are LEFT UNDETERMINED (frequency shift != meaning shift).
# ================================================================

wdr:curator-tierc a prov:Agent ;
    rdfs:label "WORD-DRIFT Tier C curator (Haiku-assisted, 2026-05-23)"@en .



# --- Atomkraft (drift: atomkraft-1986) ---
wdr:trigger-tierc-chernobyl-nuclear-disaster-april-1986 a drift:TriggerEvent ;
    rdfs:label "Chernobyl nuclear disaster April 1986"@en ;
    drift:eventDate "1986"^^xsd:gYear ;
    drift:triggerCategory drift:Environmental ;
    .

wdr:hyp-tierc-atomkraft-1986 a drift:CausalHypothesis ;
    drift:aboutDrift wdr:drift-freq-atomkraft-1986 ;
    drift:proposedTrigger wdr:trigger-tierc-chernobyl-nuclear-disaster-april-1986 ;
    drift:evidenceType drift:FrequencyCorrelation ;
    drift:confidence 0.5 ;
    drift:hasSource wdr:corpus-google-ngrams-de ;
    prov:wasAttributedTo wdr:curator-tierc ;
    dct:date "2026-05-23"^^xsd:date .


# --- Basisdemokratie (drift: basisdemokratie-1983) ---
