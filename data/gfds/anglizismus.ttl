wdr:trigger-gfds-trigger-blackfacing-2014 a drift:TriggerEvent ;
    rdfs:label "racial sensitivity debate blackface Germany theater carnival"@en ;
    dct:description "White actors painted black in theatrical/carnival contexts; racial sensitivity debate reached Germany"@en ;
    drift:eventDate "2014"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-gfds-trigger-boostern-2021 a drift:TriggerEvent ;
    rdfs:label "COVID-19 booster vaccination campaign Germany 2021"@en ;
    dct:description "To receive a COVID-19 booster vaccination; Germanized verb from English 'boost' during pandemic"@en ;
    owl:sameAs wd:Q81068910 ;
    drift:eventDate "2021"^^xsd:gYear ;
    drift:triggerCategory drift:Pandemic .

wdr:trigger-gfds-trigger-crowdfunding-2012 a drift:TriggerEvent ;
    rdfs:label "Kickstarter internet crowdfunding startup culture rise"@en ;
    dct:description "Raising capital from many small individual contributions via internet; new startup and creative funding model"@en ;
    drift:eventDate "2012"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-gfds-trigger-fake-news-2016 a drift:TriggerEvent ;
    rdfs:label "Trump election Brexit deliberate disinformation fake news 2016"@en ;
    dct:description "Deliberately false information spread as news; Trump election and Brexit made term ubiquitous"@en ;
    drift:eventDate "2016"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-gfds-trigger-for-future-2019 a drift:TriggerEvent ;
    rdfs:label "Fridays for Future Greta Thunberg climate movement 2019"@en ;
    dct:description "Phraseological formula from Fridays for Future climate movement; applied to other activist contexts"@en ;
    drift:eventDate "2019"^^xsd:gYear ;
    drift:triggerCategory drift:Ecological .

wdr:trigger-gfds-trigger-gate-2013 a drift:TriggerEvent ;
    rdfs:label "NSA surveillance scandal Germany Watergate suffix spread"@en ;
    dct:description "Suffix for designating scandals; derived from Watergate; NSA-Gate and other scandals spread the suffix"@en ;
    drift:eventDate "2013"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-gfds-trigger-gendersternchen-2018 a drift:TriggerEvent ;
    rdfs:label "German gender-inclusive language reform feminist activism"@en ;
    dct:description "Gender star (*) for gender-inclusive writing; feminist linguistic activism in German language"@en ;
    drift:eventDate "2018"^^xsd:gYear ;
    drift:triggerCategory drift:Political .

wdr:trigger-gfds-trigger-influencer-2017 a drift:TriggerEvent ;
    rdfs:label "social media influencer marketing YouTube Instagram rise"@en ;
    dct:description "Online celebrities who exert influence on their audience; social media marketing rose to prominence"@en ;
    drift:eventDate "2017"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-gfds-trigger-leaken-2010 a drift:TriggerEvent ;
    rdfs:label "WikiLeaks Julian Assange secret information leaks"@en ;
    dct:description "Anonymous publication of secret information via internet; WikiLeaks made the term mainstream"@en ;
    drift:eventDate "2010"^^xsd:gYear ;
