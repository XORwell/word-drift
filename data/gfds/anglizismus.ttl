wdr:trigger-gfds-trigger-lockdown-2020 a drift:TriggerEvent ;
    rdfs:label "COVID-19 pandemic lockdown restrictions Germany 2020"@en ;
    dct:description "Pandemic restriction measures including contact bans; COVID-19 made the English term standard in German"@en ;
    owl:sameAs wd:Q81068910 ;
