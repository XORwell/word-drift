wdr:trigger-gfds-trigger-aura-2024 a drift:TriggerEvent ;
    rdfs:label "TikTok gaming aura points social status youth slang 2024"@en ;
    dct:description "Refers to charisma, status, and presence of a person; from gaming/TikTok 'aura points' trend"@en ;
    drift:eventDate "2024"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-gfds-trigger-babo-2013 a drift:TriggerEvent ;
    rdfs:label "Haftbefehl Babo rap song German youth slang spread 2013"@en ;
    dct:description "Turkish/Kurdish origin word for boss, leader; spread through German hip-hop especially Haftbefehl song"@en ;
    drift:eventDate "2013"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-gfds-trigger-cringe-2021 a drift:TriggerEvent ;
    rdfs:label "YouTube streaming culture youth embarrassment slang"@en ;
    dct:description "Anglicism describing embarrassing or second-hand shame situations; spread through YouTube and streaming"@en ;
    drift:eventDate "2021"^^xsd:gYear ;
    drift:triggerCategory drift:Cultural .

wdr:trigger-gfds-trigger-ehrenmann-ehrenfrau-2018 a drift:TriggerEvent ;
