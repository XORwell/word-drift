# WORD-DRIFT — VoID (Vocabulary of Interlinked Datasets) description
#
# Describes the WORD-DRIFT RDF dataset for FAIR discovery (resource-track
# submission). Triple counts are taken from data/reports/stats.json
# (regenerate with `make metadata`); the "full" layer = curated showcase +
# benchmark backbone, the "curated" layer = the hand-modelled showcase set.
#
# Persistent namespace base: https://w3id.org/word-drift/
# Source repository:         https://github.com/XORwell/word-drift
# License (data):            CC-BY-4.0

@prefix void:    <http://rdfs.org/ns/void#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix wdr:     <https://w3id.org/word-drift/resource/> .
@prefix wdv:     <https://w3id.org/word-drift/void#> .

wdv:WordDriftDataset a void:Dataset ;
    dcterms:title "WORD-DRIFT — An Open Knowledge Graph for Lexical Semantic Change"@en ;
    dcterms:description """An open RDF/SHACL knowledge graph for lexical semantic change (Bedeutungswandel) in German and English. Models word senses with diachronic attestation intervals and connotation, typed drift events (pejoration, amelioration, broadening, narrowing, metaphorization, metonymization, reversal, reappropriation), and a causal trigger layer linking real-world events to the drift they plausibly caused — each causal claim carrying a source citation and a confidence-graded hypothesis (never an asserted fact; see ADR-0004)."""@en ;
    dcterms:creator [ a foaf:Person ; foaf:name "Christian Nennemann" ] ;
    dcterms:publisher [ a foaf:Agent ; foaf:name "nennemann.de" ] ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:source <https://github.com/XORwell/word-drift> ;
    dcterms:issued "2026-05-23"^^xsd:date ;
    dcterms:modified "2026-05-24"^^xsd:date ;
    dcterms:language "en" , "de" ;
    foaf:homepage <https://github.com/XORwell/word-drift> ;

    # Vocabularies used by the dataset
    void:vocabulary <https://w3id.org/word-drift/ontology#> ;        # drift:
    void:vocabulary <http://www.w3.org/ns/lemon/ontolex#> ;          # OntoLex-Lemon
    void:vocabulary <http://www.w3.org/2006/time#> ;                 # OWL-Time
    void:vocabulary <http://www.w3.org/ns/prov#> ;                   # PROV-O
    void:vocabulary <http://www.w3.org/2004/02/skos/core#> ;         # SKOS
    void:vocabulary <http://purl.org/dc/terms/> ;                    # Dublin Core Terms

    # Counts for the FULL dataset (curated showcase + benchmark backbone).
    # Source of truth: data/reports/stats.json -> full.triples
    void:triples 37748 ;
    void:entities 530 ;          # full.words
    void:distinctSubjects 530 ;

    # An example resource that resolves under the persistent namespace.
    void:exampleResource wdr:word-querdenker ;
    void:exampleResource wdr:word-funk ;

    # SPARQL endpoint (qlever) — placeholder; replaced with the live URL on
    # deployment. The dataset is queryable via the queries/ in the repo until then.
    void:sparqlEndpoint <https://w3id.org/word-drift/sparql> ;

    # Root resource for the linked-data / w3id namespace.
    void:uriSpace "https://w3id.org/word-drift/resource/" ;
    void:rootResource wdr: ;

    void:feature <http://www.w3.org/ns/formats/Turtle> .

# ---------------------------------------------------------------------------
# Curated showcase subset (Layer 2 in docs/datasets.md): the hand-modelled
# words with sharp, documentable triggers that drive the causal layer and demo.
# Source of truth: data/reports/stats.json -> curated.triples
# ---------------------------------------------------------------------------

wdv:CuratedShowcaseSubset a void:Dataset , void:Linkset ;
    rdfs:label "WORD-DRIFT curated showcase subset"@en ;
    dcterms:description "Hand-modelled words (with the causal trigger layer) — the high-precision Layer 2 of the two-layer data strategy (ADR-0002)."@en ;
    dcterms:isPartOf wdv:WordDriftDataset ;
    void:subset wdv:WordDriftDataset ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    void:triples 7665 ;
    void:entities 142 ;          # curated.words
    void:exampleResource wdr:word-querdenker .

wdv:WordDriftDataset void:subset wdv:CuratedShowcaseSubset .

# ---------------------------------------------------------------------------
# Linkset: outbound owl:sameAs links to Wikidata (trigger events, entities)
# enable the federated SPARQL queries in queries/federated/.
# ---------------------------------------------------------------------------

wdv:WikidataLinkset a void:Linkset ;
    rdfs:label "WORD-DRIFT → Wikidata linkset"@en ;
    void:subjectsTarget wdv:WordDriftDataset ;
    void:objectsTarget <http://www.wikidata.org/> ;
    void:linkPredicate <http://www.w3.org/2002/07/owl#sameAs> .
